{% style %}
.section-{{ section.id }} {
  background: {{ section.settings.section_bg }};
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.section-{{ section.id }} .ritual-cta__wrapper {
  position: relative;
  background: {{ section.settings.wrapper_bg }};
  border-radius: 12px;
  overflow: hidden;
  padding: 80px 40px;
}

.section-{{ section.id }} .ritual-cta__mobile-image {
  display: none;
}

.section-{{ section.id }} .ritual-cta__content {
  max-width: 650px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 2;
}

.section-{{ section.id }} .ritual-cta__tag {
  color: {{ section.settings.tag_color }};
  text-align: center;
  font-family: "Mona Sans";
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 20px;
  letter-spacing: 0px;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.section-{{ section.id }} .ritual-cta__heading {
  color: {{ section.settings.heading_color }};
  margin-bottom: 16px;
}

.section-{{ section.id }} .ritual-cta__subtitle {
  color: {{ section.settings.subtitle_color }};
  text-align: center;
  font-family: "Plus Jakarta Sans";
  font-size: 16px;
  font-style: normal;
  font-weight: 400;
  line-height: 22px;
    margin-bottom: 16px;
    max-width: 607px;
    margin-inline: auto;
}

.section-{{ section.id }} .ritual-cta__button {
  display: inline-flex;
}

.section-{{ section.id }} .ritual-cta__button .btn_btn {
  background: {{ section.settings.button_bg }};
  color: {{ section.settings.button_color }};
  transition: all 0.3s ease;
}

.section-{{ section.id }} .ritual-cta__button .btn_btn:hover {
  background: {{ section.settings.button_hover_bg }};
  color: {{ section.settings.button_hover_color }};
}

.section-{{ section.id }} .ritual-cta__corner-image {
  position: absolute;
  z-index: 1;
  max-width: 200px;
}

.section-{{ section.id }} .ritual-cta__corner-image img {
  display: block;
  width: 100%;
  height: auto;
}

.section-{{ section.id }} .ritual-cta__corner-image--top-left {
  top: 0;
  left: 0;
}

.section-{{ section.id }} .ritual-cta__corner-image--top-right {
  top: 0;
  right: 0;
}

.section-{{ section.id }} .ritual-cta__corner-image--bottom-left {
  bottom: 0;
  left: 0;
}

.section-{{ section.id }} .ritual-cta__corner-image--bottom-right {
  bottom: 0;
  right: 0;
}

@media screen and (max-width: 768px) {
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .section-{{ section.id }} .ritual-cta__wrapper {
    padding: 20px 12px 24px;
  }

  .section-{{ section.id }} .ritual-cta__mobile-image {
    display: block;
    margin: 0 -12px 24px;
  }

  .section-{{ section.id }} .ritual-cta__mobile-image img {
    width: 100%;
    display: block;
  }

  .section-{{ section.id }} .ritual-cta__corner-image {
    display: none;
  }

  .section-{{ section.id }} .ritual-cta__content {
    max-width: 100%;
  }

  .section-{{ section.id }} .ritual-cta__tag {
        margin-bottom: 12px;
    }

    .section-{{ section.id }} .ritual-cta__heading {
        margin-bottom: 12px;
    }

    .section-{{ section.id }} .ritual-cta__subtitle {
        font-size: 14px;
        line-height: 120%;
        margin-bottom: 24px;
    }

    .section-{{ section.id }} .ritual-cta__button {
        max-width: 100%;
        width: 100%;
    }

    .section-{{ section.id }} .ritual-cta__button .btn_btn {
        width: 100%;
    }


}
{% endstyle %}

<section class="ritual-cta section-{{ section.id }} fade-in-section">
  <div class="page-width">
    <div class="ritual-cta__wrapper">

      {% if section.settings.mobile_image != blank %}
        <div class="ritual-cta__mobile-image">
          {{
            section.settings.mobile_image
            | image_url: width: 1600
            | image_tag:
              widths: '50,100,150,200,300,400,500,600,800,1000,1200,1400,1600',
              loading: 'lazy',
              alt: 'image'
          }}
        </div>
      {% endif %}

      {% if section.settings.top_left_image != blank %}
        <div class="ritual-cta__corner-image ritual-cta__corner-image--top-left">
          {{
            section.settings.top_left_image
            | image_url: width: 500
            | image_tag:
              widths: '100,200,300,400,500',
              loading: 'lazy',
              alt: 'image'
          }}
        </div>
      {% endif %}

      {% if section.settings.top_right_image != blank %}
        <div class="ritual-cta__corner-image ritual-cta__corner-image--top-right">
          {{
            section.settings.top_right_image
            | image_url: width: 500
            | image_tag:
              widths: '100,200,300,400,500',
              loading: 'lazy',
              alt: 'image'
          }}
        </div>
      {% endif %}

      {% if section.settings.bottom_left_image != blank %}
        <div class="ritual-cta__corner-image ritual-cta__corner-image--bottom-left">
          {{
            section.settings.bottom_left_image
            | image_url: width: 500
            | image_tag:
              widths: '100,200,300,400,500',
              loading: 'lazy',
              alt: 'image'
          }}
        </div>
      {% endif %}

      {% if section.settings.bottom_right_image != blank %}
        <div class="ritual-cta__corner-image ritual-cta__corner-image--bottom-right">
          {{
            section.settings.bottom_right_image
            | image_url: width: 500
            | image_tag:
              widths: '100,200,300,400,500',
              loading: 'lazy',
              alt: 'image'
          }}
        </div>
      {% endif %}

      <div class="ritual-cta__content">

        {% if section.settings.tag != blank %}
          <div class="ritual-cta__tag">
            {{ section.settings.tag }}
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <div class="ritual-cta__heading title_title fade-in-up">
            {{
              section.settings.heading
              | replace: '<p>', ''
              | replace: '</p>', ''
            }}
          </div>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <div class="ritual-cta__subtitle fade-in-up">
            {{
              section.settings.subtitle
              | replace: '<p></p>', ''
            }}
          </div>
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <div class="ritual-cta__button">
            <a
              href="{{ section.settings.button_link }}"
              class="btn_btn"
            >
              {{ section.settings.button_text }}
            </a>
          </div>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ritual CTA",
  "tag": "section",
  "class": "shopify-section-ritual-cta",
  "settings": [
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "header",
      "content": "Desktop Corner Images"
    },
    {
      "type": "image_picker",
      "id": "top_left_image",
      "label": "Top Left Image"
    },
    {
      "type": "image_picker",
      "id": "top_right_image",
      "label": "Top Right Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_image",
      "label": "Bottom Left Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_right_image",
      "label": "Bottom Right Image"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "wrapper_bg",
      "label": "Wrapper Background",
      "default": "#F8F6EE"
    },
    {
      "type": "color",
      "id": "tag_color",
      "label": "Tag Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#F4D236"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button Hover Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "label": "Bottom Padding"
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "label": "Bottom Padding"
    }
  ],
  "presets": [
    {
      "name": "Ritual CTA",
      "category": "Custom"
    }
  ]
}
{% endschema %}