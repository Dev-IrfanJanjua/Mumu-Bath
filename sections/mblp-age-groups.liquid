<script>
  document.addEventListener('DOMContentLoaded', function() {
    let splideInstance = null;

    function initializeSplide() {
      // Destroy existing instance if it exists
      if (splideInstance) {
        splideInstance.destroy();
        splideInstance = null;
      }

      // Only initialize on mobile/tablet
      if (window.innerWidth <= 768) {
        const splideElement = document.getElementById('mblp-steps-slider-{{ section.id }}');

        if (splideElement && typeof Splide !== 'undefined') {
          splideInstance = new Splide('#mblp-steps-slider-{{ section.id }}', {
            type: 'slide',
            perPage: 2,
            perMove: 1,
            gap: '20px',
            padding: { left: '20px', right: '20px' },
            pagination: true,
            arrows: false,
            autoplay: false,
            drag: true,
            snap: true,
            focus: '0',
            trimSpace: false,
             breakpoints: {
              500: {
                perPage: 1, 
                focus: 'center', // Ensure center focus
            trimSpace: false
              }
            },
            classes: {
              arrows: 'splide__arrows',
              arrow : 'splide__arrow',
              prev  : 'splide__arrow--prev',
              next  : 'splide__arrow--next',
            }
          });

          try {
            splideInstance.mount();
            console.log('Splide initialized successfully');
          } catch (error) {
            console.error('Error initializing Splide:', error);
          }
        }
      }
    }

    // Wait for Splide library to load
    function waitForSplide() {
      if (typeof Splide !== 'undefined') {
        initializeSplide();
      } else {
        setTimeout(waitForSplide, 100);
      }
    }

    waitForSplide();

    // Handle resize events
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        initializeSplide();
      }, 250);
    });
  });
</script>

