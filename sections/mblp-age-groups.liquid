<!-- Section: MBLP Age Groups -->
<div id="{{ section.settings.age-group-id }}"  class="{{ section.settings.age-group-class }} mblp-age-groups-main">
  <div class="container">
    <div class="mblp-age-groups-wrapper">
      <div class="mblp-age-groups-sub-wrapper">
        <!-- Section Title -->
        {% if section.settings.section_title != blank %}
          <div class="mblp-age-groups-title">
            <h2>{{ section.settings.section_title }}</h2>
          </div>
        {% endif %}

        <!-- Section Subtitle -->
        {% if section.settings.section_subtitle != blank %}
          <div class="mblp-age-groups-subtitle">
            <p>{{ section.settings.section_subtitle }}</p>
          </div>
        {% endif %}

        <!-- Steps Container -->
        <div class="mblp-age-groups-steps-container">
          <!-- Mobile Splide Slider -->
          <div class="splide mblp-steps-slider-{{ section.id }}" id="mblp-steps-slider-{{ section.id }}">
            <div class="splide__track">
              <ul class="splide__list">
                <!-- Step 1 -->
                {% if section.settings.step1_image != blank
                  or section.settings.step1_number != blank
                  or section.settings.step1_title != blank
                  or section.settings.step1_description != blank
                %}
                  <li class="splide__slide">
                    <div class="mblp-age-groups-step">
                      {% if section.settings.step1_image != blank %}
                        <div class="mblp-age-groups-step-image mblp-age-groups-step-image-card-1">
                          {{ section.settings.step1_image | image_url: width: 1500 | image_tag }}
                        </div>
                      {% endif %}

                      <div class="mblp-age-groups-main-step">

                      {% if section.settings.step1_number != blank %}
                        <div class="mblp-age-groups-step-number">
                          <span>{{ section.settings.step1_number }}</span>
                        </div>
                      {% endif %}

                      {% if section.settings.step1_title != blank %}
                        <div class="mblp-age-groups-step-title">
                          <h3>{{ section.settings.step1_title }}</h3>
                        </div>
                      {% endif %}

                      {% if section.settings.step1_description != blank %}
                        <div class="mblp-age-groups-step-description">
                          <p>{{ section.settings.step1_description }}</p>
                        </div>
                      {% endif %}
                    </div>
                    </div>
                  </li>
                {% endif %}

                <!-- Step 2 -->
                {% if section.settings.step2_image != blank
                  or section.settings.step2_number != blank
                  or section.settings.step2_title != blank
                  or section.settings.step2_description != blank
                  or section.settings.step2_link_text != blank
                %}
                  <li class="splide__slide">
                    <div class="mblp-age-groups-step">
                      {% if section.settings.step2_image != blank %}
                        <div class="mblp-age-groups-step-image">
                          {{ section.settings.step2_image | image_url: width: 1500 | image_tag }}
                        </div>
                      {% endif %}

                       <div class="mblp-age-groups-main-step">
                      {% if section.settings.step2_number != blank %}
                        <div class="mblp-age-groups-step-number">
                          <span>{{ section.settings.step2_number }}</span>
                        </div>
                      {% endif %}

                      {% if section.settings.step2_title != blank %}
                        <div class="mblp-age-groups-step-title">
                          <h3>{{ section.settings.step2_title }}</h3>
                        </div>
                      {% endif %}

                      {% if section.settings.step2_description != blank %}
                        <div class="mblp-age-groups-step-description">
                          <p>{{ section.settings.step2_description }}</p>
                        </div>
                      {% endif %}
                      </div>

                      {% if section.settings.step2_link_text != blank %}
                        <div class="mblp-age-groups-step-link">
                          {% if section.settings.step2_link_image != blank %}
                            <img src="{{ section.settings.step2_link_image | image_url: width: 24 }}" alt="Link icon">
                          {% endif %}
                          <a href="{{ section.settings.step2_link_url | default: '#' }}">
                            {{ section.settings.step2_link_text }}
                          </a>
                        </div>
                      {% endif %}
                    </div>
                  </li>
                {% endif %}

                <!-- Step 3 -->
                {% if section.settings.step3_image != blank
                  or section.settings.step3_number != blank
                  or section.settings.step3_title != blank
                  or section.settings.step3_description != blank
                %}
                  <li class="splide__slide">
                    <div class="mblp-age-groups-step">
                      {% if section.settings.step3_image != blank %}
                        <div class="mblp-age-groups-step-image">
                          {{ section.settings.step3_image | image_url: width: 1500 | image_tag }}
                        </div>
                      {% endif %}

                       <div class="mblp-age-groups-main-step">

                      {% if section.settings.step3_number != blank %}
                        <div class="mblp-age-groups-step-number">
                          <span>{{ section.settings.step3_number }}</span>
                        </div>
                      {% endif %}

                      {% if section.settings.step3_title != blank %}
                        <div class="mblp-age-groups-step-title">
                          <h3>{{ section.settings.step3_title }}</h3>
                        </div>
                      {% endif %}

                      {% if section.settings.step3_description != blank %}
                        <div class="mblp-age-groups-step-description">
                          <p>{{ section.settings.step3_description }}</p>
                        </div>
                      {% endif %}
                    </div>
                    </div>
                  </li>
                {% endif %}
              </ul>
            </div>
          </div>

          <!-- Desktop Non-Slider Layout -->
          <div class="mblp-desktop-steps">
            <!-- Step 1 -->
            {% if section.settings.step1_image != blank
              or section.settings.step1_number != blank
              or section.settings.step1_title != blank
              or section.settings.step1_description != blank
            %}
              <div class="mblp-age-groups-step">
                {% if section.settings.step1_image != blank %}
                  <div class="mblp-age-groups-step-image mblp-age-groups-step-image-card-1">
                    {{ section.settings.step1_image | image_url: width: 1500 | image_tag }}
                  </div>
                {% endif %}

                 <div class="mblp-age-groups-main-step">
                {% if section.settings.step1_number != blank %}
                  <div class="mblp-age-groups-step-number">
                    <span>{{ section.settings.step1_number }}</span>
                  </div>
                {% endif %}

                {% if section.settings.step1_title != blank %}
                  <div class="mblp-age-groups-step-title">
                    <h3>{{ section.settings.step1_title }}</h3>
                  </div>
                {% endif %}

                {% if section.settings.step1_description != blank %}
                  <div class="mblp-age-groups-step-description">
                    <p>{{ section.settings.step1_description }}</p>
                  </div>
                {% endif %}
              </div>
              </div>
            {% endif %}

            <!-- Step 2 -->
            {% if section.settings.step2_image != blank
              or section.settings.step2_number != blank
              or section.settings.step2_title != blank
              or section.settings.step2_description != blank
              or section.settings.step2_link_text != blank
            %}
              <div class="mblp-age-groups-step">
                {% if section.settings.step2_image != blank %}
                  <div class="mblp-age-groups-step-image">
                    {{ section.settings.step2_image | image_url: width: 1500 | image_tag }}
                  </div>
                {% endif %}

                 <div class="mblp-age-groups-main-step">
                {% if section.settings.step2_number != blank %}
                  <div class="mblp-age-groups-step-number">
                    <span>{{ section.settings.step2_number }}</span>
                  </div>
                {% endif %}

                {% if section.settings.step2_title != blank %}
                  <div class="mblp-age-groups-step-title">
                    <h3>{{ section.settings.step2_title }}</h3>
                  </div>
                {% endif %}

                {% if section.settings.step2_description != blank %}
                  <div class="mblp-age-groups-step-description">
                    <p>{{ section.settings.step2_description }}</p>
                  </div>
                {% endif %}

                </div>
                {% if section.settings.step2_link_text != blank %}
                  <div class="mblp-age-groups-step-link">
                    {% if section.settings.step2_link_image != blank %}
                      <img src="{{ section.settings.step2_link_image | image_url: width: 24 }}" alt="Link icon">
                    {% endif %}
                    <a href="{{ section.settings.step2_link_url | default: '#' }}">
                      {{ section.settings.step2_link_text }}
                    </a>
                  </div>
                {% endif %}
              </div>
            {% endif %}

            <!-- Step 3 -->
            {% if section.settings.step3_image != blank
              or section.settings.step3_number != blank
              or section.settings.step3_title != blank
              or section.settings.step3_description != blank
            %}
              <div class="mblp-age-groups-step">
                {% if section.settings.step3_image != blank %}
                  <div class="mblp-age-groups-step-image">
                    {{ section.settings.step3_image | image_url: width: 1500 | image_tag }}
                  </div>
                {% endif %}

                 <div class="mblp-age-groups-main-step">
                {% if section.settings.step3_number != blank %}
                  <div class="mblp-age-groups-step-number">
                    <span>{{ section.settings.step3_number }}</span>
                  </div>
                {% endif %}

                {% if section.settings.step3_title != blank %}
                  <div class="mblp-age-groups-step-title">
                    <h3>{{ section.settings.step3_title }}</h3>
                  </div>
                {% endif %}

                {% if section.settings.step3_description != blank %}
                  <div class="mblp-age-groups-step-description">
                    <p>{{ section.settings.step3_description }}</p>
                  </div>
                {% endif %}
              </div>
              </div>
            {% endif %}
          </div>

          <!-- Desktop Info Section -->
          {% if section.settings.info_icon != blank or section.settings.info_content != blank %}
            <div class="mblp-age-groups-info-section mblp-desktop-only">
              <div class="mblp-age-groups-info-wrapper">
                {% if section.settings.info_icon != blank %}
                  <div class="mblp-age-groups-info-icon">
                    {{ section.settings.info_icon | image_url: width: 48 | image_tag }}
                  </div>
                {% endif %}
                {% if section.settings.info_content != blank %}
                  <div class="mblp-age-groups-info-content">
                    {{ section.settings.info_content }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}



          <!-- Button Section -->
          {% if section.settings.button_text != blank %}
            <div class="mblp-age-groups-button-section">
              <a href="{{ section.settings.button_url | default: '#' }}" class="mblp-age-groups-button">
                {{ section.settings.button_text }}
              </a>
            </div>
          {% endif %}

        </div>
      </div>
    </div>
  </div>
</div>

