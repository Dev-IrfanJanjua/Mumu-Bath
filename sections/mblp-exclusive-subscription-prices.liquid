       .mblp-exclusive-subscription-tabs-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 60px;
  padding: 0 15px;
}

 
.mblp-exclusive-subscription-tabs-nav {
    display: flex;
     {% comment %} border-bottom: 2px solid var(--col-dark-grey);
  padding-bottom: 16px; {% endcomment %}
    gap: 14px !important;
    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
