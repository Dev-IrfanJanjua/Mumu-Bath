        /* No border for selected */
      }
      .mblp-exclusive-subscription-subscribe-btn {
          border-radius: 6px;
          width: 100%;
          cursor: pointer;
          display: flex;
          height: 44px;
          padding: 10px 0px;
          justify-content: center;
          align-items: center;
          text-align: center;
