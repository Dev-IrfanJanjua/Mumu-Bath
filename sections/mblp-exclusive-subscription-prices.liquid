  font-weight: 500;
  line-height: normal;
  position: relative;
  flex-shrink: 0; /* Prevent tabs from shrinking */
    /* Add scroll snap alignment */
    scroll-snap-align: start;
    /* Minimum width to ensure readability */
    min-width: fit-content;
}

.mblp-exclusive-subscription-tab-btn.active {
  color: var(--col-light-black);
}
