{% comment %} ==== updated marqee 2 june 2026 ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    overflow: hidden;
    margin: 0;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

.sec-{{ section.id }} .cs-feature-scroll-container-mf .page-width {
    overflow: hidden;
}

.sec-{{ section.id }} .cs-feature-scroll-track-mf {
    display: flex;
    animation: scroll-seamless-{{ section.id }} 20s linear infinite;
    width: max-content;
    will-change: transform;
    padding: 10px 0;
}

.sec-{{ section.id }} .cs-feature-icon-item-mf {
    display: flex;
    align-items: center;
    padding: 0 clamp(12px, 5.88vw, 80px);
    white-space: nowrap;
    flex-shrink: 0;
    flex-direction: row;
    gap: 8px;
    justify-content: center;
}

.sec-{{ section.id }} .cs-feature-icon-item-mf img {
    max-width: 48px;
    width: 100%;
    max-height: 48px;
    flex-shrink: 0;
    display: block;
}

.sec-{{ section.id }} .cs-feature-icon-item-mf span {
    color: #000;
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 150%;
}

.sec-{{ section.id }} .left-col {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 0 0 24px;
}
.sec-{{ section.id }} .shop-footer .icon {
    display: inline-block;
    width: var(--icon-size, 20px);
    height: var(--icon-size, 20px);
    vertical-align: middle;
    fill: none;
    stroke: white;
}
.sec-{{ section.id }} .zz-footer-link.left-con-richtext {
   padding: 8px 0 0;
}
.sec-{{ section.id }} .left-col .zz-footer-title {
  margin-bottom: 10px;
}
.sec-{{ section.id }} .left-col .text-button-large {
    font-family: "Source Code Pro" !important;
}

.sec-{{ section.id }} .cs-feature-scroll-wrapper {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
}

.sec-{{ section.id }} h2.feature-scroll-title {
    color: var(--Deep-Navy, #1A2744);
    font-family: Lora;
    font-size: 18px;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
    text-transform: uppercase;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.sec-{{ section.id }} h2.feature-scroll-title::before,
.sec-{{ section.id }} h2.feature-scroll-title::after {
    content: '';
    width: 16px;
    height: 2px;
    background-color: currentColor;
    display: block;
    border-radius: 16px;
}

@keyframes scroll-seamless-{{ section.id }} {
    0% {
        transform: translateX(0);
    }
    100% {
        transform: translateX(-33.333%);
    }
}

@media (max-width: 768px) {
    .sec-{{ section.id }} .cs-feature-icon-item-mf span {
        font-size: 14px;
    }
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .sec-{{ section.id }} .cs-feature-icon-item-mf img {
        max-width: 36px;
        height: 36px;
    }
    .sec-{{ section.id }} .left-col .zz-footer-title {
        font-size: 18px !important;
        padding: 0px;
        border: 0px;
        margin: 0 0 10px !important;
    }
    .sec-{{ section.id }} .left-col {
        flex-direction: column;
        margin: 0 0 32px;
    }
    .sec-{{ section.id }} .text-button-large {
        font-size: 14px !important;
    }
    .sec-{{ section.id }} .zz-footer-link.left-con-richtext {
        font-size: 14px;
        padding: 0px;
    }
}
{% endstyle %}


<div class="cs-feature-scroll-container-mf fade-in-section sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %}">
    <div class="page-width">
        <div class="cs-feature-scroll-wrapper">
            <div class="cs-feature-scroll-track-mf">
              {% comment %} Original set {% endcomment %}
              {% for block in section.blocks %}
                {% if block.type == 'feature' %}
                  <div class="cs-feature-icon-item-mf">
                    {% if block.settings.icon %}
                      <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.icon.alt }}" width="39" height="39" loading="eager" fetchpriority="high">
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <span>{{ block.settings.title }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}

              {% comment %} Duplicate set 1 {% endcomment %}
              {% for block in section.blocks %}
                {% if block.type == 'feature' %}
                  <div class="cs-feature-icon-item-mf">
                    {% if block.settings.icon %}
                      <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.icon.alt }}" width="39" height="39" loading="eager" fetchpriority="high">
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <span>{{ block.settings.title }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}

              {% comment %} Duplicate set 2 {% endcomment %}
              {% for block in section.blocks %}
                {% if block.type == 'feature' %}
                  <div class="cs-feature-icon-item-mf">
                    {% if block.settings.icon %}
                      <img src="{{ block.settings.icon | image_url }}" alt="{{ block.settings.icon.alt }}" width="39" height="39" loading="eager" fetchpriority="high">
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <span>{{ block.settings.title }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Scrolling Feature Icons",
  "tag": "section",
  "class": "scrolling-feature-icons",
  "settings": [
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
        "type": "image_picker",
        "id": "icon",
        "label": "Icon Mobile"
    },
    {
        "type": "text",
        "id": "mob_title",
        "label": "Text"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Feature Icons",
      "category": "Marquee"
    }
  ]
}
{% endschema %}