{% comment %} ==== Stats Icons Section ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

.sec-{{ section.id }} .si-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 0;
}

.sec-{{ section.id }} .si-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.sec-{{ section.id }} .si-icon {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
    margin-bottom: 16px;
}

.sec-{{ section.id }} .si-title {
    color: #111;
    font-family: "Mona Sans", sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: -0.4px;
    text-transform: capitalize;
    margin: 0 0 12px;
}

.sec-{{ section.id }} .si-subtitle {
    color: #000;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 120%;
    text-align: center;
    margin: 0;
}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .si-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 24px 12px;
    }

    .sec-{{ section.id }} .si-title {
        font-size: 16px;
        font-weight: 500;
        line-height: 25px;
        letter-spacing: -0.4px;
        margin: 0 0 4px;
    }

    .sec-{{ section.id }} .si-subtitle {
        font-size: 14px;
        line-height: 120%;
    }
}
{% endstyle %}

<div class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %} fade-in-section">
    <div class="page-width">
        {% if section.blocks.size > 0 %}
            <div class="si-grid">
                {% for block in section.blocks %}
                    {% if block.type == 'stat' %}
                        <div class="si-card fade-in-item" {{ block.shopify_attributes }}>
                            {% if block.settings.icon %}
                                <img
                                    src="{{ block.settings.icon | image_url }}"
                                    alt="{{ block.settings.icon.alt | default: block.settings.title }}"
                                    width="50"
                                    height="50"
                                    class="si-icon"
                                    loading="eager"
                                >
                            {% endif %}
                            {% if block.settings.title != blank %}
                                <p class="si-title">{{ block.settings.title }}</p>
                            {% endif %}
                            {% if block.settings.subtitle != blank %}
                                <p class="si-subtitle">{{ block.settings.subtitle }}</p>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{% schema %}
{
  "name": "Stats Icons",
  "tag": "section",
  "class": "stats-icons-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (50×50)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "$65 / Person"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Includes materials & tools"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Icons",
      "category": "Custom",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "title": "$65 / Person",
            "subtitle": "Includes materials & tools"
          }
        },
        {
          "type": "stat",
          "settings": {
            "title": "90 Minutes",
            "subtitle": "Guided DIY experience"
          }
        },
        {
          "type": "stat",
          "settings": {
            "title": "8–16 Guests",
            "subtitle": "Perfect group size"
          }
        },
        {
          "type": "stat",
          "settings": {
            "title": "Brooklyn, NYC",
            "subtitle": "72 Jay St location"
          }
        }
      ]
    }
  ]
}
{% endschema %}