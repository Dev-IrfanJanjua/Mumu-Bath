{% comment %} ==== Plan Your Party Section (Content + Form Placeholder) ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

.sec-{{ section.id }} .pyp-inner {
    display: grid;
    grid-template-columns: 36% calc(64% - 60px);
    gap: 60px;
    align-items: start;
}

.sec-{{ section.id }} .pyp-left {
    display: flex;
    flex-direction: column;
    gap: 60px;
}

.sec-{{ section.id }} .pyp-head {
    display: flex;
    flex-direction: column;
}

.sec-{{ section.id }} .pyp-title {
    color: {{ section.settings.title_color }};
    margin: 0;
}

.sec-{{ section.id }} .pyp-subtitle {
    color: #101010;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px;
    margin-top: 16px;
    margin-bottom: 0;
}

.sec-{{ section.id }} .pyp-card {
    border-radius: 8px;
    border: 1px solid rgba(17, 12, 9, 0.10);
    background: {{ section.settings.card_bg_color }};
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.sec-{{ section.id }} .pyp-block-item {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
}

.sec-{{ section.id }} .pyp-block-icon {
    width: 21px;
    height: 21px;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
}

.sec-{{ section.id }} .pyp-block-text {
    color: #16100C;
    font-family: "Mona Sans", sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 600;
    line-height: 20px;
    margin: 0;
}

.sec-{{ section.id }} .pyp-response-text {
    color: {{ section.settings.response_text_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-style: italic;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: -0.32px;
    margin: 0;
}

.sec-{{ section.id }} .pyp-form {
    width: 100%;
}

.sec-{{ section.id }} .pyp-card-mobile{
    display: none;
}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .pyp-inner {
        grid-template-columns: 1fr;
        gap: 0;
    }

    .sec-{{ section.id }} .pyp-left {
        gap: 0;
    }

    .sec-{{ section.id }} .pyp-head {
        text-align: center;
        margin-bottom: 40px;
    }

    .sec-{{ section.id }} .pyp-subtitle {
        color: #000;
        text-align: center;
        font-size: 14px;
        line-height: 120%;
    }

    .sec-{{ section.id }} .pyp-card {
        margin-top: 0;
    }

    .sec-{{ section.id }} .pyp-card-mobile{
        display: flex;
        margin-top: 24px;
    }

    .sec-{{ section.id }} .pyp-card-desktop{
        display: none;
    }

}
{% endstyle %}

<div id="party-form-section" class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %} fade-in-section">
    <div class="page-width">
        <div class="pyp-inner">

            {% comment %} Left: Content (head + card) — desktop order {% endcomment %}
            <div class="pyp-left">

                <div class="pyp-head">
                    {% if section.settings.title != blank %}
                        <h2 class="pyp-title title_title fade-in-up">{{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                    {% endif %}
                    {% if section.settings.subtitle != blank %}
                        <p class="pyp-subtitle fade-in-up">{{ section.settings.subtitle }}</p>
                    {% endif %}
                </div>

                {% if section.blocks.size > 0 or section.settings.response_text != blank %}
                    <div class="pyp-card pyp-card-desktop">
                        {% for block in section.blocks %}
                            {% if block.type == 'contact_item' %}
                                {% if block.settings.link != blank %}
                                    <a href="{{ block.settings.link }}" class="pyp-block-item fade-in-item" {{ block.shopify_attributes }}>
                                {% else %}
                                    <div class="pyp-block-item fade-in-item" {{ block.shopify_attributes }}>
                                {% endif %}

                                {% if block.settings.icon %}
                                    <img
                                        src="{{ block.settings.icon | image_url }}"
                                        alt=""
                                        width="21"
                                        height="21"
                                        class="pyp-block-icon"
                                        loading="lazy"
                                        aria-hidden="true"
                                    >
                                {% endif %}
                                {% if block.settings.text != blank %}
                                    <p class="pyp-block-text">{{ block.settings.text }}</p>
                                {% endif %}

                                {% if block.settings.link != blank %}
                                    </a>
                                {% else %}
                                    </div>
                                {% endif %}
                            {% endif %}
                        {% endfor %}

                        {% if section.settings.response_text != blank %}
                            <p class="pyp-response-text">{{ section.settings.response_text }}</p>
                        {% endif %}
                    </div>
                {% endif %}

            </div>

            {% comment %} Right: Form (desktop) {% endcomment %}
            <div class="pyp-form">
                {{ section.settings.form_code }}
            </div>

            {% if section.blocks.size > 0 or section.settings.response_text != blank %}
                <div class="pyp-card pyp-card-mobile">
                    {% for block in section.blocks %}
                        {% if block.type == 'contact_item' %}
                            {% if block.settings.link != blank %}
                                <a href="{{ block.settings.link }}" class="pyp-block-item fade-in-item" {{ block.shopify_attributes }}>
                            {% else %}
                                <div class="pyp-block-item fade-in-item" {{ block.shopify_attributes }}>
                            {% endif %}

                            {% if block.settings.icon %}
                                <img
                                    src="{{ block.settings.icon | image_url }}"
                                    alt=""
                                    width="21"
                                    height="21"
                                    class="pyp-block-icon"
                                    loading="lazy"
                                    aria-hidden="true"
                                >
                            {% endif %}
                            {% if block.settings.text != blank %}
                                <p class="pyp-block-text">{{ block.settings.text }}</p>
                            {% endif %}

                            {% if block.settings.link != blank %}
                                </a>
                            {% else %}
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    {% if section.settings.response_text != blank %}
                        <p class="pyp-response-text">{{ section.settings.response_text }}</p>
                    {% endif %}
                </div>
            {% endif %}

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Plan Your Party",
  "tag": "section",
  "class": "plan-your-party-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Share a few details and our gifting team will respond with curated recommendations shaped around your recipients, occasion, and budget."
    },
    {
      "type": "header",
      "content": "Contact Card"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "textarea",
      "id": "response_text",
      "label": "Response Time Text",
      "default": "Average response time: 1–2 business days"
    },
    {
      "type": "color",
      "id": "response_text_color",
      "label": "Response Time Text Color",
      "default": "#27500A"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "liquid",
      "id": "form_code",
      "label": "Form Embed Code",
      "info": "Paste your form app's embed code or Liquid snippet here. No styling is applied to this area."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F6EE"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "contact_item",
      "name": "Contact Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (21×21)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "sasha.chou@mumubath.com"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Plan Your Party",
      "category": "Custom",
      "blocks": [
        { "type": "contact_item", "settings": { "text": "sasha.chou@mumubath.com" } },
        { "type": "contact_item", "settings": { "text": "72 Jay St, Brooklyn, NY 11201" } }
      ]
    }
  ]
}
{% endschema %}