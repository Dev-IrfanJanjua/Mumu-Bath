</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    let splideInstance = null;

    function initializeSplide() {
      // Destroy existing instance if it exists
      if (splideInstance) {
        splideInstance.destroy();
        splideInstance = null;
      }

      // Only initialize on mobile/tablet
      if (window.innerWidth <= 768) {
        const splideElement = document.getElementById('mblp-workshop-party-steps-slider');

        if (splideElement && typeof Splide !== 'undefined') {
          splideInstance = new Splide('#mblp-workshop-party-steps-slider', {
            type: 'slide',
            perPage: 1,
            perMove: 1,
            gap: '14px',
            padding: { left: '30px', right: '75px' },
            pagination: true,
            arrows: false,
            autoplay: false,
            drag: true,
            snap: true,
            focus: 'center',
            trimSpace: false,
            classes: {
              arrows: 'splide__arrows',
              arrow : 'splide__arrow',
              prev  : 'splide__arrow--prev',
              next  : 'splide__arrow--next',
            }
          });

          try {
            splideInstance.mount();
            console.log('Splide initialized successfully');
          } catch (error) {
            console.error('Error initializing Splide:', error);
          }
        }
      }
    }

    // Wait for Splide library to load
    function waitForSplide() {
      if (typeof Splide !== 'undefined') {
        initializeSplide();
      } else {
        setTimeout(waitForSplide, 100);
      }
    }

    waitForSplide();

    // Handle resize events
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        initializeSplide();
      }, 250);
    });
  });
</script>

