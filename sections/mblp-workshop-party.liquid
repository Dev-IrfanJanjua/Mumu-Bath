<!-- Section: MBLP Workshop party -->
<div class="mblp-workshop-party-main-{{ section.id }}">
  <div class="container">
    <div class="mblp-workshop-party-wrapper">
      <div class="mblp-workshop-party-sub-wrapper">
        <!-- Section Title -->
        {% if section.settings.section_title != blank %}
          <div class="mblp-workshop-party-title">
            <h2>{{ section.settings.section_title }}</h2>
          </div>
        {% endif %}

        <!-- Section Subtitle -->
        {% if section.settings.section_subtitle != blank %}
          <div class="mblp-workshop-party-subtitle">
            <p>{{ section.settings.section_subtitle }}</p>
          </div>
        {% endif %}

        <!-- Steps Container -->
        <div class="mblp-workshop-party-steps-container">
          <!-- Mobile Splide Slider -->
          <div class="splide mblp-workshop-party-steps-slider" id="mblp-workshop-party-steps-slider">
            <div class="splide__track">
              <ul class="splide__list">
                <!-- Step 1 -->
                <li class="splide__slide">
                  <div class="mblp-workshop-party-step">
                    {% if section.settings.step1_image != blank %}
                      <div class="mblp-workshop-party-step-image">
                        {{ section.settings.step1_image | image_url: width: 1500 | image_tag }}
                      </div>
                    {% endif %}

                    {% if section.settings.step1_number != blank %}
                      <div class="mblp-workshop-party-step-number">
                        <span>{{ section.settings.step1_number }}</span>
                      </div>
                    {% endif %}

                    {% if section.settings.step1_title != blank %}
                      <div class="mblp-workshop-party-step-title">
                        <h3>{{ section.settings.step1_title }}</h3>
                      </div>
                    {% endif %}

                    {% if section.settings.step1_description != blank %}
                      <div class="mblp-workshop-party-step-description">
                        <p>{{ section.settings.step1_description }}</p>
                      </div>
                    {% endif %}
                  </div>
                </li>

                <!-- Step 2 -->
                <li class="splide__slide">
                  <div class="mblp-workshop-party-step">
                    {% if section.settings.step2_image != blank %}
                      <div class="mblp-workshop-party-step-image">
                        {{ section.settings.step2_image | image_url: width: 1500 | image_tag }}
                      </div>
                    {% endif %}

                    {% if section.settings.step2_number != blank %}
                      <div class="mblp-workshop-party-step-number">
                        <span>{{ section.settings.step2_number }}</span>
                      </div>
                    {% endif %}

                    {% if section.settings.step2_title != blank %}
                      <div class="mblp-workshop-party-step-title">
                        <h3>{{ section.settings.step2_title }}</h3>
                      </div>
                    {% endif %}

                    {% if section.settings.step2_description != blank %}
                      <div class="mblp-workshop-party-step-description">
                        <p>{{ section.settings.step2_description }}</p>
                      </div>
                    {% endif %}

                    {% if section.settings.step2_link_text != blank %}
                      <div class="mblp-workshop-party-step-link">
                        {% if section.settings.step2_link_image != blank %}
                          <img src="{{ section.settings.step2_link_image | image_url: width: 24 }}" alt="Link icon">
                        {% endif %}
                        <a href="{{ section.settings.step2_link_url | default: '#' }}">
                          {{ section.settings.step2_link_text }}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                </li>

                <!-- Step 3 -->
                <li class="splide__slide">
                  <div class="mblp-workshop-party-step">
                    {% if section.settings.step3_image != blank %}
                      <div class="mblp-workshop-party-step-image">
                        {{ section.settings.step3_image | image_url: width: 1500 | image_tag }}
                      </div>
                    {% endif %}

                    {% if section.settings.step3_number != blank %}
                      <div class="mblp-workshop-party-step-number">
                        <span>{{ section.settings.step3_number }}</span>
                      </div>
                    {% endif %}

                    {% if section.settings.step3_title != blank %}
                      <div class="mblp-workshop-party-step-title">
                        <h3>{{ section.settings.step3_title }}</h3>
                      </div>
                    {% endif %}

                    {% if section.settings.step3_description != blank %}
                      <div class="mblp-workshop-party-step-description">
                        <p>{{ section.settings.step3_description }}</p>
                      </div>
                    {% endif %}
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- Desktop Non-Slider Layout -->
          <div class="mblp-desktop-steps">
            <!-- Step 1 -->
            <div class="mblp-workshop-party-step">
              {% if section.settings.step1_image != blank %}
                <div class="mblp-workshop-party-step-image">
                  {{ section.settings.step1_image | image_url: width: 1500 | image_tag }}
                </div>
              {% endif %}

              {% if section.settings.step1_number != blank %}
                <div class="mblp-workshop-party-step-number">
                  <span>{{ section.settings.step1_number }}</span>
                </div>
              {% endif %}

              {% if section.settings.step1_title != blank %}
                <div class="mblp-workshop-party-step-title">
                  <h3>{{ section.settings.step1_title }}</h3>
                </div>
              {% endif %}

              {% if section.settings.step1_description != blank %}
                <div class="mblp-workshop-party-step-description">
                  <p>{{ section.settings.step1_description }}</p>
                </div>
              {% endif %}
            </div>

            <!-- Step 2 -->
            <div class="mblp-workshop-party-step">
              {% if section.settings.step2_image != blank %}
                <div class="mblp-workshop-party-step-image">
                  {{ section.settings.step2_image | image_url: width: 1500 | image_tag }}
                </div>
              {% endif %}

              {% if section.settings.step2_number != blank %}
                <div class="mblp-workshop-party-step-number">
                  <span>{{ section.settings.step2_number }}</span>
                </div>
              {% endif %}

              {% if section.settings.step2_title != blank %}
                <div class="mblp-workshop-party-step-title">
                  <h3>{{ section.settings.step2_title }}</h3>
                </div>
              {% endif %}

              {% if section.settings.step2_description != blank %}
                <div class="mblp-workshop-party-step-description">
                  <p>{{ section.settings.step2_description }}</p>
                </div>
              {% endif %}

              {% if section.settings.step2_link_text != blank %}
                <div class="mblp-workshop-party-step-link">
                  {% if section.settings.step2_link_image != blank %}
                    <img src="{{ section.settings.step2_link_image | image_url: width: 24 }}" alt="Link icon">
                  {% endif %}
                  <a href="{{ section.settings.step2_link_url | default: '#' }}">
                    {{ section.settings.step2_link_text }}
                  </a>
                </div>
              {% endif %}
            </div>

            <!-- Step 3 -->
            <div class="mblp-workshop-party-step">
              {% if section.settings.step3_image != blank %}
                <div class="mblp-workshop-party-step-image">
                  {{ section.settings.step3_image | image_url: width: 1500 | image_tag }}
                </div>
              {% endif %}

              {% if section.settings.step3_number != blank %}
                <div class="mblp-workshop-party-step-number">
                  <span>{{ section.settings.step3_number }}</span>
                </div>
              {% endif %}

              {% if section.settings.step3_title != blank %}
                <div class="mblp-workshop-party-step-title">
                  <h3>{{ section.settings.step3_title }}</h3>
                </div>
              {% endif %}

              {% if section.settings.step3_description != blank %}
                <div class="mblp-workshop-party-step-description">
                  <p>{{ section.settings.step3_description }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

