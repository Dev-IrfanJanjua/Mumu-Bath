{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

{% liquid
  assign selected_collection = collections[section.settings.collection]
%}

<section
  class="hair-featured-collection fade-in-section section-{{ section.id }} {% if section.settings.pdp_style %} pdp-{{ section.id }} {% endif %} "
  style="
    background-color: {{ section.settings.bg_color }};
  "
>
  {% unless section.settings.pdp_style %}
    <div class="page-width">
  {% endunless %}

    {% if section.settings.heading != blank %}
      <div class="hair-featured-collection__header fade-in-left">
        <h2 class="hair__heading">
          {{ section.settings.heading }}
        </h2>

        {% unless section.settings.pdp_style %}
          <div class="hair-featured-collection__arrows">
            <div class="hair-swiper-prev">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="21" viewBox="0 0 11 21" fill="none">
              <path d="M9.43981 1.47566e-06C9.43981 4.01397 6.62597 7.53 0.999998 10.5514C6.62597 13.0665 9.43981 16.3023 9.4398 20.2589" stroke="black" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            </div>
  
            <div class="hair-swiper-next">
              <svg xmlns="http://www.w3.org/2000/svg" width="26" height="40" viewBox="0 0 26 40" fill="none">
              <path d="M16.0016 9.87012C16.0016 13.8841 18.8154 17.4001 24.4414 20.4216C18.8154 22.9366 16.0016 26.1725 16.0016 30.129" stroke="black" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        {% endunless %}
      </div>
    {% endif %}

    <div class="swiper hair-featured-swiper fade-in-up">
      <div class="swiper-wrapper">

        {% if selected_collection != blank %}

          {% for product in selected_collection.products limit: 12 %}

            <div class="swiper-slide">
              {%- render 'new-product-card', product: product, section: section -%}
            </div>

          {% endfor %}

        {% endif %}

      </div>

      <div class="hair-swiper-pagination"></div>

    </div>

    {% if selected_collection != blank and section.settings.button_text != blank %}
      <div class="hair-featured-collection__footer">

        <a
          href="{{ selected_collection.url }}"
          class="hair-collection-btn tfc__view-all"
        >
          {{ section.settings.button_text }}
        </a>

      </div>
    {% endif %}

    {% unless section.settings.pdp_style %}
    </div>
    {% endunless %}
  
</section>

<style>

.hair-featured-collection {
  padding-top:{{ section.settings.padding_top_desktop }}px;
  padding-bottom:{{ section.settings.padding_bottom_desktop }}px;
}

.hair-featured-collection  .page-width {
  padding-right:0px;
}
.hair-featured-collection__header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:20px;
  margin-bottom:48px;
  padding-right:40px;
}

.hair__heading{
  margin:0;
}

.hair-featured-collection__arrows{
  display:flex;
  align-items:center;
  gap:0px;
}

.hair-swiper-prev,
.hair-swiper-next{
  width:40px;
  height:40px;
  border-radius:50%;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
}

.hair-product-card{
  background:#fff;
  border-radius:8px;
  overflow:hidden;
  transition:.4s ease;
  height:100%;
}

{% comment %} .hair-product-card:hover{
  transform:translateY(-6px);
} {% endcomment %}

.hair-product-card__image-wrapper{
  position:relative;
  display:block;
  overflow:hidden;
  aspect-ratio:1/1;
  border-radius:10px;
}

.hair-product-card__image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  transition:.5s ease;
}

.secondary-image{
  position:absolute;
  inset:0;
  opacity:0;
}


.hair-product-card__content{
  padding:12px;
  border-radius: 6px;
background: var(--Stone, #F8F6EE);
margin:2px 0 0;
}

.hair-product-card__title{
  margin:0 0 6px;

}

.hair-product-card__title a{
  color:inherit;
  text-decoration:none;
  color: var(--rhokea-com-swamp, var(--color-cyan-4, #001116));
  font-family: "Mona Sans" !important;
  font-size: 18px;
  font-style: normal;
  font-weight: 600;
  line-height: 24px; /* 133.333% */
  text-transform: capitalize;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hair-product-rating{
  display:flex;
  align-items:center;
  gap:5px;
  margin-bottom:13px;
}

.hair-rating-image{
  max-width:85px;
  height:auto;
}
.hair-rating-text p {
color: #3B332F;
font-family: Helvetica;
font-size: 12px;
font-style: normal;
font-weight: 400;
line-height: 20px; /* 166.667% */
text-transform: uppercase;
margin:0px;
}
.hair-rating-text strong{
  color: #3B332F;
font-family: Helvetica;
font-size: 14px;
font-style: normal;
font-weight: 400;
line-height: 20px; /* 142.857% */
margin:0px;
}

.hair-product-price{
  color: var(--heyharper-com-mine-shaft, var(--color-grey-20, #343233));
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 16.8px; /* 105% */
    letter-spacing: var(--letter-spacing-0_08, 0.08px);
}
.hair-product-compare-price {
  color: #909090;
font-family: "Plus Jakarta Sans";
font-size: 15px;
font-style: normal;
font-weight: 300;
line-height: 16.8px; /* 112% */
letter-spacing: var(--letter-spacing-0_08, 0.08px);
text-decoration-line: line-through;
margin:0px;
}
.atc-btn button {
  display: flex;
max-width: 190px;
width: 100%;
height: 32px;
padding: 8px 70px;
width:100%;
justify-content: center;
align-items: center;
gap: var(--item-spacing-xxs, 4px);
border-radius: 5px;
border: var(--stroke-weight-1, 1px) solid rgba(0, 0, 0, 0.00);
background: var(--Yellow, #FBDD40);
color: #000;
text-align: center;
font-family: "Plus Jakarta Sans";
font-size: 16px;
font-style: normal;
font-weight: 500;
line-height: 14.04px; /* 87.75% */
letter-spacing: 0.086px;
  cursor:pointer;
  transition:.3s;
}
.atc-btn button {
  transition: background-color 0.25s ease, color 0.25s ease;
  white-space: nowrap;
}
.atc-btn button:hover svg path {
  fill: #fff;
  transition: fill 0.3s ease;
}

.atc-btn button:hover,
.atc-btn button:focus-visible {
  background-color: var(--hero-btn-hover-bg, #000000) !important;
  color: #ffffff;
  outline-offset: 3px;
}

.hair-featured-collection__footer{
  text-align:center;
  margin-top:48px;
}

.hair-collection-btn{
  text-decoration:none;
  display:inline-block;
  color: var(--studs-com-black, var(--color-black-solid, #000));
  text-align: center;
  font-family: "Plus Jakarta Sans";
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 22.4px; /* 160% */
  letter-spacing: 0;
  text-transform: uppercase;
  border-bottom:1.5px solid black;
  padding: 0 0 2px;
}

.hair-swiper-pagination{
  position:relative !important;
  margin-top:25px;
  display:none;
}

.section-{{ section.id }} .hair-swiper-pagination .swiper-pagination-bullet{
  background:#ffffff;
  opacity:1;
  border:1.3px solid black;
}


.feeat-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
    gap: 10px;
}

{% comment %} === product stylling ===== {% endcomment %}

{% if section.settings.pdp_style %}

.pdp-{{ section.id }}{
  padding-left: 40px;
}

.pdp-{{ section.id }} .hair-featured-collection__header {
    margin-bottom: 32px;
}

.pdp-{{ section.id }} .hair__heading {
    font-size: 48px;
    letter-spacing: 0;
}

.pdp-{{ section.id }}  .hair-swiper-pagination {
    position: static !important;
    margin-top: 32px;
    text-align: center;
    display: block;
}

.pdp-{{ section.id }} .hair-swiper-pagination span.swiper-pagination-bullet.swiper-pagination-bullet-active {
    border-radius: 4px;
    border: 1px solid #142E2A;
    background: #142E2A;
    max-width: 26px;
    width: 100%;
}

@media screen and (max-width: 768px){

.pdp-{{ section.id }}{
  padding-left: 16px;
}

.pdp-{{ section.id }} .hair-featured-collection__header {
    margin-bottom: 28px;
}

.pdp-{{ section.id }} .hair__heading {
    font-size: 30px;
    letter-spacing: 0px;
}

.pdp-{{ section.id }} .hair-product-card__title {
    min-height: unset;
    line-height: 0px;
}

.pdp-{{ section.id }} .hair-swiper-pagination {
    position: static !important;
    margin-top: 22px;
    text-align: center;
    display: block;
}

}

{% endif %}


@media(max-width:767px){

  .hair-featured-collection{
    padding-top:{{ section.settings.padding_top_mobile }}px;
    padding-bottom:{{ section.settings.padding_bottom_mobile }}px;
  }

  .hair-featured-collection__header {
        margin-bottom: 28px;
        padding-right: 16px;
        gap: 0px;
        justify-content:center;
    }

  .hair-product-card__content{
     padding: 10.309px 12.886px;
  }
  .hair-product-card__title  {
     line-height:0px;
  }

  .hair-product-card__title a {
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 18.899px; /* 118.119% */
    text-transform: capitalize;
  }
  .hair-featured-collection__arrows {
     display:none;
  }
  .hair-product-rating {   
        gap: 3px;
        margin-bottom: 11px;
    }
    
.hair-swiper-pagination {
    margin-top: 22px;
    display: flex;
    justify-content: center;
}
.section-{{ section.id }} .hair-swiper-pagination .swiper-pagination-bullet-active {
    background: black;
    opacity: 1;
    width: 26px;
    height: 8px;
    border-radius: 4px;
}

.hair-featured-collection__footer {
    margin-top: 22px;
}
.hair-featured-collection .swiper-horizontal>.swiper-pagination-bullets, .swiper-pagination-bullets.swiper-pagination-horizontal, .swiper-pagination-custom, .swiper-pagination-fraction {
    bottom: var(--swiper-pagination-bottom, 8px);
    top: 0px;
    left: 0;
    width: 100%;
}
.atc-btn button span {

font-size: 13.745px;
font-style: normal;
font-weight: 500;
line-height: 12.061px; /* 87.75% */
letter-spacing: 0.074px;
}
.atc-btn button {
  display: flex;
max-width: 190px;
height: 32px;
padding: 8px 45px;
}

}

</style>

<script>
document.addEventListener('DOMContentLoaded', function(){

  new Swiper('.hair-featured-swiper', {
    slidesPerView:1.3,
    spaceBetween:12,
    loop:true,
    speed:1000,

    navigation:{
      nextEl:'.hair-swiper-next',
      prevEl:'.hair-swiper-prev'
    },

    pagination:{
      el:'.hair-swiper-pagination',
      clickable:true
    },

    breakpoints:{
      768:{
        slidesPerView:2.5,
        spaceBetween:12
      },
      990:{
        slidesPerView:4,
        spaceBetween:14
      }
    }
  });

});
</script>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "pdp_style",
      "label": "Enable PDP Stylling"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers You'll Love"
    },
    {
      "type": "image_picker",
      "id": "rating_image",
      "label": "Default Rating Image"
    },
    {
      "type": "richtext",
      "id": "rating_text",
      "label": "Default Rating Text",
      
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP BEST SELLERS"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Desktop Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Desktop Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Mobile Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 40
    },
    {
       "type":"checkbox",
       "id":"cs-btn",
       "label":"Button with icon"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Slider"
    }
  ]
}
{% endschema %}