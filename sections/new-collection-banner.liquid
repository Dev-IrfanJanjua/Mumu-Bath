{% comment %} Collection Banner Section {% endcomment %}

<style>
  .section-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    min-height: {{ section.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
  }

  /* ── Background images – absolute positioned HTML elements ── */
  .section-{{ section.id }} .cb-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .section-{{ section.id }} .cb-bg__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.bg_position }};
    display: block;
  }

  .section-{{ section.id }} .cb-bg__img--mobile {
    display: none;
  }

  .section-{{ section.id }} .cb-bg__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  /* ── Inner layout ── */
  .section-{{ section.id }} .cb-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 0;
  }

  /* ── Left content ── */
  .section-{{ section.id }} .cb-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 612px;
  }

  .section-{{ section.id }} .cb-title.title_title {
    color: {{ section.settings.title_color }};
    font-family: "Mona Sans", sans-serif;
    font-size: 60px;
    font-weight: 500;
    line-height: 66px;
    letter-spacing: -0.86px;
    text-transform: capitalize;
    margin: 0;
  }

  .section-{{ section.id }} .cb-subtitle {
    color: {{ section.settings.subtitle_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    margin: 0;
  }

  .section-{{ section.id }} .cb-btn.btn_btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10.07px;
    width: 209.5px;
    padding: 18px 30px;
    border-radius: 41px;
    background: {{ section.settings.btn_bg_color }} !important;
    color: {{ section.settings.btn_text_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 148%;
    text-transform: capitalize;
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-sizing: border-box;
    white-space: nowrap;
    transition: all 0.3s ease;
    margin-top: 34px;
  }

  .faq-banner-{{ section.id }} a.cb-btn.btn_btn{
    margin-top: 14px;
  }

  .section-{{ section.id }} .cb-btn.btn_btn:hover{
      background: #000 !important;
      color: #fff;
    }

  /* Right side is just empty — image fills via absolute bg */
  .section-{{ section.id }} .cb-right {
    display: block;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      min-height: {{ section.settings.min_height_mobile }}px;
      align-items: flex-start;
    }

    /* swap bg images */
    .section-{{ section.id }} .cb-bg__img--desktop {
      display: none;
    }

    .section-{{ section.id }} .cb-bg__img--mobile {
      display: block;
      object-position: {{ section.settings.bg_position_mobile }};
    }

    /* single column, content on top */
    .section-{{ section.id }} .cb-inner {
      grid-template-columns: 1fr;
    }

    .section-{{ section.id }} .cb-right {
      display: none;
    }

    .section-{{ section.id }} .cb-content {
      max-width: 100%;
      align-items: center;
      text-align: center;
    }

    .section-{{ section.id }} .cb-title.title_title {
      font-size: 36px;
      line-height: 42px;
      text-align: center;
    }

    .section-{{ section.id }} .cb-subtitle {
      font-size: 14px;
      line-height: 22px;
      text-align: center;
      max-width: 316px;
    }

    .section-{{ section.id }} .cb-btn.btn_btn {
        font-size: 14px;
        line-height: 148%;
        padding: 14px 28px;
        max-width: 100%;
        width: 100%;
        margin-top: 8px;
    }

    .faq-banner-{{ section.id }} a.cb-btn.btn_btn {
        font-size: 18px;
        line-height: 140%;
        margin-top: 14px;
    }

  }
</style>

<section class="section-{{ section.id }} {{ section.settings.add_class }}-{{ section.id }}" id="shopify-section-{{ section.id }}">

  <!-- Absolute background images -->
  <div class="cb-bg" aria-hidden="true">
    {%- if section.settings.bg_image_desktop != blank -%}
      {{
        section.settings.bg_image_desktop
        | image_url: width: 2400
        | image_tag:
          class: 'cb-bg__img cb-bg__img--desktop',
          loading: 'eager',
          fetchpriority: 'high',
          alt: ''
      }}
    {%- endif -%}

    {%- if section.settings.bg_image_mobile != blank -%}
      {{
        section.settings.bg_image_mobile
        | image_url: width: 1200
        | image_tag:
          class: 'cb-bg__img cb-bg__img--mobile',
          loading: 'eager',
          fetchpriority: 'high',
          alt: ''
      }}
    {%- elsif section.settings.bg_image_desktop != blank -%}
      {{
        section.settings.bg_image_desktop
        | image_url: width: 1200
        | image_tag:
          class: 'cb-bg__img cb-bg__img--mobile',
          loading: 'eager',
          alt: ''
      }}
    {%- endif -%}

    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="cb-bg__overlay"></div>
    {%- endif -%}
  </div>

  <div class="page-width">
    <div class="cb-inner">

      <!-- Left: content -->
      <div class="cb-content">

        {%- comment -%} Title: custom > collection title > blank {%- endcomment -%}
        {%- if section.settings.custom_title != blank -%}
          {%- assign banner_title = section.settings.custom_title | replace: '<p>', '' | replace: '</p>', '' -%}
        {%- elsif collection and collection.title != blank -%}
          {%- assign banner_title = collection.title -%}
        {%- else -%}
          {%- assign banner_title = nil -%}
        {%- endif -%}

        {%- if banner_title -%}
          <h1 class="cb-title title_title">{{ banner_title }}</h1>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="cb-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- if section.settings.btn_label != blank -%}
          {%- if section.settings.btn_url != blank -%}
            {%- assign btn_href = section.settings.btn_url -%}
          {%- elsif collection -%}
            {%- assign btn_href = collection.url -%}
          {%- else -%}
            {%- assign btn_href = '#' -%}
          {%- endif -%}
          <a href="{{ btn_href }}" class="cb-btn btn_btn">{{ section.settings.btn_label }}</a>
        {%- endif -%}

      </div>

      <!-- Right: spacer (bg image fills visually) -->
      {% comment %} <div class="cb-right"></div> {% endcomment %}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "add_class",
      "label": "Add Extra Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "custom_title",
      "label": "Custom Title",
      "info": "<p>Leave blank to use the collection's title automatically</p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Leave blank to hide",
      "default": "Skin-loving essentials that deliver a healthy natural glow with a smooth, breathable finish."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL",
      "info": "Leave blank to use the collection URL automatically"
    },
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "select",
      "id": "bg_position",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" },
        { "value": "right top", "label": "Right Top" },
        { "value": "right bottom", "label": "Right Bottom" }
      ],
      "default": "center center"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image (Mobile)",
      "info": "Falls back to desktop image if left blank"
    },
    {
      "type": "select",
      "id": "bg_position_mobile",
      "label": "Image Position (Mobile)",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center bottom"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Size"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Min Height (Desktop)",
      "default": 500
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Min Height (Mobile)",
      "default": 600
    },
    {
      "type": "header",
      "content": "Spacing – Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing – Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 300,
      "step": 3,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 300,
      "info": "Increase to push content above bottom image area on mobile"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#EEE7DD"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#FBDD3F"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
