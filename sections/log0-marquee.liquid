{% comment %} Glitch-free marquee — CSS only, no JS, Safari + Android safe {% endcomment %}

{% stylesheet %}

/* ─── Container ─────────────────────────────────────── */
.feature-scroll-container-mf {
    overflow: hidden;
    background: #242221;
    padding: 37px 0;
    margin: 0;
    /* Keeps Safari from merging this layer with parent */
    isolation: isolate;
    -webkit-isolation: isolate;
}

/* ─── Track ──────────────────────────────────────────── */
.feature-scroll-track-mf {
    display: flex;
    flex-wrap: nowrap;
    width: max-content;
    /* translate3d forces GPU layer — stays promoted the whole time */
    -webkit-animation: marquee-scroll 20s linear infinite;
    animation: marquee-scroll 20s linear infinite;
    /* NO will-change — Safari drops layers on will-change between cycles */
    /* NO backface-visibility — not needed, causes issues on some iOS */
    /* NO translateZ — translate3d in keyframes handles it */
}

/* ─── Each item ──────────────────────────────────────── */
.feature-icon-item-mf {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-right: 80px;
    white-space: nowrap;
}

/* ─── Image ──────────────────────────────────────────── */
.feature-icon-item-mf img {
    display: block;
    width: 100%;
    max-width: 140px;
    height: auto;
    aspect-ratio: 137 / 37;
    object-fit: contain;
    /* Prevent Safari from lazy-loading mid-scroll */
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
}

/* ─── Keyframes ─────────────────────────────────────────
   We have 4 identical sets.
   Shift by exactly -25% = 1 set width.
   translate3d keeps the element on the GPU compositor
   the entire duration — no layer drop at loop boundary.
─────────────────────────────────────────────────────── */
@-webkit-keyframes marquee-scroll {
    0%   { -webkit-transform: translate3d(0, 0, 0); transform: translate3d(0, 0, 0); }
    100% { -webkit-transform: translate3d(-25%, 0, 0); transform: translate3d(-25%, 0, 0); }
}
@keyframes marquee-scroll {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-25%, 0, 0); }
}

/* ─── Responsive ─────────────────────────────────────── */
@media screen and (max-width: 767px) {
    .feature-scroll-container-mf {
        padding: 20px 0;
    }
    .feature-icon-item-mf {
        margin-right: 10px;
    }
    .feature-icon-item-mf img {
        max-width: 100px;
        aspect-ratio: 22 / 7;
    }
}

/* ─── PDP variant ────────────────────────────────────── */
.pdp-marquee .feature-scroll-container-mf {
    padding: 16px 0;
}

/* ─── Accessibility: respect reduced motion ──────────── */
@media (prefers-reduced-motion: reduce) {
    .feature-scroll-track-mf {
        -webkit-animation: none;
        animation: none;
    }
}

{% endstylesheet %}


<div class="feature-scroll-container-mf sec-{{ section.id }} {% if section.settings.pdp %}pdp-marquee{% endif %}">
    <div class="feature-scroll-track-mf">

        {% comment %} Set 1 — original {% endcomment %}
        {% for block in section.blocks %}
            {% if block.type == 'feature' %}
                <div class="feature-icon-item-mf" {{ block.shopify_attributes }}>
                    {% if block.settings.icon %}
                        <img
                            src="{{ block.settings.icon | image_url: width: 280 }}"
                            alt="{{ block.settings.icon.alt | escape }}"
                            width="280"
                            height="auto"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                        >
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        {% comment %} Set 2 — duplicate {% endcomment %}
        {% for block in section.blocks %}
            {% if block.type == 'feature' %}
                <div class="feature-icon-item-mf" aria-hidden="true">
                    {% if block.settings.icon %}
                        <img
                            src="{{ block.settings.icon | image_url: width: 280 }}"
                            alt=""
                            width="280"
                            height="auto"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                        >
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        {% comment %} Set 3 — duplicate {% endcomment %}
        {% for block in section.blocks %}
            {% if block.type == 'feature' %}
                <div class="feature-icon-item-mf" aria-hidden="true">
                    {% if block.settings.icon %}
                        <img
                            src="{{ block.settings.icon | image_url: width: 280 }}"
                            alt=""
                            width="280"
                            height="auto"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                        >
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        {% comment %} Set 4 — duplicate (extra buffer for Safari) {% endcomment %}
        {% for block in section.blocks %}
            {% if block.type == 'feature' %}
                <div class="feature-icon-item-mf" aria-hidden="true">
                    {% if block.settings.icon %}
                        <img
                            src="{{ block.settings.icon | image_url: width: 280 }}"
                            alt=""
                            width="280"
                            height="auto"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                        >
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

    </div>
</div>


{% schema %}
{
  "name": "Scrolling Feature Icons",
  "tag": "section",
  "class": "scrolling-feature-icons",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide",
      "label": "Hide Desktop"
    },
    {
      "type": "checkbox",
      "id": "pdp",
      "label": "PDP Styling"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Logo Marquee",
      "category": "Custom"
    }
  ]
}
{% endschema %}
