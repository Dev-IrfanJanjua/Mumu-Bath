<script>
// Add this to your existing JavaScript section
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = '{{ section.id }}';
  const section = document.querySelector(`#DP--${sectionId}`);
  
  if (section) {
    // Check if success message exists and clear URL parameters
    const successMessage = section.querySelector('.wbs-pck__form-reply--success');
    if (successMessage) {
      // Clear URL parameters after 3 seconds to prevent the message from showing on reload
      setTimeout(function() {
        if (window.location.search.includes('contact%5Bform%5D') || window.location.hash) {
          // Use replaceState to remove parameters without reloading
          const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.replaceState({}, document.title, cleanUrl);
        }
      }, 3000);
    }
    
    // Your existing code for asterisk styling
    const labels = section.querySelectorAll('.wbs-pck__element label, .wbs-pck__element legend');
    labels.forEach(label => {
      const text = label.textContent;
      if (text.includes('*')) {
        const textWithoutAsterisk = text.replace('*', '');
        label.innerHTML = textWithoutAsterisk + '<span style="color: red; font-family: \'Dm Sans Medium\' !important;">*</span>';
      }
    });
  }
});
</script>
