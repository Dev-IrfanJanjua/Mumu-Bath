

{% liquid
  assign tab_blocks = section.blocks | where: 'type', 'tab'
%}

<section
  class="tfc-section fade-in-section"
  id="tfc-section-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    --tfc-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --tfc-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --tfc-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --tfc-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --tfc-tab-active-bg: {{ section.settings.tab_active_bg }};
    --tfc-tab-active-color: {{ section.settings.tab_active_color }};
    --tfc-tab-inactive-bg: {{ section.settings.tab_inactive_bg }};
    --tfc-tab-inactive-color: {{ section.settings.tab_inactive_color }};
    --tfc-tab-border-color: {{ section.settings.tab_border_color }};
  "
>
  <div class="page-width">

    {%- comment -%} ── HEADING + ARROWS ── {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <div class="tfc__header">
        <h2 class="hair__heading">{{ section.settings.heading }}</h2>

        
      </div>
    {% endif %}

    {%- comment -%} ── TABS — all from blocks ── {%- endcomment -%}
     <div class="tabs-head fade-in-left">
        {%- if tab_blocks.size > 0 -%}
        <div class="tfc__tabs" role="tablist" aria-label="Product categories">
            {%- for block in tab_blocks -%}
            <button
                class="tfc__tab{% if forloop.first %} tfc__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="tfc-panel-{{ block.id }}"
                data-tab="{{ block.id }}"
                {{ block.shopify_attributes }}
            >
                {{ block.settings.tab_label | escape }}
            </button>
            {%- endfor -%}
        </div>
        {%- endif -%}
        <div class="tfc__arrows">
          <button class="tfc-swiper-prev" aria-label="Previous products">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="21" viewBox="0 0 11 21" fill="none">
              <path d="M9.43981 1.47566e-06C9.43981 4.01397 6.62597 7.53 0.999998 10.5514C6.62597 13.0665 9.43981 16.3023 9.4398 20.2589" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="tfc-swiper-next" aria-label="Next products">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="21" viewBox="0 0 11 21" fill="none">
              <path d="M1.56019 1.47566e-06C1.56019 4.01397 4.37403 7.53 10 10.5514C4.37403 13.0665 1.56019 16.3023 1.56021 20.2589" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
    </div>

    {%- comment -%} ── PANELS WRAPPER — needed for absolute stacking ── {%- endcomment -%}
    <div class="tfc__panels-wrapper fade-in-up">
      {%- for block in tab_blocks -%}
        {%- assign tab_collection = collections[block.settings.collection] -%}
        <div
          class="tfc__panel{% if forloop.first %} tfc__panel--active{% endif %}"
          id="tfc-panel-{{ block.id }}"
          role="tabpanel"
          data-panel="{{ block.id }}"
          data-collection-url="{{ tab_collection.url }}"
        >
          {%- render 'tfc-swiper',
            products: tab_collection.products,
            section: section,
            swiper_id: section.id,
            suffix: block.id
          -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} ── VIEW ALL — URL updates with active tab ── {%- endcomment -%}
    <div class="tfc__footer">
      {%- assign first_tab_block = tab_blocks | first -%}
      {%- assign first_collection = collections[first_tab_block.settings.collection] -%}
      <a
        class="tfc__view-all hair-collection-btn"
        href="{{ first_collection.url | default: '/collections/all' }}"
      >
        {{ section.settings.button_text | default: 'View All' }}
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Section ── */
  .tfc-section {
    padding-top: var(--tfc-pt-mobile, 48px);
    padding-bottom: var(--tfc-pb-mobile, 48px);
  }
  @media (min-width: 750px) {
    .tfc-section {
      padding-top: var(--tfc-pt-desktop, 72px);
      padding-bottom: var(--tfc-pb-desktop, 72px);
    }
  }

  .tfc-section  .page-width {
    padding-right:0px;
  }
  .tfc__header, .tabs-head {
      padding-right:40px;
  }
  /* ── Header ── */
  .tfc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 24px;
  }
  .tabs-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
    margin-block-end: 48px;
}
  .tfc__heading { margin: 0; }

  /* ── Arrows ── */
  .tfc__arrows {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-shrink: 0;
  }
  .tfc-swiper-prev,
  .tfc-swiper-next {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    color: currentColor;
    transition: opacity 0.2s;
  }
  .tfc-swiper-prev:hover,
  .tfc-swiper-next:hover { opacity: 0.6; }
  .tfc-swiper-prev.swiper-button-disabled,
  .tfc-swiper-next.swiper-button-disabled { opacity: 0.3; cursor: default; }

  /* ── Tabs ── */
  .tfc__tabs {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-block-end: 0;
  }
  .tfc__tab {
    background-color: var(--tfc-tab-inactive-bg, transparent);
    color: var(--tfc-tab-inactive-color, #1a1a1a);
    border: 1px solid var(--tfc-tab-border-color, #d0cac3);
    border-radius: 999px;
    padding: 12px 24px;

    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    border-radius: 500px;
border: 0.4px solid #000;
background: #FFF;
color: #000;
font-family: "Plus Jakarta Sans";
font-size: 15px;
font-style: normal;
font-weight: 400;
line-height: 120%; /* 18px */
text-transform: capitalize;
    
  }
  .tfc__tab--active,
  .tfc__tab:hover {
    background-color: var(--tfc-tab-active-bg, #1a1a1a);
    color: var(--tfc-tab-active-color, #fff);
    border-color: var(--tfc-tab-active-bg, #1a1a1a);
  }

  /* ── Panels wrapper — gives a height context for absolute children ── */
  .tfc__panels-wrapper {
    position: relative;
  }

  /* ── Panels — opacity fade, NO display:none ── */
  .tfc__panel {
    opacity: 0;
    pointer-events: none;
    position: absolute;
    inset: 0;
    width: 100%;
    transition: opacity 0.3s ease;
    /* height: 0 prevents the wrapper from collapsing while inactive */
    overflow: hidden;
    height: 0;
  }
  .tfc__panel--active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
    height: auto;
    overflow: visible;
  }

  /* ── Swiper overrides ── */
  .tfc-swiper { overflow: hidden; }
  .tfc-swiper .swiper-slide { height: auto; }

  
  .hair-product-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.35s ease;
  }
  .hair-product-card__image.secondary-image {
    position: absolute;
    inset: 0;
    opacity: 0;
  }


  /* default state */
.hair-product-card__image.primary-image {
  opacity: 1;
}

/* only apply hover swap IF secondary image exists */
.hair-product-card__image-wrapper:has(.secondary-image):hover .primary-image {
  opacity: 0;
}

.hair-product-card__image-wrapper:has(.secondary-image):hover .secondary-image {
  opacity: 1;
}
 

  /* ── Footer ── */
/* ── Footer ── */

  .tfc__footer {
    text-align: center;
    margin: 45px 0 0;
}



  @media (max-width: 750px) {
      .tfc__arrows {
          display:none;
      }
      .tfc-section .swiper-horizontal>.swiper-pagination-bullets, .swiper-pagination-bullets.swiper-pagination-horizontal, .swiper-pagination-custom, .swiper-pagination-fraction {
            bottom: var(--swiper-pagination-bottom, 8px);
            top: 0px;
            left: 0;
            width: 100%;
     }
    .tfc__footer {
    margin: 22px 0 0;
}

.tfc__tabs {
    display: flex;
    align-items: flex-start;
    margin-block-end: 0;
    overflow-x: auto;
    flex-wrap: nowrap;
    gap:8px;
    padding-bottom: 2px;
    scrollbar-width: none;
}
.tfc__header {
    margin-block-end: 20px;
}
.tfc__header { padding-right:16px;}
.tabs-head {
     padding-right:4px;
     margin: 0 0 28px;
}
.tfc__tab {
    padding: 8px 16px;
    cursor: pointer;
    border: 1px solid #000 !important;
  }

}
</style>

<script>
(function () {
  /* Wait for Swiper to be available since it's deferred */
  function waitForSwiper(cb) {
    if (typeof Swiper !== 'undefined') { cb(); return; }
    const t = setInterval(function () {
      if (typeof Swiper !== 'undefined') { clearInterval(t); cb(); }
    }, 50);
  }

  waitForSwiper(function () {
    const section = document.getElementById('tfc-section-{{ section.id }}');
    if (!section) return;

    const tabs    = section.querySelectorAll('.tfc__tab');
    const panels  = section.querySelectorAll('.tfc__panel');
    const viewAll = section.querySelector('.tfc__view-all');
    const prevBtn = section.querySelector('.tfc-swiper-prev');
    const nextBtn = section.querySelector('.tfc-swiper-next');

    /* ── Init a swiper inside a panel ── */
    function initSwiper(panel) {
      const el = panel.querySelector('.tfc-swiper');
      if (!el || el._swiperReady) return el && el._swiperInstance;
      el._swiperReady = true;

      const inst = new Swiper(el, {
        slidesPerView: 1.2,
        spaceBetween: 12,
        loop:true,
        speed:1000,
        navigation: { prevEl: prevBtn, nextEl: nextBtn },
        pagination: {
          el: el.querySelector('.tfc-swiper-pagination'),
          clickable: true
        },
        breakpoints: {
          480:  { slidesPerView: 2,  spaceBetween: 14 },
          750:  { slidesPerView: 3,  spaceBetween: 16 },
          990:  { slidesPerView: 4,  spaceBetween: 20 },
          1200: { slidesPerView: 4,  spaceBetween: 24 }
        }
      });

      el._swiperInstance = inst;
      return inst;
    }

    /* ── Switch tabs ── */
    function activateTab(tab) {
      const target = tab.dataset.tab;

      tabs.forEach(function (t) {
        const on = t === tab;
        t.classList.toggle('tfc__tab--active', on);
        t.setAttribute('aria-selected', on);
      });

      panels.forEach(function (p) {
        const on = p.dataset.panel === target;
        p.classList.toggle('tfc__panel--active', on);

        if (on) {
          /* Init swiper (no-op if already done) then update nav */
          const inst = initSwiper(p);
          if (inst) { inst.navigation.update(); inst.update(); }

          /* Update View All URL */
          const url = p.dataset.collectionUrl;
          if (viewAll && url) viewAll.href = url;
        }
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () { activateTab(tab); });
    });

    /* ── Bootstrap first panel ── */
    const firstPanel = section.querySelector('.tfc__panel--active');
    if (firstPanel) initSwiper(firstPanel);
  });
})();
</script>

{% schema %}
{
  "name": "Tabbed Collection",
  "tag": "section",
  "class": "section-tabbed-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top — Desktop (px)",
      "min": 0, "max": 200, "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom — Desktop (px)",
      "min": 0, "max": 200, "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top — Mobile (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom — Mobile (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 48
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Colour",
      "default": "#f9f5f0"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty Products To Excite The Senses"
    },
    {
      "type": "header",
      "content": "Tab Styles"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Active Tab Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Active Tab Text Colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_inactive_bg",
      "label": "Inactive Tab Background",
      "default": "rgba(255,255,255,0)"
    },
    {
      "type": "color",
      "id": "tab_inactive_color",
      "label": "Inactive Tab Text Colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "Inactive Tab Border Colour",
      "default": "#d0cac3"
    },
    {
      "type": "header",
      "content": "Rating Fallback"
    },
    {
      "type": "image_picker",
      "id": "rating_image",
      "label": "Default Rating Stars Image"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Default Rating Text",
      "default": "4.7 (240)"
    },
    {
      "type": "header",
      "content": "Footer Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "View All Button Text",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Add to Cart Button"
    },
    {
      "type": "checkbox",
      "id": "cs-btn",
      "label": "Show Cart Icon on Button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Label",
          "default": "Category"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed Collection",
      "settings": {
        "heading": "Beauty Products To Excite The Senses",
        "button_text": "View All",
        "tab_active_bg": "#1a1a1a",
        "tab_active_color": "#ffffff",
        "tab_border_color": "#d0cac3",
        "rating_text": "4.7 (240)",
        "cs-btn": true
      },
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "All" } },
        { "type": "tab", "settings": { "tab_label": "Soaps" } },
        { "type": "tab", "settings": { "tab_label": "Body Butter & Body Cream" } },
        { "type": "tab", "settings": { "tab_label": "Face" } },
        { "type": "tab", "settings": { "tab_label": "Candles & Fragrance" } },
        { "type": "tab", "settings": { "tab_label": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
