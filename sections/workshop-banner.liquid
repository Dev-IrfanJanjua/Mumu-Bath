{% comment %} ==== Create Connect Celebrate Banner Section ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

.sec-{{ section.id }} .ccc-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: center;
}

.sec-{{ section.id }} .ccc-content {
    display: flex;
    flex-direction: column;
}

.sec-{{ section.id }} .ccc-title {
    color: #000;
    font-family: "Mona Sans", sans-serif;
    font-size: 60px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: 0;
    text-transform: capitalize;
    margin: 0 0 12px;
    max-width: 500px;
}

.sec-{{ section.id }} .ccc-subtitle {
    color: #000;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 0;
    margin: 0 0 24px;
    max-width: 555px;
}

.sec-{{ section.id }} .ccc-image {
    border-radius: 20px;
    overflow: hidden;
}

.sec-{{ section.id }} .ccc-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 20px;
}

.sec-{{ section.id }} .ccc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 242px;
    width: 100%;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border-color: {{ section.settings.btn_bg_color }};
}

.sec-{{ section.id }} .ccc-btn:hover {
    background-color: {{ section.settings.btn_hover_bg_color }};
    color: {{ section.settings.btn_hover_text_color }};
    border-color: {{ section.settings.btn_hover_bg_color }};
}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .page-width{
        padding: 0;
    }

    .sec-{{ section.id }} .ccc-content {
        padding: 0 16px;
    }

    .sec-{{ section.id }} .ccc-inner {
        grid-template-columns: 1fr;
        gap: 24px;
    }

    .sec-{{ section.id }} .ccc-image {
        order: -1;
        border-radius: 0;
    }

    .sec-{{ section.id }} .ccc-image img{
        border-radius: 0;
    }

    .sec-{{ section.id }} .ccc-title {
        font-size: 36px;
        line-height: 42px;
        margin: 0 0 12px;
    }

    .sec-{{ section.id }} .ccc-subtitle {
        font-size: 14px;
        line-height: 120%;
        margin: 0 0 24px;
    }

    .sec-{{ section.id }} .ccc-btn {
        max-width: 210px;
        font-size: 16px;
    }
}
{% endstyle %}

<div class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %}">
    <div class="page-width">
        <div class="ccc-inner">

            {% comment %} Left: Content {% endcomment %}
            <div class="ccc-content">

                {% if section.settings.title != blank %}
                    <h1 class="ccc-title title_title">
                        {{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}
                    </h1>
                {% endif %}

                {% if section.settings.subtitle != blank %}
                    <p class="ccc-subtitle">{{ section.settings.subtitle }}</p>
                {% endif %}

                {% if section.settings.btn_label != blank %}
                    
                    <a    href="{{ section.settings.btn_url }}"class="ccc-btn btn_btn">
                        {{ section.settings.btn_label }}
                    </a>
                {% endif %}

            </div>

            {% comment %} Right: Image {% endcomment %}
            <div class="ccc-image">
                {% if section.settings.image %}
                    <img
                        src="{{ section.settings.image | image_url: width: 1200 }}"
                        alt="{{ section.settings.image.alt | default: section.settings.title | strip_html }}"
                        width="{{ section.settings.image.width }}"
                        height="{{ section.settings.image.height }}"
                        loading="eager"
                        fetchpriority="high"
                    >
                {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                {% endif %}
            </div>

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Workshop Banner",
  "tag": "section",
  "class": "ccc-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Create, Connect, & Celebrate At Mumu Bath.</p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Join hands-on bath, body, and self-care workshops — or bring your own creative pop-up to our welcoming community space in Brooklyn."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Host With Us"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#F5E44A"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_bg_color",
      "label": "Button Hover Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_text_color",
      "label": "Button Hover Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F6EE"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Workshop Banner",
      "category": "Custom"
    }
  ]
}
{% endschema %}