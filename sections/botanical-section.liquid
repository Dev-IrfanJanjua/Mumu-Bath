    },
    {
      "type": "header",
      "content": "Colors – Header"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1A2744"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#1A2744"
    },
    {
      "type": "header",
      "content": "Colors – Cards"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#1A2744"
    },
    {
      "type": "color",
      "id": "card_desc_color",
      "label": "Card Description Color",
      "default": "#1A2744"
    },
    {
      "type": "color",
      "id": "image_placeholder_bg",
      "label": "Image Placeholder Background",
      "default": "#E8E4DA"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Name",
          "default": "Organic Olive Oil"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Paprika brings antioxidant-rich care for a fresh, radiant glow."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Botanicals Grid",
      "blocks": [
        {
