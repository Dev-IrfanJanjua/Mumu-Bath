      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap Between Cards",
      "default": 24
    },
    {
      "type": "header",
      "content": "Spacing – Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Spacing – Mobile"
    },
    {
      "type": "range",
