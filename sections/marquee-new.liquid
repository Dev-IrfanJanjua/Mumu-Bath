{% comment %} {% comment %}
  Herbies Reviews Section
  File: sections/herbies-reviews.liquid
  Font: var(--new-font) (add via theme assets or Google Fonts)
{% endcomment %}

<style>
  
  #herbies-reviews-{{ section.id }} {
    --bg: {{ section.settings.bg_color }};
    --text-dark: {{ section.settings.text_dark_color }};
    --text-muted: {{ section.settings.text_muted_color }};
    --card-bg: {{ section.settings.card_bg_color }};
    --star-color: {{ section.settings.star_color }};
    --verified-color: {{ section.settings.verified_color }};
    --title-size: {{ section.settings.title_size }}px;
    --subtitle-size: {{ section.settings.subtitle_size }}px;
    --rating-size: {{ section.settings.rating_size }}px;
    --review-body-size: {{ section.settings.review_body_size }}px;
    --reviewer-size: {{ section.settings.reviewer_size }}px;
    --section-padding-top: {{ section.settings.section_padding_top }}px;
    --section-padding-bottom: {{ section.settings.section_padding_bottom }}px;
    --card-padding: {{ section.settings.card_padding }}px;
    --card-radius: {{ section.settings.card_radius }}px;
    --card-gap: {{ section.settings.card_gap }}px;
    --marquee-height: {{ section.settings.marquee_height }}px;
    --marquee-speed: {{ section.settings.marquee_speed }}s;
    --stars-size: {{ section.settings.stars_size }}px;
    --heading-spacing: {{ section.settings.heading_spacing }}px;
    --title-mobile-size: {{ section.settings.title_mobile_size }}px;
    --marquee-height-mobile: {{ section.settings.marquee_height_mobile }}px;
    --section-padding-mobile: {{ section.settings.section_padding_mobile }}px;
  }

  #herbies-reviews-{{ section.id }} .hr-section {
    background: var(--bg);
    padding: var(--section-padding-top) 0 var(--section-padding-bottom);
    font-family: 'var(--new-font)', sans-serif;
    text-align: center;
    overflow: hidden;
    box-sizing: border-box;
  }
  .hr-section *{
    letter-spacing: 0;
  }

  #herbies-reviews-{{ section.id }} .hr-rating-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: var(--heading-spacing);
  }

  #herbies-reviews-{{ section.id }} .hr-stars {
    color: var(--star-color);
    font-size: var(--stars-size);
    letter-spacing: 2px;
    line-height: 0;
  }

  #herbies-reviews-{{ section.id }} .hr-rating-text {
   color: var(--www-yorkshiredentalsuite-co-uk-mine-shaft, var(--color-grey-23, #3D3838));
    font-family: Saans;
    font-size: 14.2px;
    font-style: normal;
    font-weight: 500;
    line-height: var(--line-height-17, 17px);
    letter-spacing: var(--letter-spacing--0_43, -0.427px);
  }

  #herbies-reviews-{{ section.id }} .hr-title p{
    color: #000;
    text-align: center;
    font-family: Poppins;
    font-size: 46px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
    letter-spacing: -0.5px;
    text-transform: capitalize;
    margin: 0;
  }
  #herbies-reviews-{{ section.id }} .hr-title p strong{
    color: var(--primary, #0F5A47);
  }

  #herbies-reviews-{{ section.id }} .hr-subtitle {
    color: #000;
    font-family: Saans;
    font-size: 16.2px;
    font-style: normal;
    font-weight: 400;
    line-height: 19px;
    padding: 16px 0 36px 0; 
    margin: 0;
  }

  /* ── Marquee ── */
  #herbies-reviews-{{ section.id }} .hr-marquee-wrap {
    width: 100%;
    overflow: hidden;
  }

  #herbies-reviews-{{ section.id }} .hr-marquee-track {
    display: flex;
    gap: 100px;
    animation: hr-marquee-scroll-{{ section.id }} var(--marquee-speed) linear infinite;
    width: max-content;
  }

  #herbies-reviews-{{ section.id }} .hr-marquee-track:hover {
    animation-play-state: paused;
  }

  #herbies-reviews-{{ section.id }} .hr-marquee-img {
    max-width: var(--marquee-height);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    flex-shrink: 0;
    display: block;
  }

  @keyframes hr-marquee-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Swiper ── */
  #herbies-reviews-{{ section.id }} .hr-swiper-wrap {
    position: relative;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
    padding-left: 50px;
  }

  #herbies-reviews-{{ section.id }} .hr-swiper-track {
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #herbies-reviews-{{ section.id }} .hr-slide {
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .hr-title.animate-item {
    max-width: 680px;
    margin: 0 auto;
  }

  #herbies-reviews-{{ section.id }} .hr-card {
    background: var(--card-bg);
    border-radius: var(--card-radius);
    padding: var(--card-padding);
    text-align: left;
    box-sizing: border-box;
    width: 100%;
  }

  #herbies-reviews-{{ section.id }} .hr-card-rating-row {
    display: flex;
    align-items: center;
    justify-content: start;
    gap: 8px;
    margin: 0px;
  }

  #herbies-reviews-{{ section.id }} .hr-card-score {
    color: var(--herbies-dark-charcoal, #2A2929);
    text-align: center;
    font-family: var(--new-font);
    font-size: 14.2px;
    font-style: normal;
    font-weight: 570;
    line-height: 17px;
    letter-spacing: -0.43px;
  }

  #herbies-reviews-{{ section.id }} .hr-card-stars {
    color: var(--star-color);
    font-size: 13px;
    letter-spacing: 1px;
    line-height: 0;
  }

  /* ── Read More ── */
  #herbies-reviews-{{ section.id }} .hr-card-text p {
    color: #000;
    font-family: Saans;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 19px;
    padding: 20px 0 8px 0;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-height: calc(19px * 4 + 20px);
    transition: max-height 0.45s ease;
  }

  #herbies-reviews-{{ section.id }} .hr-card-text p.hr-expanded {
    display: block;
    max-height: 1000px;
    overflow: visible;
  }

  #herbies-reviews-{{ section.id }} .hr-card-text p strong {
    font-weight: 700;
  }

  #herbies-reviews-{{ section.id }} .hr-read-more-btn {
    background: none;
    border: none;
    padding: 0 0 16px 0;
    cursor: pointer;
    color: #000;
    font-family: Saans;
    font-size: 14px;
    font-weight: 600;
    text-decoration: underline;
    display: inline-block;
    line-height: 1;
  }

  #herbies-reviews-{{ section.id }} .hr-read-more-btn.hr-rm-hidden {
    display: none;
  }

  #herbies-reviews-{{ section.id }} .hr-card-text_title p {
    color: #000;
    font-family: Saans;
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 20px;
    margin: 0;
        min-height: 40px;
  }

  #herbies-reviews-{{ section.id }} .hr-card-text_title {
    padding-top: 16px;
  }

  #herbies-reviews-{{ section.id }} .hr-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  #herbies-reviews-{{ section.id }} .hr-reviewer {
    color: var(--herbies-dark-charcoal, #2A2929);
    text-align: center;
    font-family: Saans;
    font-size: 14px;
    font-style: normal;
    font-weight: 570;
    line-height: 17px;
  }

  #herbies-reviews-{{ section.id }} .hr-verified {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--herbies-dark-charcoal, #2A2929);
    text-align: center;
    font-family: Saans;
    font-size: 14px;
    font-style: normal;
    font-weight: 380;
    line-height: 17px;
  }

  #herbies-reviews-{{ section.id }} .hr-verified svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* ── Controls ── */
  #herbies-reviews-{{ section.id }} .hr-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid #ccc;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }

  #herbies-reviews-{{ section.id }} .hr-btn:hover {
    border-color: var(--text-dark);
    background: rgba(0,0,0,0.05);
  }

  #herbies-reviews-{{ section.id }} .hr-btn svg {
    width: 16px;
    height: 16px;
  }

  #herbies-reviews-{{ section.id }} .hr-dots {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  #herbies-reviews-{{ section.id }} .hr-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  #herbies-reviews-{{ section.id }} .hr-dot.active {
    background: var(--text-dark);
    transform: scale(1.2);
  }

  .cs_reviews-swiper-pagination {
    position: unset;
    width: fit-content !important;
  }

  .cs_reviews-swiper-pagination .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    opacity: 1;
    background: transparent;
    border: 1px solid var(--herbies-dark-charcoal, #0F5A47);
  }

  .cs_reviews-swiper-pagination .swiper-pagination-bullet-active {
    background: var(--herbies-dark-charcoal, #0F5A47);
    width: 22px;
    border-radius: 33554400px;
  }

  .hr-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    margin-top: 25px;
  }

  .cs_reiv_butt-prev {
    transform: rotate(180deg);
    line-height: 0;
    cursor: pointer;
  }

  .cs_reiv_butt-next {
    line-height: 0;
    cursor: pointer;
  }

  .hr-controls .swiper-button-disabled svg {
    opacity: 0.2;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #herbies-reviews-{{ section.id }} .hr-rating-text {
      font-size: 14px; 
    }

    #herbies-reviews-{{ section.id }} .hr-marquee-track {
      display: flex;
      gap: 11px;
    }

    #herbies-reviews-{{ section.id }} .hr-card {
      padding: 16px;
      border-radius: 8px;
    }

    #herbies-reviews-{{ section.id }} .hr-card-text_title {
      padding-top: 14px;
    }

    #herbies-reviews-{{ section.id }} .hr-card-text_title p {
      font-size: 16px;
      font-weight: 600; 
    }

    #herbies-reviews-{{ section.id }} .hr-section {
      padding: var(--section-padding-mobile) 0;
    }

    #herbies-reviews-{{ section.id }} .hr-title p {
      font-size: var(--title-mobile-size);
      margin-bottom: 10px;
    }

    #herbies-reviews-{{ section.id }} .hr-card-text strong {
      font-weight: 500;
    }

    #herbies-reviews-{{ section.id }} .hr-marquee-img {
      max-width: var(--marquee-height-mobile);
      width: auto;
      height: auto;
    }

    #herbies-reviews-{{ section.id }} .hr-rating-row {
      margin-bottom: 10px;
    }

    #herbies-reviews-{{ section.id }} .hr-subtitle {
      margin: 0 0 24px;
      padding: 0;
      font-size: 15.2px;
    }

    #herbies-reviews-{{ section.id }} .hr-swiper-wrap {
      padding-left: 20px;
    }

    #herbies-reviews-{{ section.id }} .hr-card-text p {
      font-size: 14px;
      padding: 16px 0 8px 0;
    }

    #herbies-reviews-{{ section.id }} .hr-card-text {
      font-size: 16px;
    }

    .hr-controls {
      justify-content: center;
      margin-top: 10px;
      padding: 0 20px;
    }

    .cs_reiv_butt-next svg {
      width: 45px;
      height: 45px;
    }

    .cs_reiv_butt-prev svg {
      width: 45px;
      height: 45px;
    }
  }
</style>

<section id="herbies-reviews-{{ section.id }}" aria-label="{{ section.settings.section_label }}">
  <div class="hr-section">

    {%- if section.settings.show_marquee -%}
    <div class="hr-marquee-wrap animate-item">
      <div class="hr-marquee-track" id="hrMarqueeTrack-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_image' and block.settings.image != blank -%}
            <img
              class="hr-marquee-img"
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.image.alt | default: 'Customer photo' }}"
              loading="lazy"
              width="{{ section.settings.marquee_height }}"
              height="{{ section.settings.marquee_height }}"
            >
          {%- endif -%}
        {%- endfor -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_image' and block.settings.image != blank -%}
            <img
              class="hr-marquee-img"
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.image.alt | default: 'Customer photo' }}"
              loading="lazy"
              aria-hidden="true"
              width="{{ section.settings.marquee_height }}"
              height="{{ section.settings.marquee_height }}"
            >
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}


  </div>
</section>

<script>
  const swiper = new Swiper(".my-reviews-Swiper", {
    slidesPerView: 4,
    spaceBetween: 16,
    speed: 500,
    pagination: {
      el: ".cs_reviews-swiper-pagination",
      clickable: true,
    },
    navigation: {
      nextEl: ".cs_reiv_butt-next",
      prevEl: ".cs_reiv_butt-prev",
    },
    breakpoints: {
      0: {
        slidesPerView: 1.1,
        spaceBetween: 10
      },
      768: {
        slidesPerView: 2,
        spaceBetween: 10
      },
      1440: {
        slidesPerView: 4,
        spaceBetween: 16,
      }
    }
  });

  // Read More functionality
  document.querySelectorAll('#herbies-reviews-{{ section.id }} .hr-read-more-btn').forEach(function(btn) {
    var textDiv = btn.previousElementSibling;
    var p = textDiv ? textDiv.querySelector('p') : null;

    if (!p) {
      btn.classList.add('hr-rm-hidden');
      return;
    }

    // Wait for render then check if text is actually clamped
    requestAnimationFrame(function() {
      if (p.scrollHeight <= p.clientHeight + 2) {
        btn.classList.add('hr-rm-hidden');
        return;
      }

      btn.addEventListener('click', function() {
        var isExpanded = btn.getAttribute('aria-expanded') === 'true';
        if (!isExpanded) {
          p.classList.add('hr-expanded');
          btn.textContent = 'Read less';
          btn.setAttribute('aria-expanded', 'true');
        } else {
          p.classList.remove('hr-expanded');
          btn.textContent = 'Read more';
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Marqee New",
  "tag": "section",
  "class": "herbies-reviews-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section ARIA Label",
      "default": "Customer Reviews"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show Image Marquee",
      "default": true
    },
    {
      "type": "range",
      "id": "marquee_height",
      "label": "Marquee Image Width (Desktop)",
      "min": 10,
      "max": 200,
      "step": 2,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "marquee_height_mobile",
      "label": "Marquee Image width (Mobile)",
      "min": 10,
      "max": 200,
      "step": 2,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Speed (lower = faster)",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 22,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "label": "Section Padding (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading Spacing",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F5F0E8"
    }
  ],
  "blocks": [
    {
      "type": "marquee_image",
      "name": "Marquee Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        }
      ]
    },
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "text",
          "id": "review_score",
          "label": "Star Score",
          "default": "4.9",
          "info": "Number from 1 to 5"
        },
        {
          "type": "richtext",
          "id": "review_bold",
          "label": "Bold Headline (inside quotes)"
        },
        {
          "type": "richtext",
          "id": "review_body",
          "label": "Review Body Text"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Sarah M."
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show Verified Badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marqee New",
      "blocks": [
        { "type": "marquee_image" },
        { "type": "marquee_image" },
        { "type": "marquee_image" },
        { "type": "marquee_image" },
        { "type": "marquee_image" },
        { "type": "marquee_image" }
      ]
    }
  ]
}
{% endschema %} {% endcomment %}