              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>

        <!-- Subtitle below table on mobile -->
        {%- if section.settings.subtitle != blank -%}
          <p class="comparison-subtitle comparison-subtitle--mobile fade-in-left">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Left Column"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why Switch From Ordinary Soap?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most soaps strip your skin and leave it feeling dry. Kiss Me Sunshine is crafted to gently cleanse while nourishing your skin."
    },
    {
      "type": "header",
      "content": "Table Header"
    },
    {
      "type": "text",
      "id": "col_features_label",
      "label": "Features Column Label",
      "default": "Features"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand Logo (optional)",
      "info": "If set, shows logo instead of brand name text in the header"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name (fallback if no logo)",
      "default": "mumu bath"
    },
    {
      "type": "text",
      "id": "col_others_label",
      "label": "Others Column Label",
      "default": "Others"
    },
    {
      "type": "header",
      "content": "Spacing – Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Spacing – Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 48
    },
    {
      "type": "header",
      "content": "Colors – Section"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#F5F3EE"
    },
    {
      "type": "header",
      "content": "Colors – Text"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Colors – Table"
    },
    {
      "type": "color",
      "id": "brand_col_color",
      "label": "Brand Column Background",
      "default": "#FBDD40"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Header Text Color (Features & Brand)",
      "default": "#001116"
    },
    {
      "type": "color",
      "id": "others_text_color",
      "label": "Others Header Text Color",
      "default": "#001116"
    },
    {
      "type": "color",
      "id": "feature_text_color",
      "label": "Feature Label Text Color",
      "default": "#101010"
    },
    {
      "type": "color_background",
      "id": "row_divider_color",
      "label": "Row Divider Color",
      "default": "#00000066"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature_label",
          "label": "Feature Label",
          "default": "Gentle, Non-Stripping"
        },
        {
          "type": "checkbox",
          "id": "brand_has_feature",
          "label": "Brand has this feature",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "others_has_feature",
          "label": "Others have this feature",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature_label": "Gentle, Non-Stripping",
            "brand_has_feature": true,
            "others_has_feature": false
          }
