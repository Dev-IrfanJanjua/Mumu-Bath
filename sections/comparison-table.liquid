{% comment %} Comparison Table Section {% endcomment %}

<style>
  .section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  .section-{{ section.id }} .page-width{
    padding-inline: 80px;
    }

  .section-{{ section.id }} .comparison-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    align-items: start;
    gap: 48px;
  }

  /* ── Left Column ── */
  .section-{{ section.id }} .comparison-left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 32px;
  }

  .section-{{ section.id }} .comparison-title.title_title {
    color: {{ section.settings.title_color }};
    font-family: "Mona Sans", sans-serif;
    font-size: 48px;
    font-weight: 500;
    line-height: 120%;
    text-transform: capitalize;
    margin: 0;
  }

  .section-{{ section.id }} .comparison-subtitle {
    color: {{ section.settings.subtitle_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22.4px;
    margin: 0;
  }

  .section-{{ section.id }} .comparison-subtitle.comparison-subtitle--desktop {
        max-width: 421px;
    }

  /* hide subtitle in left col on mobile — shown below table instead */
  .section-{{ section.id }} .comparison-subtitle--mobile {
    display: none;
  }

  /* ── Right Column – Table ── */
  .section-{{ section.id }} .comparison-table-wrap {
    width: 100%;
  }

  .section-{{ section.id }} .comparison-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border-radius: 8px;
    overflow: hidden;
    background: transparent;
  }

  /* Column widths: feature label | brand col | others col */
  .section-{{ section.id }} .comparison-table col.col-feature {
    width: 45%;
  }
  .section-{{ section.id }} .comparison-table col.col-brand {
    width: 27.5%;
  }
  .section-{{ section.id }} .comparison-table col.col-others {
    width: 27.5%;
    background: #fff;
  }

  /* ── Header row ── */
  .section-{{ section.id }} .comparison-table thead tr {
    background-color: {{ section.settings.brand_col_color }};
  }

  .section-{{ section.id }} .comparison-table th {
    padding: 13.398px 22px;
    height: 66.992px;
    vertical-align: middle;
    box-sizing: border-box;
  }

  .section-{{ section.id }} .comparison-table th.th-feature {
    background-color: {{ section.settings.brand_col_color }};
    color: {{ section.settings.header_text_color }};
    font-family: Lora, serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 22px;
    text-transform: uppercase;
    text-align: left;
    opacity: 1;
  }

  .section-{{ section.id }} .comparison-table th.th-brand {
    background-color: {{ section.settings.brand_col_color }};
    text-align: center;
    vertical-align: middle;
    padding: 13.398px 22px;
    opacity: 1;
  }

  .section-{{ section.id }} .comparison-table th.th-brand img,
  .section-{{ section.id }} .comparison-table th.th-brand svg {
    max-height: 32px;
    width: auto;
    display: inline-block;
  }

  .section-{{ section.id }} .comparison-table th.th-brand .th-brand-text {
    color: {{ section.settings.header_text_color }};
    font-family: Lora, serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 22px;
    text-transform: capitalize;
    text-align: center;
    opacity: 1;
  }

  .section-{{ section.id }} .comparison-table th.th-others {
    background-color: #fff;
    color: {{ section.settings.others_text_color }};
    font-family: Lora, serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 22px;
    text-transform: capitalize;
    text-align: center;
    opacity: 1;
    border-top-right-radius: 8px;
    overflow: hidden;
  }

  .section-{{ section.id }} .comparison-table tbody tr:last-child td.td-others {
    border-bottom-right-radius: 8px;
    overflow: hidden;
}

  /* ── Body rows ── */
  .section-{{ section.id }} .comparison-table tbody tr td{
    border: none;
    }

  .section-{{ section.id }} .comparison-table thead tr th,
  .section-{{ section.id }} .comparison-table tbody tr:not(:last-child) td {
    border: none;
    border-bottom: 1px solid {{ section.settings.row_divider_color }};
  }

  .section-{{ section.id }} .comparison-table tbody tr:last-child {
    border-bottom: none;
  }

  .section-{{ section.id }} .comparison-table td {
    padding: 13.398px 22px;
    vertical-align: middle;
    box-sizing: border-box;
  }

  /* Feature label cell */
  .section-{{ section.id }} .comparison-table td.td-feature {
    background-color: {{ section.settings.brand_col_color }};
    color: {{ section.settings.feature_text_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 120%;
    text-transform: capitalize;
  }

  /* Brand check cell */
  .section-{{ section.id }} .comparison-table td.td-brand {
    background-color: {{ section.settings.brand_col_color }};
    text-align: center;
    vertical-align: middle;
  }

  /* Others cell */
  .section-{{ section.id }} .comparison-table td.td-others {
    background-color: transparent;
    text-align: center;
    vertical-align: middle;
  }

  /* ── Icons ── */
  .section-{{ section.id }} .ct-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-top: 7px;
  }

  .section-{{ section.id }} .ct-icon svg {
    width: 100%;
    height: 100%;
    aspect-ratio: 1;
    display: block;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .section-{{ section.id }} .page-width{
        padding-inline: 16px;
    }

    .section-{{ section.id }} .comparison-wrapper {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .section-{{ section.id }} .comparison-title.title_title {
      font-size: 30px;
      text-align: center;
    }

    /* Hide desktop subtitle, show mobile one below table */
    .section-{{ section.id }} .comparison-subtitle--desktop {
      display: none;
    }

    .section-{{ section.id }} .comparison-subtitle--mobile {
        display: block;
        margin-top: 40px;
        text-align: center;
        font-size: 14px;
    }

    .section-{{ section.id }} .comparison-table th,
    .section-{{ section.id }} .comparison-table td {
      padding: 10px 12px;
    }

    .section-{{ section.id }} .comparison-table th.th-feature{
        font-size: 16px;
    }

    .section-{{ section.id }} .comparison-table td.td-feature {
      font-size: 14px;
    }

    .section-{{ section.id }} .comparison-table th.th-brand .th-brand-text,
    .section-{{ section.id }} .comparison-table th.th-others {
      font-size: 14px;
    }

    .section-{{ section.id }} .comparison-table col.col-feature {
        width: 56%;
    }

    .section-{{ section.id }} .comparison-table col.col-others,
    .section-{{ section.id }} .comparison-table col.col-brand {
        width: 22%;
    }

    .section-{{ section.id }} .comparison-table th.th-brand {
        padding: 0;
    }

  }
</style>

<section class="section-{{ section.id }} fade-in-section" id="shopify-section-{{ section.id }}">
  <div class="page-width">
    <div class="comparison-wrapper">

      <!-- Left -->
      <div class="comparison-left">
        <div>
          {%- if section.settings.title != blank -%}
            <h2 class="comparison-title title_title fade-in-left">{{ section.settings.title }}</h2>
          {%- endif -%}
        </div>

        {%- if section.settings.subtitle != blank -%}
          <p class="comparison-subtitle comparison-subtitle--desktop fade-in-left">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      <!-- Right: table + mobile subtitle -->
      <div class="comparison-table-wrap">
        <table class="comparison-table" role="table">
          <colgroup>
            <col class="col-feature">
            <col class="col-brand">
            <col class="col-others">
          </colgroup>
          <thead>
            <tr>
              <th class="th-feature" scope="col">{{ section.settings.col_features_label }}</th>
              <th class="th-brand" scope="col">
                {%- if section.settings.brand_logo != blank -%}
                  {{
                    section.settings.brand_logo
                    | image_url: width: 300
                    | image_tag:
                      loading: 'lazy',
                      alt: section.settings.brand_name | escape
                  }}
                {%- else -%}
                  <span class="th-brand-text">{{ section.settings.brand_name }}</span>
                {%- endif -%}
              </th>
              <th class="th-others" scope="col">{{ section.settings.col_others_label }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for block in section.blocks -%}
              {%- if block.type == 'row' -%}
                <tr class="fade-in-item" {{ block.shopify_attributes }}>
                  <td class="td-feature">{{ block.settings.feature_label }}</td>
                  <td class="td-brand">
                    {%- if block.settings.brand_has_feature -%}
