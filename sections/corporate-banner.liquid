{% comment %} ==== Corporate Banner Section ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
}

.sec-{{ section.id }} .cb-inner {
    display: flex;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
}

.sec-{{ section.id }} .cb-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 100%;
    width: 100%;
}

.sec-{{ section.id }} .cb-heading {
    display: flex;
    flex-direction: column;
}

.sec-{{ section.id }} .cb-title {
    color: #000;
    font-family: "Mona Sans", sans-serif;
    font-size: 60px;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: 0px;
    text-transform: capitalize;
    margin: 0 0 12px;
}

.sec-{{ section.id }} .cb-subtitle {
    color: #000;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 0px;
    margin: 0;
    max-width: 555px;
}

.sec-{{ section.id }} .cb-blocks {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
}

.sec-{{ section.id }} .cb-block-item {
    display: flex;
    align-items: center;
    gap: 4px;
}

.sec-{{ section.id }} .cb-block-icon {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
}

.sec-{{ section.id }} .cb-block-text {
    color: #000;
    font-family: "Mona Sans", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 0;
    margin: 0;
    white-space: nowrap;
}

.sec-{{ section.id }} .cb-btns {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.sec-{{ section.id }} .btn_btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid transparent;
    white-space: nowrap;
    max-width: 273px;
    width: 100%;
}

.sec-{{ section.id }} .btn_btn.cb-btn-primary {
    background-color: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_text }};
    border-color: {{ section.settings.btn_primary_bg }};
}

.sec-{{ section.id }} .btn_btn.cb-btn-primary:hover {
    background-color: {{ section.settings.btn_primary_hover_bg }};
    color: {{ section.settings.btn_primary_hover_text }};
    border-color: {{ section.settings.btn_primary_hover_bg }};
}

.sec-{{ section.id }} .btn_btn.cb-btn-secondary {
    background-color: {{ section.settings.btn_secondary_bg }};
    color: {{ section.settings.btn_secondary_text }};
    border-color: {{ section.settings.btn_secondary_border }};
}

.sec-{{ section.id }} .btn_btn.cb-btn-secondary:hover {
    background-color: {{ section.settings.btn_secondary_hover_bg }};
    color: {{ section.settings.btn_secondary_hover_text }};
    border-color: {{ section.settings.btn_secondary_hover_bg }};
}

.sec-{{ section.id }} .cb-image {
    position: relative;
    max-width: 42%;
    width: 100%;
}

.sec-{{ section.id }} .cb-image-wrap {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
}

.sec-{{ section.id }} .cb-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
    z-index: 1;
    position: relative;
}

.sec-{{ section.id }} img.cb_abs-icon {
    width: 100px;
    height: 100px;
    position: absolute;
    z-index: 0;
    top: -10px;
    left: 0;
}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .cb-inner {
        gap: 16px;
        flex-direction: column;
    }

    .sec-{{ section.id }} .cb-image {
        order: -1;
        max-width: 100%;
    }

    .sec-{{ section.id }} .cb-title {
        font-size: 36px;
        line-height: 42px;
        letter-spacing: 0px;
    }

    .sec-{{ section.id }} .cb-subtitle {
        font-size: 15px;
    }

    .sec-{{ section.id }} .cb-content {
        gap: 16px;
        max-width: 100%;
    }

    .sec-{{ section.id }} .cb-blocks {
        flex-direction: column;
        align-items: self-start;
    }

    .sec-{{ section.id }} .cb-btns {
        margin-top: 8px;
    }

    .sec-{{ section.id }} .btn_btn.cb-btn-primary {
        font-size: 16px;
    }


    {% if section.settings.hide_secondary_mobile %}
    .sec-{{ section.id }} .cb-btn-secondary {
        display: none;
    }
    {% endif %}
}
{% endstyle %}

<div class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %}">
    <div class="page-width">
        <div class="cb-inner">

            {% comment %} Left: Content {% endcomment %}
            <div class="cb-content">

                <div class="cb-heading">
                    {% if section.settings.title != blank %}
                        <h1 class="cb-title title_title">{{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}</h1>
                    {% endif %}
                    {% if section.settings.subtitle != blank %}
                        <p class="cb-subtitle">{{ section.settings.subtitle }}</p>
                    {% endif %}
                </div>

                {% if section.blocks.size > 0 %}
                    <div class="cb-blocks">
                        {% for block in section.blocks %}
                            {% if block.type == 'feature' %}
                                <div class="cb-block-item" {{ block.shopify_attributes }}>
                                    {% if section.settings.block_icon %}
                                        <img
                                            src="{{ section.settings.block_icon | image_url }}"
                                            alt=""
                                            width="16"
                                            height="16"
                                            class="cb-block-icon"
                                            loading="eager"
                                            aria-hidden="true"
                                        >
                                    {% endif %}
                                    {% if block.settings.text != blank %}
                                        <span class="cb-block-text">{{ block.settings.text }}</span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="cb-btns">
                    {% if section.settings.btn_primary_label != blank %}
                        
                        <a href="{{ section.settings.btn_primary_url }}"class="btn_btn cb-btn-primary">
                            {{ section.settings.btn_primary_label }}
                        </a>
                    {% endif %}
                    {% if section.settings.btn_secondary_label != blank %}
                        
                        <a href="{{ section.settings.btn_secondary_url }}"class="btn_btn cb-btn-secondary">
                            {{ section.settings.btn_secondary_label }}
                        </a>
                    {% endif %}
                </div>

            </div>

            {% comment %} Right: Image {% endcomment %}
            <div class="cb-image">
                <div class="cb-image-wrap">
                    {% if section.settings.image_abs %}
                        <img
                            src="{{ section.settings.image_abs | image_url: width: 1200 }}"
                            alt="Absolute Icon"
                            width="100"
                            height="auto"
                            loading="lazy"
                            class="cb_abs-icon"
                        >
                      {% endif %}
                    {% if section.settings.image %}
                        <img
                            src="{{ section.settings.image | image_url: width: 1200 }}"
                            alt="{{ section.settings.image.alt | default: section.settings.title }}"
                            width="{{ section.settings.image.width }}"
                            height="{{ section.settings.image.height }}"
                            loading="eager"
                            fetchpriority="high"
                        >
                    {% else %}
                        {{ 'image' | placeholder_svg_tag }}
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Corporate Banner",
  "tag": "section",
  "class": "corporate-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Send beautifully curated bath, body, and self-care gifts made with natural ingredients, Taiwanese-inspired scents, and thoughtful packaging your team, clients, and partners will remember."
    },
    {
      "type": "header",
      "content": "Feature Blocks"
    },
    {
      "type": "image_picker",
      "id": "block_icon",
      "label": "Icon (shared across all blocks)"
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primary Button Label",
      "default": "Request A Quote"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary Button URL"
    },
    {
      "type": "color",
      "id": "btn_primary_bg",
      "label": "Primary Button Background",
      "default": "#F5E44A"
    },
    {
      "type": "color",
      "id": "btn_primary_text",
      "label": "Primary Button Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_bg",
      "label": "Primary Button Hover Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_text",
      "label": "Primary Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secondary Button Label",
      "default": "Explore Gift Options"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary Button URL"
    },
    {
      "type": "color",
      "id": "btn_secondary_bg",
      "label": "Secondary Button Background",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "btn_secondary_text",
      "label": "Secondary Button Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_secondary_border",
      "label": "Secondary Button Border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_secondary_hover_bg",
      "label": "Secondary Button Hover Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_secondary_hover_text",
      "label": "Secondary Button Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "hide_secondary_mobile",
      "label": "Hide secondary button on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    },
    {
      "type": "image_picker",
      "id": "image_abs",
      "label": "Right Image Overlay Icon"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F6EE"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Minimum 10 Gifts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Corporate Banner",
      "category": "Custom",
      "blocks": [
        { "type": "feature", "settings": { "text": "Minimum 10 Gifts" } },
        { "type": "feature", "settings": { "text": "Custom Notes Available" } },
        { "type": "feature", "settings": { "text": "Discounts on 30+ Recipients" } }
      ]
    }
  ]
}
{% endschema %}