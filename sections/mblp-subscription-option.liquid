<style>
              /* Mobile First Approach */
              .mblp-subscription-option-main {
                background-color: --col-white;
                padding-top: {{ section.settings.padding_top_mobile }}px !important;
                padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
              }

              .mblp-subscription-option-wrapper {
                max-width: 100%;
                margin: 0 auto;
              }

              .mblp-subscription-option-sub-wrapper {
                display: flex;
                flex-direction: column;
                gap: 40px;
              }

              .mblp-subscription-option-title h2 {
                text-align: center;
                color: var(--col-light-black);
                margin: 0;
                font-family: var(--fs-lora) !important;
                font-size: 36px !important;
                font-style: normal;
                font-weight: 700;
                line-height: normal;
            }

              .mblp-subscription-option-cards-container {
                display: flex;
                flex-direction: column;
                gap: 2rem;
              }

              .mblp-subscription-option-card {
                background: var(--col-white);
                border-radius: 8px;
                box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
                overflow: hidden;
                border: 3px solid var(--col-light-black);
              }

              .mblp-subscription-option-card-header {
                background-color: var(--col-light-black);
                color: var(--col-yellow);
                text-align: center;
                display: flex;
                width: 400px;
                padding: 16px 20px 16px 32px;
                align-items: center;
                gap: 10px;
              }


              .mblp-subscription-option-card-header span {
                font-family: 'Inter Semi Bold' !important;
                font-size: 24px;
                font-style: normal;
                font-weight: 600;
                line-height: normal;
              }
             .mblp-subscription-option-card-header strong {
                font-size: 40px;
             }

              .mblp-subscription-option-card-body {
                /* padding: 1.5rem; */
                display: flex;
                flex-direction: column;
                /* gap: 1.5rem; */
              }

              .mblp-subscription-option-product-list {
                display: flex;
              flex-direction: column;
              gap: 0.75rem;
              min-height: 260px;
              padding: 32px;
              background: var(--col-offwhite);
                border-bottom: 1px solid var(--col-light-black);

              }

              .mblp-subscription-option-product-item {
                display: flex;
                align-items: center;
                gap: 12px;
              }

              .mblp-subscription-option-product-item::before {
                content: "♡";
                color: var(--col-black);
              font-size: 24px;
              }

              .mblp-subscription-option-product-item span {
                color: var(--col-black);
              text-align: center;
              font-family: 'Inter Medium' !important;
              font-size: 16px;
              font-style: normal;
              font-weight: 500;
              line-height: normal;
              }

            .mblp-subscription-option-features-list {
              display: flex;
              flex-direction: column;
              gap: 0.5rem;
              /* border-top: 1px solid #e5e5e5; */
              padding: 32px;
          }

              .mblp-subscription-option-feature-item {
                display: flex;
                align-items: center;
                gap: 12px;
              }

              .mblp-subscription-option-feature-item::before {
                content: "✓";
                color: var(--col-black);
              font-size: 24px;
              }

              .mblp-subscription-option-feature-item span {
                color: var(--col-black);
              text-align: center;
              font-family: 'Inter Medium' !important;
              font-size: 16px;
              font-style: normal;
              font-weight: 500;
              line-height: normal;
              }

        .mblp-subscription-option-button {
            /* margin-top: auto; */
            align-items: center;
            display: inline-flex;
            justify-content: center;
        }

          .mblp-subscription-option-button a {
            display: flex;
            font-family: 'Inter Medium' !important;
            background-color: var(--col-light-black);
            color: var(--col-white);
            justify-content: center;
            text-align: center;
            align-items: center;
            padding: 12px 10px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 500;
            transition: background-color 0.3s ease;
            max-width: 320px;
            margin-bottom: 30px;
            width: 100%;
        }

      @media (min-width: 1024px) {
                .mblp-subscription-option-cards-container {
                  gap: 80px;
                  justify-content: center;
                }
              }

              /* Desktop Styles */
              @media (min-width: 769px) {
                .mblp-subscription-option-main {
                  padding-top: {{ section.settings.padding_top_desktop }}px;
                  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
                }

                .mblp-subscription-option-cards-container {
                  flex-direction: row;
                  gap: 2rem;
                }

                .mblp-subscription-option-card {
                  /* flex: 1; */
                  display: flex;
                  flex-direction: column;
                }

                .mblp-subscription-option-card-body {
                  flex: 1;
                }

                .mblp-subscription-option-title h2 {
                  font-size: 2.5rem;
                }
              }



          @media (max-width: 768px) {
                .mblp-subscription-option-cards-container {
                  flex-direction: column;
                  align-items: center;
                }
            .mblp-subscription-option-feature-item span {
      font-size: 14px;
  }
                .mblp-subscription-option-title h2 {
        font-size: 28px !important;
    }
    .mblp-subscription-option-card-header {
        justify-content: center;
        width: auto;
    }
    .mblp-subscription-option-card-header strong {
        font-size: 32px;
    }
    .mblp-subscription-option-card-header span {
        font-size: 18px;
        }
        .mblp-subscription-option-sub-wrapper {
        gap: 20px;
    }
            .mblp-subscription-option-card {
          max-width: 350px;
      }
      .mblp-subscription-option-product-list {
        gap: 0;
        padding: 20px;
                min-height: auto;
          }
          .mblp-subscription-option-features-list {
        gap: 0;
        padding: 20px;
    }
    .mblp-subscription-option-button a {
        max-width: 300px;
      font-size: 16px;
    }
          }
</style>

