                <div class="mblp-subscription-option-features-list">
                  {% if section.settings.card1_feature1 != blank %}
                    <div class="mblp-subscription-option-feature-item">
                      <span>{{ section.settings.card1_feature1 }}</span>
                    </div>
                  {% endif %}

                  {% if section.settings.card1_feature2 != blank %}
                    <div class="mblp-subscription-option-feature-item">
