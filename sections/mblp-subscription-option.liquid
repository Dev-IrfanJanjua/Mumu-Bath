                      <span>{{ section.settings.card1_product6 }}</span>
                    </div>
                  {% endif %}

                  {% if section.settings.card1_product7 != blank %}
                    <div class="mblp-subscription-option-product-item">
                      <span>{{ section.settings.card1_product7 }}</span>
                    </div>
                  {% endif %}

                  {% if section.settings.card1_product8 != blank %}
