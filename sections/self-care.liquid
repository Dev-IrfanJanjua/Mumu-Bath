  ],
  "presets": [
    {
      "name": "Self-Care Products",
      "category": "Custom",
      "blocks": [
        { "type": "product_item", "settings": { "text": "Bath Bomb" } },
        { "type": "product_item", "settings": { "text": "Body Butter" } },
        { "type": "product_item", "settings": { "text": "Bath Bomb" } },
