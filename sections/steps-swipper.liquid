{% comment %} ==== Steps Swiper Section ===== {% endcomment %}

{% unless content_for_header contains 'swiper' %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
{% endunless %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
}

.sec-{{ section.id }} .steps-head {
    text-align: center;
    margin-bottom: 48px;
}

.sec-{{ section.id }} .steps-title {
    color: {{ section.settings.title_color }};
    margin: 0;
    letter-spacing: 0;
}

.sec-{{ section.id }} .steps-swiper {
    overflow: visible;
}

.sec-{{ section.id }} .steps-swiper .swiper-wrapper {
    align-items: stretch;
}

.sec-{{ section.id }} .steps-swiper .swiper-slide {
    height: auto;
}

.sec-{{ section.id }} .step-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 12px;
    border-radius: 8px;
    border: 0.8px solid {{ section.settings.card_border_color }};
    background: {{ section.settings.card_bg_color }};
    height: 100%;
    box-sizing: border-box;
}

.sec-{{ section.id }} .step-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
}

.sec-{{ section.id }} .step-card-title {
    color: #000;
    font-family: "Mona Sans", sans-serif;
    font-size: 18px;
    font-weight: 600;
    line-height: 120%;
    text-transform: capitalize;
    letter-spacing: 0;
    margin: 0;
}

.sec-{{ section.id }} .step-card-text {
    color: #000;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: -0.5px;
    margin: 0;
}

.sec-{{ section.id }} .steps-swiper .swiper-pagination {
    position: relative;
    margin-top: 24px;
}

.sec-{{ section.id }} .steps-swiper .swiper-pagination-bullet {
    background: {{ section.settings.pagination_color }};
    opacity: 0.3;
}

.sec-{{ section.id }} .steps-swiper .swiper-pagination-bullet-active {
    background: {{ section.settings.pagination_color }};
    opacity: 1;
}

{% if section.settings.hide_page %}
    .sec-{{ section.id }} .steps-swiper .swiper-pagination{
        display: none;
    }
{% endif %}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .steps-head {
        margin-bottom: 24px;
    }

    .sec-{{ section.id }} .step-card-text {
        font-size: 14px;
        letter-spacing: -0.5px;
    }
}
{% endstyle %}

<div class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %} fade-in-section">
    <div class="page-width">

        {% if section.settings.title != blank %}
            <div class="steps-head">
                <h2 class="steps-title title_title fade-in-up">{{ section.settings.title }}</h2>
            </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
            <div class="swiper steps-swiper" id="steps-swiper-{{ section.id }}">
                <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        {% if block.type == 'step' %}
                            <div class="swiper-slide" {{ block.shopify_attributes }}>
                                <div class="step-card fade-in-item">

                                    {% if block.settings.icon %}
                                        <img
                                            src="{{ block.settings.icon | image_url }}"
                                            alt="{{ block.settings.icon.alt | default: block.settings.title }}"
                                            width="40"
                                            height="40"
                                            class="step-icon"
                                            loading="lazy"
                                        >
                                    {% endif %}

                                    {% if block.settings.title != blank %}
                                        <h3 class="step-card-title">{{ block.settings.title }}</h3>
                                    {% endif %}

                                    {% if block.settings.text != blank %}
                                        <p class="step-card-text">{{ block.settings.text }}</p>
                                    {% endif %}

                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
                <div class="swiper-pagination"></div>
            </div>
        {% endif %}

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('steps-swiper-{{ section.id }}');
    if (!el) return;

    new Swiper(el, {
        slidesPerView: 1.4,
        spaceBetween: 12,
        pagination: {
            el: el.querySelector('.swiper-pagination'),
            clickable: true
        },
        breakpoints: {
            480: {
                slidesPerView: 1.4,
                spaceBetween: 12
            },
            768: {
                slidesPerView: 3,
                spaceBetween: 12
            },
            1024: {
                slidesPerView: {{ section.blocks.size }},
                spaceBetween: 12
            }
        }
    });
});
</script>

{% schema %}
{
  "name": "Steps Swiper",
  "tag": "section",
  "class": "steps-swiper-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "checkbox",
      "id": "hide_page",
      "label": "Hide Pagination",
      "default": true
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Simple, Seamless, Thoughtful"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F6EE"
    },
    {
      "type": "color",
      "id": "pagination_color",
      "label": "Pagination Dot Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (40×40)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Share Your Needs"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Text",
          "default": "Tell us your occasion, quantity, budget, timeline, and recipient details."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Steps Swiper",
      "category": "Custom",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Share Your Needs",
            "text": "Tell us your occasion, quantity, budget, timeline, and recipient details."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "We Curate Options",
            "text": "Our team recommends gift ideas that match your goals and budget."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Customize The Details",
            "text": "Choose products, notes, packaging, and any special touches."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Confirm Your Order",
            "text": "Approve the final selection, quantity, and delivery details."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "We Handle The Rest",
            "text": "Your gifts are prepared with care and sent out beautifully."
          }
        }
      ]
    }
  ]
}
{% endschema %}