    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Form Card Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Colors – Text"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
