{% comment %} Contact Form Section {% endcomment %}

<style>
  .section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  .section-{{ section.id }} .cf-wrapper {
    display: grid;
    grid-template-columns: 51% calc(49% - {{ section.settings.col_gap }}px);
    gap: {{ section.settings.col_gap }}px;
    align-items: stretch;
  }

  /* ── Left: content card ── */
  .section-{{ section.id }} .cf-left {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .section-{{ section.id }} .cf-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-{{ section.id }} .cf-title.title_title {
    color: {{ section.settings.title_color }};
  }

  .section-{{ section.id }} .cf-subtitle {
    color: {{ section.settings.subtitle_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 120%;
    margin: 0;
  }

  /* ── Form ── */
  .section-{{ section.id }} .cf-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .section-{{ section.id }} .cf-field {
    width: 100%;
    padding: 13px 16px;
    border: 1px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_border_radius }}px;
    background-color: {{ section.settings.input_bg_color }};
    color: {{ section.settings.input_text_color }};
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 19.5px;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .section-{{ section.id }} .cf-field::placeholder {
    color: rgba(0, 0, 0, 0.60);
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 19.5px;
  }

  .section-{{ section.id }} .cf-field:focus {
    border-color: {{ section.settings.input_focus_color }};
  }

  .section-{{ section.id }} .cf-field--textarea {
    resize: vertical;
    min-height: 160px;
  }

  .section-{{ section.id }} .cf-btn.btn_btn {
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border-radius: {{ section.settings.btn_border_radius }}px;
  }

  .section-{{ section.id }} .cf-btn.btn_btn:hover {
    background-color: {{ section.settings.hover_bg_color }};
    color: {{ section.settings.hover_text_color }};
  }

  /* ── Messages ── */
  .section-{{ section.id }} .cf-success {
    padding: 8px;
    background-color: #d4edda;
    color: #000;
    border: 1px solid #c3e6cb;
    border-radius: 8px;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 12px;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .section-{{ section.id }} .cf-errors {
    padding: 8px;
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
    border-radius: {{ section.settings.input_border_radius }}px;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 15px;
    line-height: 1.5;
    list-style: none;
    margin: 0;
    padding-left: 18px;
  }

  .section-{{ section.id }} .cf-errors li {
    margin-bottom: 4px;
  }

  .section-{{ section.id }} .cf-errors li:last-child {
    margin-bottom: 0;
  }

  /* ── Right: image ── */
  .section-{{ section.id }} .cf-right {
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    min-height: 300px;
  }

  .section-{{ section.id }} .cf-right img,
  .section-{{ section.id }} .cf-right svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .section-{{ section.id }} .cf-wrapper {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    /* image below content on mobile */
    .section-{{ section.id }} .cf-left  { order: 1; }
    .section-{{ section.id }} .cf-right { order: 2; min-height: 260px; }

    .section-{{ section.id }} .cf-left {
        padding: 20px 12px;
        gap: 24px;
        border-radius: 20px;
    }

    .section-{{ section.id }} .cf-title.title_title {
        text-align: center;
    }

    .section-{{ section.id }} .cf-form {
        gap: 12px;
    }

    .section-{{ section.id }} .cf-subtitle {
      font-size: 14px;
      font-weight: 400;
      line-height: 22px;
      text-align: center;
    }

  }
</style>

{%- assign form_id = 'contact-form-' | append: section.id -%}

<section class="section-{{ section.id }}" id="shopify-section-{{ section.id }}">
  <div class="page-width">
    <div class="cf-wrapper">

      <!-- Left: form card -->
      <div class="cf-left">

        <div class="cf-header">
          {%- if section.settings.title != blank -%}
            <h2 class="cf-title title_title">{{ section.settings.title }}</h2>
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <p class="cf-subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
        </div>

        {%- form 'contact', id: form_id -%}

          {%- if form.posted_successfully? -%}
            <p class="cf-success">
              {{ section.settings.success_message }}
            </p>
          {%- endif -%}

          {%- if form.errors -%}
            <ul class="cf-errors" role="alert">
              {%- for field in form.errors -%}
                <li>{{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <div class="cf-form">
            <input
              class="cf-field"
              type="text"
              name="contact[name]"
              id="{{ form_id }}-name"
              placeholder="{{ section.settings.label_name }}"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              autocomplete="name"
            >

            <input
              class="cf-field"
              type="email"
              name="contact[email]"
              id="{{ form_id }}-email"
              placeholder="{{ section.settings.label_email }}"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              autocomplete="email"
              required
            >

            <textarea
              class="cf-field cf-field--textarea"
              name="contact[body]"
              id="{{ form_id }}-body"
              placeholder="{{ section.settings.label_message }}"
              required
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>

            <button type="submit" class="cf-btn btn_btn">
              {{ section.settings.btn_label }}
            </button>
          </div>

        {%- endform -%}

      </div>

      <!-- Right: image -->
      <div class="cf-right">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '550, 750, 900, 1100, 1200',
              sizes: '(max-width: 768px) 100vw, 50vw',
              alt: section.settings.image.alt | default: section.settings.title | escape
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Need Help Getting Started?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Thank you for your support. If you need more help, feel free to send us a message, and we'll get back to you soon."
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Name Placeholder",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email Placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "Message Placeholder",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
