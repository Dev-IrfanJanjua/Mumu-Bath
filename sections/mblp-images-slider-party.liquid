<!-- Section: MBLP Images Slider Party -->
<div class="mblp-images-slider-party-main-{{ section.id }}">
  <div class="mblp-container">
    <div class="mblp-images-slider-party-wrapper">
      <div class="mblp-images-slider-party-sub-wrapper">
        <!-- Section Title -->
        {% if section.settings.section_title != blank %}
          <div class="mblp-images-slider-party-title">
            <h2>{{ section.settings.section_title }}</h2>
          </div>
        {% endif %}

        <!-- Images Container -->
        <div class="mblp-images-slider-party-container">
          <!-- Mobile Splide Slider -->
          <div class="splide mblp-images-slider-party-slider" id="mblp-images-slider-party-slider">
            <div class="splide__track">
              <ul class="splide__list">
                {% for block in section.blocks %}
                  {% if block.settings.image != blank %}
                    <li class="splide__slide">
                      <div class="mblp-images-slider-party-image">
                        <img src="{{ block.settings.image | image_url: width: 1500 }}" alt="{{ block.settings.image.alt | default: 'Party image' }}">
                      </div>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          </div>

          <!-- Desktop Flex Layout -->
          <div class="mblp-images-slider-party-desktop">
            {% for block in section.blocks %}
              {% if block.settings.image != blank %}
                <div class="mblp-images-slider-party-image">
                  <img src="{{ block.settings.image | image_url: width: 1500 }}" alt="{{ block.settings.image.alt | default: 'Party image' }}">
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Load Splide CSS and JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">
<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>

<style>
  .mblp-images-slider-party-main-{{ section.id }} {
    background-color: #FFF;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }


  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-sub-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-title h2 {
    font-size: 36px;
    text-align: center;
    font-family: 'Dm Sans Bold' !important;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
    padding: 10px;
    margin-bottom: 30px;
    color: var(--col-light-black);
  }

  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-container {
    width: 100%;
    padding: 20px 0px;
  }

  /* Mobile Slider Styles */
  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-slider {
    display: block;
    width: 100%;
  }

  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-desktop {
    display: none;
  }

  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-image {
    width: 100%;
    {% comment %} height: 300px; {% endcomment %}
    overflow: hidden;
  }

  .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  /* Custom Splide Pagination Styles */
  .mblp-images-slider-party-main-{{ section.id }} .splide__pagination {
    bottom: -50px !important;
    padding: 0;
    position: relative !important;
  }

  .mblp-images-slider-party-main-{{ section.id }} .splide__pagination__page {
    width: 10px !important;
    height: 10px !important;
    border-radius: 50% !important;
    background: #D1D5DB !important;
    margin: 0 4px !important;
    opacity: 1 !important;
    transition: all 0.3s ease !important;
    border: none !important;
    transform: none !important;
  }

  .mblp-images-slider-party-main-{{ section.id }} .splide__pagination__page.is-active {
    background: var(--col-light-black) !important;
    transform: scale(1.2) !important;
  }

  /* Hide splide arrows on mobile */
  .mblp-images-slider-party-main-{{ section.id }} .splide__arrows {
    display: none !important;
  }

  /* Splide track and list styles */
  .mblp-images-slider-party-main-{{ section.id }} .splide__track {
    overflow: hidden;
    position: relative;
  }

  .mblp-images-slider-party-main-{{ section.id }} .splide__list {
    backface-visibility: hidden;
    display: flex;
    height: 100%;
    margin: 0 !important;
    padding: 0 !important;
  }

  .mblp-images-slider-party-main-{{ section.id }} .splide__slide {
    backface-visibility: hidden;
    box-sizing: border-box;
    flex-shrink: 0;
    list-style-type: none !important;
    margin: 0;
    position: relative;
    width: 100%;
    padding: 0;
  }

  /* Mobile specific adjustments */
  @media (max-width: 768px) {
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-title h2 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-container {
    padding: 0px 0 0 32px;
  }
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-image {
      {% comment %} height: 250px; {% endcomment %}
    }

    /* Ensure Splide is visible and working */
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-slider {
      visibility: visible !important;
      opacity: 1 !important;
      width: 100%;
      position: relative;
    }

    .mblp-images-slider-party-main-{{ section.id }} .splide__track {
      overflow: hidden !important;
      width: 100%;
    }

    .mblp-images-slider-party-main-{{ section.id }} .splide__list {
      width: 100%;
      transition-property: transform;
    }
  }

  /* Tablet and Desktop Styles */
  @media (min-width: 769px) {
    .mblp-images-slider-party-main-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-title h2 {
      font-size: 36px;
    }

  }

  /* Large Desktop Styles */
  @media (min-width: 1024px) {
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-desktop {
      gap: 25px;
    }

    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-image {
      {% comment %} flex: 0 0 calc(33.333% - 17px);
      height: 400px; {% endcomment %}
    }

    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-title h2 {
      font-size: 40px;
    }
  }

  /* Extra Large Desktop */
  @media (min-width: 1200px) {
    .mblp-images-slider-party-main-{{ section.id }} .mblp-images-slider-party-image {
      {% comment %} flex: 0 0 calc(25% - 19px); {% endcomment %}
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    let splideInstance = null;

    function initializeSplide() {
      // Destroy existing instance if it exists
      if (splideInstance) {
        splideInstance.destroy();
        splideInstance = null;
      }

      // Initialize on all screen sizes
      if (true) {
        const splideElement = document.getElementById('mblp-images-slider-party-slider');

        if (splideElement && typeof Splide !== 'undefined') {
          // Responsive settings based on screen size
          let splideConfig = {
            type: 'loop',
            perMove: 1,
            gap: '20px',
            pagination: false,
            arrows: false,
            autoplay: false,
            drag: true,
            snap: true,
            focus: '0',
            rewind: true,
            trimSpace: false,
            classes: {
              arrows: 'splide__arrows',
              arrow : 'splide__arrow',
              prev  : 'splide__arrow--prev',
              next  : 'splide__arrow--next',
            }
          };

          // Adjust settings based on screen size
          if (window.innerWidth <= 500) {
            splideConfig.perPage = 1;
            splideConfig.padding = { right: '10%' };
            splideConfig.gap = '15px';
          } else if (window.innerWidth <= 768) {
            splideConfig.perPage = 2;
            splideConfig.padding = { right: '10%' };
            splideConfig.gap = '15px';
          }else if (window.innerWidth <= 1024) {
            splideConfig.perPage = 3;
            splideConfig.padding = { right: '10%' };
          } else if (window.innerWidth <= 1200) {
            splideConfig.perPage = 3;
            splideConfig.padding = { right: '10%' };
          } else {
            splideConfig.perPage = 3;
            splideConfig.padding = { right: '10%' };
          } 

          splideInstance = new Splide('#mblp-images-slider-party-slider', splideConfig);

          try {
            splideInstance.mount();
            console.log('MBLP Images Slider Party initialized successfully');
          } catch (error) {
            console.error('Error initializing MBLP Images Slider Party:', error);
          }
        }
      }
    }

    // Wait for Splide library to load
    function waitForSplide() {
      if (typeof Splide !== 'undefined') {
        initializeSplide();
      } else {
        setTimeout(waitForSplide, 100);
      }
    }

    waitForSplide();

    // Handle resize events
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        initializeSplide();
      }, 250);
    });
  });
</script>

{% schema %}
{
  "name": "MBLP Images Slider Party",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Party Highlights"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Party Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MBLP Images Slider Party",
      "settings": {
        "section_title": "Party Highlights"
      },
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}