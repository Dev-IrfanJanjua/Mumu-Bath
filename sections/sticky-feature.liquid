{% comment %} ==== Sticky Feature List Section ===== {% endcomment %}

{% style %}
.sec-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

.sec-{{ section.id }} .sfl-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
}

.sec-{{ section.id }} .sfl-left {
    position: sticky;
    top: {{ section.settings.sticky_offset }}px;
}

.sec-{{ section.id }} .sfl-title {
    color: {{ section.settings.title_color }};
    margin: 0 0 24px;
    letter-spacing: 0;
}

.sec-{{ section.id }} .sfl-subtitle {
    color: #000;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 120%;
    letter-spacing: 0;
    margin: 0;
}

.sec-{{ section.id }} .sfl-blocks {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.sec-{{ section.id }} .sfl-block-item {
    display: flex;
    align-items: center;
    gap: 12px;
    border-radius: 8px;
    border: 0.8px solid {{ section.settings.block_border_color }};
    background: {{ section.settings.block_bg_color }};
    padding: 20px 16px;
    text-decoration: none;
}

.sec-{{ section.id }} .sfl-block-icon {
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    object-fit: contain;
    display: block;
}

.sec-{{ section.id }} .sfl-block-text {
    color: #000;
    font-family: "Mona Sans", sans-serif;
    font-size: 24px;
    font-weight: 600;
    line-height: 120%;
    text-transform: capitalize;
    letter-spacing: 0;
    margin: 0;
}

@media (max-width: 768px) {
    .sec-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .sec-{{ section.id }} .sfl-inner {
        grid-template-columns: 1fr;
        gap: 24px;
    }

    .sec-{{ section.id }} .sfl-left {
        position: static;
        text-align: center;
    }

    .sec-{{ section.id }} .sfl-title {
        margin: 0 0 16px;
    }

    .sec-{{ section.id }} .sfl-subtitle {
        font-size: 14px;
        line-height: 120%;
        text-align: center;
    }

    .sec-{{ section.id }} .sfl-block-item {
        padding: 12px;
        gap: 12px;
    }

    .sec-{{ section.id }} .sfl-block-icon {
        width: 40px;
        height: 40px;
    }

    .sec-{{ section.id }} .sfl-block-text {
        font-size: 16px;
        font-weight: 600;
        line-height: 25px;
        letter-spacing: 0;
    }
}
{% endstyle %}

<div class="sec-{{ section.id }}{% if section.settings.customclass != blank %} {{ section.settings.customclass }}-{{ section.id }}{% endif %} fade-in-section">
    <div class="page-width">
        <div class="sfl-inner">

            {% comment %} Left: Sticky Content {% endcomment %}
            <div class="sfl-left">
                {% if section.settings.title != blank %}
                    <h2 class="sfl-title title_title fade-in-up">{{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                {% endif %}
                {% if section.settings.subtitle != blank %}
                    <p class="sfl-subtitle fade-in-up">{{ section.settings.subtitle }}</p>
                {% endif %}
            </div>

            {% comment %} Right: Blocks {% endcomment %}
            {% if section.blocks.size > 0 %}
                <div class="sfl-blocks">
                    {% for block in section.blocks %}
                        {% if block.type == 'feature' %}
                            {% if block.settings.link != blank %}
                                <a href="{{ block.settings.link }}" class="sfl-block-item fade-in-item" {{ block.shopify_attributes }}>
                            {% else %}
                                <div class="sfl-block-item fade-in-item" {{ block.shopify_attributes }}>
                            {% endif %}

                            {% if block.settings.icon %}
                                <img
                                    src="{{ block.settings.icon | image_url }}"
                                    alt="{{ block.settings.icon.alt | default: block.settings.text }}"
                                    width="50"
                                    height="50"
                                    class="sfl-block-icon"
                                    loading="lazy"
                                >
                            {% endif %}

                            {% if block.settings.text != blank %}
                                <span class="sfl-block-text">{{ block.settings.text }}</span>
                            {% endif %}

                            {% if block.settings.link != blank %}
                                </a>
                            {% else %}
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Sticky Feature List",
  "tag": "section",
  "class": "sticky-feature-list-section",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "customclass",
      "label": "Custom Class"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Generic gifts are easy to forget. Mumu Bath helps you create gifting moments that feel warm, useful, and personal — whether you're celebrating employees, thanking clients, welcoming partners, or sending seasonal appreciation."
    },
    {
      "type": "range",
      "id": "sticky_offset",
      "label": "Sticky Top Offset",
      "info": "Distance from top of viewport when sticky (adjust for header height)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Block Styles"
    },
    {
      "type": "color",
      "id": "block_bg_color",
      "label": "Block Background",
      "default": "#FAF7EF"
    },
    {
      "type": "color",
      "id": "block_border_color",
      "label": "Block Border Color",
      "default": "#FAF7EF"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (50×50)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Employee Appreciation"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sticky Feature List",
      "category": "Custom",
      "blocks": [
        { "type": "feature", "settings": { "text": "Employee Appreciation" } },
        { "type": "feature", "settings": { "text": "Client Thank You Gifts" } },
        { "type": "feature", "settings": { "text": "Event & Conference Gifts" } },
        { "type": "feature", "settings": { "text": "Holiday & Milestone Gifting" } }
      ]
    }
  ]
}
{% endschema %}