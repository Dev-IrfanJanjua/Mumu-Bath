<cart-drawer id="cart-drawer" class="cart-drawer drawer {% if cart.empty? %}drawer--center-body{% endif %}" initial-focus="false" handle-editor-events>
  <p class="h4 cart_drawer_title" slot="header">{{ 'cart.general.title' | t }}</p>
  {%- if cart.empty? -%}

    <p class="h5 text-center empty_cart">{{ 'cart.general.empty' | t }}</p>
  {%- else -%}
    {%- if settings.cart_show_free_shipping_bar -%}
      {%- render 'free-shipping-bar' -%}
      {% comment %} {%- render 'shipping-bar' -%} {% endcomment %}
    {%- endif -%}

    <div class="cart-drawer__items">
      {%- for line_item in cart.items -%}
        {%- render 'line-item', line_item: line_item, show_quantity_selector: true -%}
      {%- endfor -%}
    </div>

    {%- unless cart.empty? -%}
      {% render 'cart-upsell', section: section, products: settings.upsell_products %}
    {%- endunless -%}

    <form action="{{ routes.cart_url }}" method="POST" class="cart-drawer__footer" slot="footer">
      <input type="hidden" name="attributes[products_mobile_grid_mode]" value="">
      <input type="hidden" name="attributes[products_desktop_grid_mode]" value="">

      {%- if section.settings.show_cart_note or section.settings.show_shipping_text -%}
        <div class="v-stack gap-0.5 justify-items-start cct">
          {% comment %} {%- if section.settings.show_cart_note -%}
            {%- assign cart_note_dialog_id = 'cart-note-' | append: section.id -%}
            <button class="link-faded-reverse" aria-controls="{{ cart_note_dialog_id }}">{{ 'cart.general.add_order_note' | t }}</button>

            <cart-note-dialog id="{{ cart_note_dialog_id }}" class="cart-drawer__order-note">
              <div class="form">
                <cart-note class="form-control">
                  {%- assign order_note = 'cart.general.order_note' | t -%}
                  {%- assign placeholder = 'cart.general.note_placeholder' | t -%}
                  {%- render 'input', name: 'note', multiline: 3, label: order_note, value: cart.note, placeholder: placeholder, show_label_as_block: true -%}
                </cart-note>

                <button type="button" class="button" is="dialog-close-button">{{ 'cart.general.save_note' | t }}</button>
              </div>
            </cart-note-dialog>
          {%- endif -%} {% endcomment %}

          {% comment %} {%- if section.settings.show_shipping_text -%}
            <p class="text-subdued">{{ 'cart.general.taxes_and_shipping_at_checkout' | t }}</p>
          {%- endif -%} {% endcomment %}

          <div class="cart_checkout_total"><span class="cart_checkout_total_text">Subtotal</span><span class="cart-drawer__button-price">{{- cart.total_price | money -}}</span></div>

          <div class="cart_checkout_text"><span>Shipping</span><span>Shipping calculated at checkout</span></div>
          <div class="cart_checkout_text"><span>Taxes</span><span>Calculated at checkout</span></div>
        </div>
      {%- endif -%}

      {% for discount_application in cart.cart_level_discount_applications %}
        <div class="h-stack justify-start gap-4">
          <span class="discount-badge text-xs">{%- render 'icon' with 'discount', width: 12 -%} {{- discount_application.title -}}</span>
          <span class="text-subdued">-{{ discount_application.total_allocated_amount | money }}</span>
        </div>
      {% endfor %}

      <div class="button-group cart_drawe_btns">
        {% comment %} {%- if section.settings.show_view_cart_button or section.settings.show_checkout_button == false -%}
          {%- assign view_cart = 'cart.general.view_cart' | t -%}
          {%- render 'button', href: routes.cart_url, content: view_cart, stretch: true -%}
        {%- endif -%} {% endcomment %}

        {%- if section.settings.show_checkout_button -%}
          {%- capture checkout_button -%}
            {{- 'cart.general.checkout' | t -}}

            {%- if section.settings.show_price_in_checkout_button -%}
              {% comment %} <span class="cart-drawer__button-price">{{- cart.total_price | money -}}</span> {% endcomment %}
            {%- endif -%}
          {%- endcapture -%}

          {%- render 'button', type: 'submit', content: checkout_button, name: 'checkout', stretch: true -%}
    
        {%- endif -%}
      </div>
    </form>
  {%- endif -%}
</cart-drawer>

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "class": "shopify-section--cart-drawer",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.cart_drawer.page_info"
    },
    {
      "type": "paragraph",
      "content": "t:sections.cart_drawer.free_shipping_bar_info"
    },
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "t:sections.cart_drawer.show_cart_note",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_text",
      "label": "t:sections.cart_drawer.show_shipping_text",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_cart_button",
      "label": "t:sections.cart_drawer.show_view_cart_button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_checkout_button",
      "label": "t:sections.cart_drawer.show_checkout_button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price_in_checkout_button",
      "label": "t:sections.cart_drawer.show_price_in_checkout_button",
      "default": true
    }
  ]
}
{% endschema %}

{% comment %} ===== Custom Stylling ===== {% endcomment %}

{% style %}

.cart-drawer__items line-item.line-item {
    gap: 12px;
    align-items: stretch;
}

.cart-drawer__items img.line-item__media {
    border-radius: 6px;
    aspect-ratio: 1;
    max-width: 117px;
    width: 100%;
    flex-shrink: 0;
}

.cart-drawer__items .line-item-info {
    flex: 1;
}

.cart-drawer__items .line-item-info .cart_qty_wrapper {
    max-width: 100%;
    width: 100%;
    justify-content: space-between;
}

.cart-drawer__items .line-item-info a.cart_drawer_rmv {
    text-decoration: none !important;
    background: transparent;
}

.cart-drawer__items .line-item-info a.h6 {
    color: var(--Black---S, #333);
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
}

.cart-drawer__items price-list.price-list sale-price.text-subdued {
    color: var(--Black---S, #333);
    font-family: "Plus Jakarta Sans";
    font-size: 14px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    letter-spacing: 0;
}

quantity-selector.cart_qty_slctr {
    border-radius: 4px;
    border: 0.8px solid #1E1E1E;
    background: #FFF;
}

quantity-selector.cart_qty_slctr input.quantity-selector__input.text-sm {
    color: #1E1E1E;
    text-align: center;
    font-family: "Plus Jakarta Sans";
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
}

.cart-drawer__items .line-item-info .v-stack {
    gap: 10px;
}

.cart-drawer::part(body) {
    padding: 0 24px;
}

.cart-drawer::part(header) {
    padding: 24px 24px 16px;
    border: none;
}

.drawer::part(footer) {
    padding: 24px;
    background: #F7F3ED;
    border: none;
}

.cart_drawe_btns button.button {
    border-radius: 33.19px;
    background: var(--Yellow, #FBDD40);
    padding: 14px 24px;
    color: #000;
    font-family: "Plus Jakarta Sans";
    font-size: 14.571px;
    font-style: normal;
    font-weight: 500;
    line-height: 148%;
    text-transform: capitalize;
    letter-spacing: 0;
}

.cart_checkout_text {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
    width: 100%;
    color: var(--black-color, #000);
    font-family: "Plus Jakarta Sans";
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
}

.v-stack.cct {
    gap: 8px;
}

.cart_checkout_total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}

span.cart_checkout_total_text {
    color: var(--black-color, #000);
    font-family: "Mona Sans";
    font-size: 14px;
    font-style: normal;
    font-weight: 700;
    line-height: 120%;
}

.cart_checkout_total span.cart-drawer__button-price {
    color: var(--Black---S, #333);
    font-family: "Plus Jakarta Sans";
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
}

.cart_checkout_total span.cart-drawer__button-price:before{
  display: none
}

span.free-shipping-bar__text.text-subdued {
    color: var(--Green-girls-Black, #0A180A);
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
}

span.free-shipping-bar__text.text-subdued span {
    color: var(--Green-girls-Black, #0A180A);
    font-family: "Plus Jakarta Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
}

free-shipping-bar.free-shipping-bar {
    padding-block: 0 !important;
    background: transparent;
    border: none;
}

.cart-upsell-swiper .hair-product-card__title a {
    font-size: 12px;
    line-height: 16px;
}

.cart-upsell-swiper .hair-product-price {
    font-size: 14px;
}

.cart-upsell-swiper .atc-btn,
.cart-upsell-swiper .atc-btn button {
    max-width: fit-content !important;
    width: 100%;
    font-size: 14px;
}

p.h4.cart_drawer_title {
    color: var(--Green-girls-Black, #0A180A);
    font-family: "Mona Sans";
    font-size: 22px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
}

.cart-upsell-swiper .hair-product-rating {
    display: none;
}

.cart-upsell-swiper .atc-btn button svg {
    width: 15px;
    height: 15px;
}

p.h5.text-center.empty {
    color: var(--rhokea-com-swamp, var(--color-cyan-4, #001116));
    font-family: "Mona Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    text-transform: capitalize;
}

@media screen and (max-width: 768px){

.cart-drawer::part(header) {
    padding: 16px;
}

.cart-drawer::part(body) {
    padding: 0 16px;
}

.drawer::part(footer) {
    padding: 16px;
}

.cart-drawer__items .line-item-info a.h6 {
    font-size: 14px;
}

quantity-selector.cart_qty_slctr input.quantity-selector__input.text-sm {
    font-size: 16px;
}

.cart-drawer__items img.line-item__media {
    aspect-ratio: 1.2;
    max-width: 100px;
}

.cart-drawer__items line-item.line-item {
    gap: 10px;
    align-items: center ;
}

.cart-drawer__items {
    gap: 16px;
}

}

{% endstyle %}