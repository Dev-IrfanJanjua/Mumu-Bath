    "faq_EcX73n": {
      "type": "faq",
      "blocks": {
        "question_zBxqaf": {
          "type": "question",
          "settings": {
            "question": "How long does a matcha bar typically last?",
            "answer": "<p>With daily use and proper storage on a draining soap dish, a matcha soap bar typically lasts 3 to 4 weeks. Avoid leaving it in standing water to extend its lifespan. Letting it dry between uses helps preserve its shape and texture.</p>"
          }
        },
        "question_cJ8JMP": {
          "type": "question",
          "settings": {
            "question": "How long will an unopened bar stay fresh?",
            "answer": "<p>An unopened bar can stay fresh for up to 18 months when stored in a cool, dry place. Keep it sealed away from moisture and heat to maintain quality.</p>"
          }
        },
        "question_z9ChLj": {
          "type": "question",
          "settings": {
            "question": "How often can I use matcha soap?",
            "answer": "<p>You can use it daily, both morning and night. The formula is gentle enough for everyday cleansing without disrupting your skin's natural barrier. Just be sure to follow up with a moisturizer to lock in hydration.</p>"
          }
        },
        "question_TkkxCx": {
          "type": "question",
          "settings": {
            "question": "Is this soap vegan and cruelty-free?",
            "answer": "<p>Yes, all our soaps are 100% vegan and cruelty-free. We never test on animals and do not use any animal-derived ingredients. It’s part of our clean and conscious skincare philosophy.</p>"
          }
        },
        "question_EWi3Vf": {
          "type": "question",
          "settings": {
            "question": "Is matcha green tea soap suitable for acne-prone skin?",
            "answer": "<p>Yes, the natural antibacterial and anti-inflammatory properties in matcha green tea soap make it great for acne-prone skin. It helps reduce redness, control oil, and clear pores without over-drying. Many of our customers see noticeable improvements with consistent use.</p>"
          }
        },
        "question_Wn9NN8": {
          "type": "question",
          "settings": {
            "question": "How do I store the soap between uses?",
            "answer": "<p>Keep it on a well-draining soap dish to allow it to dry completely. Avoid leaving it in a wet or enclosed space. This helps preserve its shape and extend its life.</p>"
          }
        },
        "question_CGB4DF": {
          "type": "question",
          "settings": {
            "question": "Can I pair this soap with your body butter or balm?",
            "answer": "<p>Absolutely. After cleansing with our matcha soap, follow with our Lightweight Body Butter or Wonder Balm for added hydration and skin support.</p>"
          }
        },
        "question_xN3MCA": {
          "type": "question",
          "settings": {
            "question": "Is this soap safe for kids or teens?",
            "answer": "<p>Yes, the gentle, natural ingredients make it safe for most skin types, including younger users. Many teens use it for oily or breakout-prone skin with great results.</p>"
          }
        },
        "question_RmkLgB": {
          "type": "question",
          "settings": {
            "question": "Will matcha tea soap help with dull or uneven skin tone?",
            "answer": "<p>Yes, matcha tea soap is great for reviving dull skin. Its natural antioxidants help improve clarity and promote a more even skin tone. With regular use, your skin can look fresher and more radiant.</p>"
          }
        },
        "question_WDqjX9": {
          "type": "question",
          "settings": {
            "question": "Is your soap cold-processed?",
            "answer": "<p>Yes, we use the cold process method to make all our soaps. This helps retain the full benefits of the natural oils, herbs, and matcha powder. It also results in a firmer, longer-lasting bar.</p>"
          }
        }
