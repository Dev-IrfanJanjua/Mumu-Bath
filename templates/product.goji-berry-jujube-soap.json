    "faq_tqwRnR": {
      "type": "faq",
      "blocks": {
        "question_BMPHW7": {
          "type": "question",
          "settings": {
            "question": "Can I use gluta berry soap daily on sensitive skin?",
            "answer": "<p>Yes, our gluta berry soap is gentle enough for daily use, even on sensitive skin types. We use mild, nourishing ingredients like olive oil and coconut oil that maintain your skin’s natural moisture. The goji berry extract works to brighten your complexion gradually.</p>"
          }
        },
        "question_6C88fk": {
          "type": "question",
          "settings": {
            "question": "Does the Goji Berry Soap contain any artificial colors or fragrances?",
            "answer": "<p>No, we do not use artificial colors or synthetic fragrances in our Goji Berry Soap. All scent and color come from natural sources like essential oils and botanicals. It’s a clean beauty product you can feel good about.</p>"
          }
        },
        "question_TYnMe7": {
          "type": "question",
          "settings": {
            "question": "How should I store the Goji Berry Soap between uses?",
            "answer": "<p>Store your Goji Berry Soap in a well-drained soap dish away from standing water. This prevents it from becoming mushy and helps it last longer. A dry environment keeps the bar firm and fresh.</p>"
          }
        },
        "question_K4YDfb": {
          "type": "question",
          "settings": {
            "question": "Is your goji berry soap bar suitable for the face and body?",
            "answer": "<p>Yes, the goji berry soap bar is gentle enough for both the face and body. It cleanses without over-drying and helps maintain natural skin moisture. The goji berry infusion supports a radiant, healthy glow.</p>"
          }
        },
        "question_X8H44j": {
          "type": "question",
          "settings": {
            "question": "Is this soap suitable for children?",
            "answer": "<p>Yes, our Goji Berry Soap is gentle enough for kids aged 3 and above. It's free from harsh chemicals, synthetic fragrances, and artificial dyes.</p>"
          }
        },
        "question_dmrMBV": {
          "type": "question",
          "settings": {
            "question": "How often should I use soap for the best results?",
            "answer": "<p>We recommend using Goji Berry Soap daily for optimal results. Consistency is key to achieving a natural glow and smooth skin.</p>"
          }
        },
        "question_rG63db": {
          "type": "question",
          "settings": {
            "question": "How long does one goji berry soap bar typically last?",
            "answer": "<p>One goji berry soap bar can last anywhere from 3 to 5 weeks depending on usage and storage. To extend its lifespan, keep it dry between uses using a soap dish with drainage.</p>"
          }
        },
        "question_C4k94e": {
          "type": "question",
          "settings": {
            "question": "What should I do if my product is damaged or incorrect?",
            "answer": "<p>Please inspect your order upon arrival and contact us right away if it's defective, damaged, or incorrect. We’ll evaluate the issue and work to resolve it promptly.</p>"
          }
        },
        "question_QwbcnV": {
          "type": "question",
          "settings": {
            "question": "How does goji berry beauty soap support skin hydration?",
            "answer": "<p>The goji berry beauty soap is crafted with nourishing oils that help lock in moisture while cleansing. Goji berry extract adds an antioxidant boost that helps prevent dryness and dullness. Your skin feels refreshed and hydrated after each use.</p>"
          }
        },
        "question_KY4QfU": {
          "type": "question",
          "settings": {
            "question": "How long does it take for Mumu Bath orders to ship?",
            "answer": "<p>Orders are typically processed within 3–5 business days, with shipments going out Monday to Friday. We use USPS First Class, USPS Ground, or UPS Ground, and shipping may be delayed during public holidays or due to unforeseen issues.</p>"
          }
