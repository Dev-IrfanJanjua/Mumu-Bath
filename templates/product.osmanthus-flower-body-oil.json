    "faq_tqwRnR": {
      "type": "faq",
      "blocks": {
        "question_BMPHW7": {
          "type": "question",
          "settings": {
            "question": "<strong>Is your osmanthus body oilsuitable for sensitive skin?</strong>",
            "answer": "<p>Yes, our osmanthus body oil is crafted with gentle, skin-loving ingredients suitable for most skin types, including sensitive skin. It’s free from synthetic fragrances, parabens, and sulfates. Always do a patch test if you have particularly reactive skin.</p>"
          }
        },
        "question_6C88fk": {
          "type": "question",
          "settings": {
            "question": "How often should I apply oil?",
            "answer": "<p>You can use oil daily, especially after showering or bathing. For the best results, apply while your skin is still damp to lock in moisture. It’s also great for a relaxing bedtime ritual.</p>"
          }
        },
        "question_TYnMe7": {
          "type": "question",
          "settings": {
            "question": "Is essential oil osmanthus safe for everyday use?",
            "answer": "<p>Yes, when properly diluted - as it is in our body oil - essential oil osmanthus is safe for daily use. Our formulation blends this oil with nourishing plant-based oils for a balanced, skin-friendly product. We always recommend doing a patch test if you’re new to essential oils.</p>"
          }
        },
        "question_K4YDfb": {
          "type": "question",
          "settings": {
            "question": "Does this body oil contain any synthetic fragrances?",
            "answer": "<p>No, we do not use synthetic fragrances in any of our products. The scent in our body oil comes naturally from real osmanthus and botanical extracts, offering a clean and authentic aroma.</p>"
          }
        },
        "question_X8H44j": {
          "type": "question",
          "settings": {
            "question": "Can osmanthus oil be used on the face?",
            "answer": "<p>While osmanthus oil is gentle, our body oil is formulated specifically for body use. For facial care, we recommend using products specially made for facial skin, as they are often lighter and more targeted in their formulation.</p>"
          }
        },
        "question_dmrMBV": {
          "type": "question",
          "settings": {
            "question": "Is the Osmanthus Flower Body Oil greasy or heavy?",
            "answer": "<p>Not at all. Our body oil is lightweight and fast absorbing. It leaves your skin feeling silky-smooth without any sticky residue.</p>"
          }
        },
        "question_rG63db": {
          "type": "question",
          "settings": {
            "question": "Is your osmanthus oil sustainably sourced?",
            "answer": "<p>We’re committed to ethically sourcing our osmanthus oil and other ingredients. Our formulations are made in small batches with quality in mind, and we work with trusted suppliers who align with our values of sustainability and purity.</p>"
          }
        },
        "question_C4k94e": {
          "type": "question",
          "settings": {
            "question": "Will the oil stain clothes or sheets?",
            "answer": "<p>When applied properly and given a few minutes to absorb, it should not stain. Always allow the oil to fully absorb before getting dressed or lying down.</p>"
          }
        },
        "question_QwbcnV": {
          "type": "question",
          "settings": {
            "question": "How should I store body oil?",
            "answer": "<p>Store in a cool, dry place away from direct sunlight. This helps preserve the oil's natural properties and extends shelf life.</p>"
          }
        }
      },
