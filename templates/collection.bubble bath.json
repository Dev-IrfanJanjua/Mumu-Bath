    "rich_text_R6pygD": {
      "type": "rich-text",
      "blocks": {
        "heading_jBdTem": {
          "type": "heading",
          "settings": {
            "text": "Relax Naturally with Bubbles & Bombs",
            "heading_tag": "h3"
          }
        },
        "richtext_VByAYY": {
          "type": "richtext",
          "settings": {
            "content": "<p>Discover the joy of bath time with our artisanal collection of bubble bars and bath bombs, made to pamper your skin and calm your senses. We use skin-loving ingredients like essential oils and botanicals for a soothing soak that feels as good as it smells. Whether you need stress relief or a little sparkle, we’ve got something special for every bath ritual.</p><p><br/>Our formulas are designed to be gentle on all skin types, especially sensitive ones. Each product in this range offers a non toxic bubble bath experience, free from harsh chemicals and synthetic fragrances. Enjoy clean, conscious bathing with bubbles that truly care for your skin.</p>"
          }
        }
      },
      "block_order": [
        "heading_jBdTem",
        "richtext_VByAYY"
