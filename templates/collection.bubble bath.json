    "rich_text_CGgURU": {
      "type": "rich-text",
      "blocks": {
        "heading_ewHb3D": {
          "type": "heading",
          "settings": {
            "text": "Why Shop From Us",
            "heading_tag": "h3"
          }
        },
        "richtext_XTWngx": {
          "type": "richtext",
          "settings": {
            "content": "<p>We believe bath time should be joyful, safe, and skin-loving. Our products are crafted with care for the whole family.</p><ul><li><strong>Clean Ingredients Always</strong> – We use only natural, non-toxic ingredients that are gentle on skin. No parabens, no sulfates - just pure bath-time bliss.</li><li><strong>Made for All Ages</strong> – Whether it’s a playful soak for kids or a relaxing soak for adults, our products suit everyone. They’re dermatologist-tested and parent-approved.</li><li><strong>Rich, Skin-Loving Formulas</strong> – Our bubble bath liquid is packed with nourishing oils and gentle cleansers. It foams beautifully while softening and hydrating your skin.</li><li><strong>Eco-Friendly & Cruelty-Free</strong> – We care about the planet as much as your skin. That’s why our packaging is recyclable and our products are never tested on animals.</li></ul>"
          }
        }
      },
