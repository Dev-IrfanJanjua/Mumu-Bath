        "liquid": "<style>\n  .custom-subscription-buttons {\n    display: flex;\n    flex-direction: row;        /* 橫排排列 */\n    justify-content: center;    /* 水平置中 */\n    gap: 24px;                  /* 左右間距 */\n    margin-top: 24px;\n    flex-wrap: wrap;            /* 避免在小螢幕擠出畫面 */\n  }\n\n  .custom-subscription-btn {\n    background-color: #fbdd40;\n    color: #1c1c1c;\n    padding: 14px 28px;\n    border: none;\n    border-radius: 4px;\n    font-size: 14px;\n    font-weight: 600;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    text-decoration: none;\n    text-align: center;\n    transition: background-color 0.3s ease, transform 0.2s ease;\n    cursor: pointer;\n  }\n\n  .custom-subscription-btn:hover {\n    background-color: #e5c73f;\n    transform: translateY(-2px);\n  }\n</style>\n\n<div class=\"custom-subscription-buttons\">\n  <a href=\"https://www.mumubath.com/collections/subscription-products\" class=\"custom-subscription-btn\">\n    VIEW ALL SUBSCRIPTION PRODUCTS\n  </a>\n  <a href=\"https://www.mumubath.com/apps/subscriptions#/subscriptions/list\" class=\"custom-subscription-btn\">\n    Manage Your Subscription\n  </a>\n</div>",
