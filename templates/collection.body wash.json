    "rich_text_QKDVtr": {
      "type": "rich-text",
      "blocks": {
        "heading_43izgH": {
          "type": "heading",
          "settings": {
            "text": "Benefits of Our Body Wash",
            "heading_tag": "h3"
          }
        },
        "richtext_GaxmAD": {
          "type": "richtext",
          "settings": {
            "content": "<p>Enjoy a shower experience that’s kind to your skin and kind to the planet. Our body wash bars are packed with natural goodness for daily care that feels indulgent.</p><ol><li><strong>Deep Yet Gentle Cleansing</strong> – Removes dirt and buildup without drying your skin, thanks to our naturally derived cleansers.</li><li><strong>Moisture-Boosting Formula</strong> – Rich oils and butters lock in hydration, leaving your skin soft and nourished after every wash.</li><li><strong>Safe for All Skin Types</strong> – Our healthy body wash is free from harsh chemicals, making it perfect for sensitive or reactive skin.</li><li><strong>Long-Lasting Bars</strong> – Each bar is designed to last, offering great value while reducing plastic waste in your routine.</li><li><strong>Environmentally Conscious</strong> – Our eco friendly body wash is crafted with biodegradable ingredients and plastic-free packaging.</li></ol>"
          }
        }
      },
      "block_order": [
        "heading_43izgH",
        "richtext_GaxmAD"
      ],
      "name": "t:sections.rich_text.presets.rich_text.name",
      "settings": {
        "reserve-rich-text-id": "",
        "separate_section_with_border": true,
