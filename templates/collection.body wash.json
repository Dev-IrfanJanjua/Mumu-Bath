    "faq_mUrKEg": {
      "type": "faq",
      "blocks": {
        "question_EyADUL": {
          "type": "question",
          "settings": {
            "question": "How long does one bar of Mumu Bath body wash last?",
            "answer": "<p>Depending on usage and storage, each body wash bar typically lasts 3-4 weeks. Keep it dry between uses to extend its life.</p>"
          }
        },
        "question_8wUT3M": {
          "type": "question",
          "settings": {
            "question": "How does an eco friendly body wash help reduce my carbon footprint?",
            "answer": "<p>By eliminating plastic packaging and reducing water content, our eco friendly body wash uses less energy in production and transport - minimizing your impact on the environment.</p>"
          }
        },
        "question_g6Qpaz": {
          "type": "question",
          "settings": {
            "question": "How is Mumu Bath different from other natural soap brands?",
            "answer": "<p>We focus on holistic skin wellness with plant-based, clean ingredients, sustainable packaging, and handcrafted care. Every product is a reflection of our values.</p>"
          }
        },
        "question_AEMxrj": {
          "type": "question",
          "settings": {
            "question": "How should I store the body wash bar between uses?",
            "answer": "<p>Keep it dry on a soap dish with drainage to prevent it from sitting in the water. This helps extend the life of your bar.</p>"
          }
        },
        "question_7tnBUR": {
          "type": "question",
          "settings": {
            "question": "Is your healthy body wash safe for kids or sensitive skin types?",
            "answer": "<p>Yes, our healthy body wash is gentle enough for kids and those with sensitive skin. We prioritize clean, minimal ingredients that support skin health at any age.</p>"
          }
        },
        "question_JTGYGL": {
          "type": "question",
          "settings": {
            "question": "What is your return policy on body wash bars?",
            "answer": "<p>We accept returns within 30 days if the item is unused and in its original packaging. Please refer to our Returns page for full details.</p>"
          }
        },
        "question_y3QTGC": {
          "type": "question",
          "settings": {
            "question": "What if my body wash bar arrives damaged?",
            "answer": "<p>We’re here to help! If your item arrives damaged, send us a photo at hello@mumubath.com and we’ll send a replacement or issue a refund.</p>"
          }
        },
        "question_iwGygq": {
          "type": "question",
          "settings": {
            "question": "Is your chemical free body wash safe for daily use?",
            "answer": "<p>Absolutely! Our chemical free body wash is designed for everyday cleansing without irritating or drying your skin. It’s gentle, effective, and perfect for all skin types.</p>"
          }
        },
        "question_eYM96Y": {
          "type": "question",
          "settings": {
            "question": "How long does shipping take for body wash orders?",
            "answer": "<p>We usually ship within 2–3 business days. Delivery times vary by location, but most U.S. orders arrive within 3–7 days.</p>"
          }
        },
        "question_UTifKQ": {
          "type": "question",
          "settings": {
            "question": "Do your body wash bars contain artificial fragrances?",
            "answer": "<p>No, all our bars are scented using only essential oils or natural botanicals. We never use synthetic fragrances or harsh additives.</p>"
          }
        }
      },
