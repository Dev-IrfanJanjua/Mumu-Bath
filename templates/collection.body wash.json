    "rich_text_jhkyVe": {
      "type": "rich-text",
      "blocks": {
        "heading_4JKEdV": {
          "type": "heading",
          "settings": {
            "text": "Why Choose Our Body Wash?",
            "heading_tag": "h3"
          }
        },
        "richtext_beVDC4": {
          "type": "richtext",
          "settings": {
            "content": "<p>Our body wash is crafted with care for your skin and the planet. Every bar blends gentle cleansing with wholesome ingredients for a truly refreshing experience.</p><ol><li>Made with Natural Ingredients – We use plant-based oils and botanical extracts to cleanse without stripping your skin’s moisture barrier.</li><li><strong>Gentle on Sensitive Skin</strong> – Our chemical free body wash is safe for all skin types, even the most delicate and allergy-prone.</li><li><strong>Nourishes While It Cleanses</strong> – Rich in vitamins and antioxidants, each wash leaves your skin soft, smooth, and hydrated.</li><li><strong>Eco-Friendly & Sustainable</strong> – Our packaging is plastic-free and biodegradable, making your daily routine better for the earth.</li><li><strong>Promotes Long-Term Skin Health</strong> – With no harsh additives, our healthy body wash supports your skin’s natural balance and glow.</li></ol>"
          }
        }
      },
      "block_order": [
        "heading_4JKEdV",
        "richtext_beVDC4"
      ],
