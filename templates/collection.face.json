        "question_GYm9bf": {
          "type": "question",
          "settings": {
            "question": "<strong>Can I use your lip balm on cracked lips?</strong>",
            "answer": "<p>Yes, our all-natural lip balm is perfect for healing dry or cracked lips. It’s made with nourishing oils and no synthetic waxes.</p>"
