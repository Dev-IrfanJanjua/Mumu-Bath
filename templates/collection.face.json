        "question_WrbtdB": {
          "type": "question",
          "settings": {
            "question": "<strong>Do you use any parabens or sulfates in your face products?</strong>",
            "answer": "<p>No, our formulas are free from parabens, sulfates, phthalates, and other harsh chemicals. We believe in clean, safe skincare.</p>"
