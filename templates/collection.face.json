        "question_mc7LhM": {
          "type": "question",
          "settings": {
            "question": "<strong>How should I layer the products in your face skincareroutine?</strong>",
            "answer": "<p>Start with a cleanser, follow with our serum, then apply moisturizer, and finish with eye cream or balm. Our <strong>face skincare</strong> line is designed to work together in harmony.</p>"
