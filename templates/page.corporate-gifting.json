    "faq_7jpQAT": {
      "type": "faq",
      "blocks": {
        "question_kEfiQi": {
          "type": "question",
          "settings": {
            "question": "Is there an order minimum for corporate gifting orders? ",
            "answer": "<p>Our order minimum quantity is 10 gifts with a minimum price of $25 per gift.</p>"
          }
        },
        "question_Tmtyii": {
          "type": "question",
          "settings": {
            "question": "How long does the order process take?",
            "answer": "<p>Once we receive your order request, you can expect to hear from our team in 1-2 business days. We'll work with you to choose the best gift for your needs.</p><p>We will ship all gifts to your recipient list within 4-7 business days, depending on order size. Rush order turnaround is possible on a case by case basis. Just let us know what you need!</p>"
          }
        },
        "question_jnYjXx": {
          "type": "question",
          "settings": {
            "question": "Where do you ship? How much does it cost?",
            "answer": "<p>At the moment we only ship within the U.S., and shipping cost will vary depending on the shipping method needed to hit your deadline. We can ship to a single location, or send each gift directly to recipients. </p>"
          }
