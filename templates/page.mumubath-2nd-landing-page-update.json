    "mblp_faqs_CR6TgB": {
      "type": "mblp-faqs",
      "blocks": {
        "faq_item_YQHfr8": {
          "type": "faq_item",
          "settings": {
            "question": "How long does a bath bomb making workshop usually last?",
            "answer": "Each bath bomb making workshop runs about 1.5 to 2 hours. It includes hands-on creation, drying time, and plenty of time for laughter and photos."
          }
        },
        "faq_item_jA8iY6": {
          "type": "faq_item",
          "settings": {
            "question": "Do you require a deposit for private party bookings?",
            "answer": "Yes, a small deposit secures your date and materials. The remaining balance is due closer to the event."
          }
        },
        "faq_item_CjLpPP": {
          "type": "faq_item",
          "settings": {
            "question": "What is included in a bath bomb workshop party package?",
            "answer": "Each bath bomb workshop party includes all supplies, instruction, and materials for every guest. We also handle setup and cleanup, so you can simply enjoy."
          }
        },
        "faq_item_qrrn7d": {
          "type": "faq_item",
          "settings": {
            "question": "Do you provide refreshments, or should we bring our own?",
            "answer": "We focus on the bath bomb experience, but you’re welcome to bring snacks or drinks. We’ll make sure there’s space for your setup."
          }
        },
        "faq_item_Vz3LPx": {
          "type": "faq_item",
          "settings": {
            "question": "What if someone in the group has sensitive skin?",
            "answer": "No worries! We use gentle, natural ingredients suitable for all skin types. If anyone has allergies, just let us know beforehand."
          }
        },
        "faq_item_DFRg9C": {
          "type": "faq_item",
          "settings": {
            "question": "Can a bath bomb workshop party be customized for specialevents?",
            "answer": "Yes, your bath bomb workshop party can be tailored for birthdays, bridal showers, or team-building events. We’ll match the theme, colors, and scents to suit your occasion."
          }
        },
        "faq_item_VMMcFy": {
          "type": "faq_item",
          "settings": {
            "question": "What happens if I need to reschedule my party?",
            "answer": "We understand plans can change. Just contact us as early as possible, and we’ll help you find a new date that works."
          }
        },
        "faq_item_WjRWCq": {
          "type": "faq_item",
          "settings": {
            "question": "What should participants wear?",
            "answer": "We recommend comfortable clothing you don’t mind getting a little powder on. Aprons are provided for extra protection."
          }
        },
        "faq_item_GKEUTm": {
          "type": "faq_item",
          "settings": {
            "question": "Do guests take home what they make in the bath bomb makingclass?",
            "answer": "Yes! Every participant in our bath bomb making class gets to take home their custom-made bath bombs. It’s a beautiful keepsake that’s both personal and practical."
          }
        },
        "faq_item_WU38p3": {
          "type": "faq_item",
          "settings": {
            "question": "Can guests share tools and materials?",
            "answer": "We provide enough materials for each participant, but some tools may be shared to keep the setup organized. Everything is sanitized between uses."
          }
        }
      },
