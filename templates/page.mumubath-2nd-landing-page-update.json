    "mblp_faqs_9Ac7cj": {
      "type": "mblp-faqs",
      "blocks": {
        "faq_item_Pbqfcq": {
          "type": "faq_item",
          "settings": {
            "question": "Can we bring our own food or drinks?",
            "answer": "For hygiene reasons, no food is permitted in the workshop space."
          }
        },
        "faq_item_JTM9FJ": {
          "type": "faq_item",
          "settings": {
            "question": "Can we decorate the space before the party?",
            "answer": "Absolutely! If you’d like to decorate and personalize your party, please arrive 30 minutes before the workshop."
          }
        },
        "faq_item_m9XEbf": {
          "type": "faq_item",
          "settings": {
            "question": "Where can participants leave their coats and belongings?",
            "answer": "We have a sofa area where you can leave coats, bags, and personal belongings."
          }
        },
        "faq_item_cR8Vg9": {
          "type": "faq_item",
          "settings": {
            "question": "Where should we place birthday gifts or other gifts?",
            "answer": "You can place the gifts in the bathtub."
          }
        },
        "faq_item_CM4ajD": {
          "type": "faq_item",
          "settings": {
            "question": "How does payment work?",
            "answer": "We accept cash, credit cards, and digital payments. A 50% deposit is required to book, with the balance due before the day of your event."
          }
        },
        "faq_item_cL8YxL": {
          "type": "faq_item",
          "settings": {
            "question": "What's the guest limit?",
            "answer": "Group size: minimum 8, maximum 16.\nAge groups: ages 6–13 and 14+ (14 and over)."
          }
        }
