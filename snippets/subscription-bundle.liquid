<script>
(function () {
  var widget = document.getElementById('{{ widget_id }}');
  if (!widget) return;

  /* ─────────────────────────────────────────
      ELEMENT REFS
  ───────────────────────────────────────── */
  var moneyFormat  = {{ shop.money_format | json }};
  var isSubscribe  = widget.dataset.defaultPurchase === 'subscribe';

  var purchaseRows   = widget.querySelectorAll('[data-ssw-purchase-row]');
  var subContent     = widget.querySelector('[data-ssw-sub-content]');
  var planCards      = widget.querySelectorAll('[data-ssw-plan]');

  var qtyInput         = widget.querySelector('[data-ssw-quantity]');
  var variantInput     = widget.querySelector('[data-ssw-variant]');
  var sellingPlanInput = widget.querySelector('.wid__selling_plan');

  var freqSelect = widget.querySelector('[data-ssw-frequency]');
  var freqHidden = widget.querySelector('input[name="selling_plan"]:not(.wid__selling_plan)');

  /* ─────────────────────────────────────────
      MONEY FORMATTER
  ───────────────────────────────────────── */
  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents, moneyFormat);
    }
    return '$' + (cents / 100).toFixed(2);
  }

  /* ─────────────────────────────────────────
      GET ACTIVE SELLING PLAN ID
  ───────────────────────────────────────── */
  function getActivePlanId() {
    if (freqSelect) return freqSelect.value || '';
    if (freqHidden) return freqHidden.value || '';
    return '';
  }

  /* ─────────────────────────────────────────
      SYNC THE SELLING PLAN INPUT
  ───────────────────────────────────────── */
  function syncSellingPlanInput() {
    if (!sellingPlanInput) return;
    sellingPlanInput.value = isSubscribe ? getActivePlanId() : '';
  }

  /* ─────────────────────────────────────────
      UPDATE PLAN CARD PRICES
  ───────────────────────────────────────── */
  function updatePlanPrices() {
    planCards.forEach(function (card) {
      var priceCents   = parseInt(card.dataset.priceCents,    10) || 0;
      var compareCents = parseInt(card.dataset.compareCents,  10) || 0;
      var subCents     = parseInt(card.dataset.subPriceCents, 10) || 0;
      var otpSavePct   = parseInt(card.dataset.otpSavePct,    10) || 0;
      var subSavePct   = parseInt(card.dataset.subSavePct,    10) || 0;

      var priceEl   = card.querySelector('[data-ssw-plan-price]');
      var compareEl = card.querySelector('[data-ssw-plan-compare]');
      var saveEl    = card.querySelector('[data-ssw-plan-save]');

      if (isSubscribe) {
        if (priceEl) priceEl.textContent = formatMoney(subCents);
        if (compareEl) {
          if (priceCents > 0 && subCents < priceCents) {
            compareEl.textContent   = formatMoney(priceCents);
            compareEl.style.display = '';
          } else {
            compareEl.style.display = 'none';
          }
        }
        if (saveEl) {
          if (subSavePct > 0) {
            saveEl.textContent   = 'Save ' + subSavePct + '%';
            saveEl.style.display = '';
          } else {
            saveEl.style.display = 'none';
          }
        }
      } else {
        if (priceEl) priceEl.textContent = formatMoney(priceCents);
        if (compareEl) {
          if (compareCents > 0 && compareCents > priceCents) {
            compareEl.textContent   = formatMoney(compareCents);
            compareEl.style.display = '';
          } else {
            compareEl.style.display = 'none';
          }
        }
        if (saveEl) {
          if (otpSavePct > 0) {
            saveEl.textContent   = 'Save ' + otpSavePct + '%';
            saveEl.style.display = '';
          } else {
            saveEl.style.display = 'none';
          }
        }
      }
    });
  }

  /* ─────────────────────────────────────────
      SELECT PURCHASE TYPE
  ───────────────────────────────────────── */
  function selectPurchaseType(type) {
    isSubscribe = (type === 'subscribe');
    widget.dataset.activePurchase = type;

    purchaseRows.forEach(function (row) {
      var active = row.dataset.sswPurchaseRow === type;
      var radio  = row.querySelector('input[type="radio"]');
      if (radio) radio.checked = active;
      row.setAttribute('aria-checked', active ? 'true' : 'false');
    });

    if (subContent) subContent.classList.toggle('is-visible', isSubscribe);

    syncSellingPlanInput();
    updatePlanPrices();
  }

  /* ─────────────────────────────────────────
      SELECT A PLAN CARD
  ───────────────────────────────────────── */
  function selectPlan(card) {
    planCards.forEach(function (c) {
      var radio = c.querySelector('input[type="radio"]');
      if (radio) radio.checked = false;
      c.setAttribute('aria-checked', 'false');
    });

    var activeRadio = card.querySelector('input[type="radio"]');
    if (activeRadio) activeRadio.checked = true;
    card.setAttribute('aria-checked', 'true');

    if (qtyInput) qtyInput.value = card.dataset.quantity || 1;
  }

  /* ─────────────────────────────────────────
      FREQUENCY SELECT CHANGE
  ───────────────────────────────────────── */
  if (freqSelect) {
    freqSelect.addEventListener('change', function () {
      if (!isSubscribe) {
        selectPurchaseType('subscribe');
      } else {
        syncSellingPlanInput();
      }
    });
  }

  /* ─────────────────────────────────────────
      EVENT LISTENERS — purchase type rows
  ───────────────────────────────────────── */
  purchaseRows.forEach(function (row) {
    row.addEventListener('click', function () {
      selectPurchaseType(row.dataset.sswPurchaseRow);
    });
    row.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        selectPurchaseType(row.dataset.sswPurchaseRow);
      }
    });
  });

  /* ─────────────────────────────────────────
      EVENT LISTENERS — plan cards
  ───────────────────────────────────────── */
  planCards.forEach(function (card) {
    card.addEventListener('click', function () { selectPlan(card); });
    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        selectPlan(card);
      }
    });
  });

  /* ─────────────────────────────────────────
      INIT
  ───────────────────────────────────────── */
  selectPurchaseType(widget.dataset.defaultPurchase || 'one_time');

  var defaultSelected = widget.querySelector('.ssw-plan input[type="radio"]:checked');
  if (defaultSelected) {
    selectPlan(defaultSelected.closest('[data-ssw-plan]'));
  } else if (planCards.length > 0) {
    selectPlan(planCards[0]);
  }

})();
</script> 

