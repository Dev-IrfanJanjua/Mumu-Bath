 <script>
(function() {

  // Only run on product pages
  if (!window.location.pathname.includes('/products/')) return;

  function getWidget() {
    return document.querySelector('[data-widget="subscribe-save"]');
  }

  /* ─────────────────────────────────────────
     READ CURRENT WIDGET STATE
  ───────────────────────────────────────── */
  function getWidgetValues() {
    var widget = getWidget();
    if (!widget) return null;

    // Read qty from the checked plan card's data-quantity
    var checkedPlanRadio = widget.querySelector('[data-ssw-plan] input[type="radio"]:checked');
    var qty = '1';
    if (checkedPlanRadio) {
      var card = checkedPlanRadio.closest('[data-ssw-plan]');
      qty = card ? (card.dataset.quantity || '1') : '1';
    } else {
      qty = (widget.querySelector('.wid__varient__qty') || {}).value || '1';
    }

    return {
      qty:       qty,
      plan:      (widget.querySelector('.wid__selling_plan') || {}).value || '',
      productId: widget.dataset.productId || ''
    };
  }

  /* ─────────────────────────────────────────
     FIND THE FORM LINKED TO #pdp_atc--btn
     The button lives inside <buy-buttons> which
     is OUTSIDE the <form>. The button carries a
     form="<id>" attribute that links it back.
     We must use that id to find the form —
     btn.closest('form') will always be null.
  ───────────────────────────────────────── */
  function getAtcForm() {
    var btn = document.getElementById('pdp_atc--btn');
    if (!btn) return null;

    // 1. Check the button's own form attribute
    var formId = btn.getAttribute('form');

    // 2. If not on the button, check the parent <buy-buttons> element
    if (!formId) {
      var buyButtonsEl = btn.closest('buy-buttons');
      if (buyButtonsEl) formId = buyButtonsEl.getAttribute('form');
    }

    if (formId) return document.getElementById(formId);

    // 3. Last resort — walk up (handles edge case where button IS inside form)
    return btn.closest('form');
  }

  /* ─────────────────────────────────────────
     SYNC WIDGET VALUES → FORM INPUTS
     Only touches form__qty and form__selling_plan
     inside the single product main section form.
     Does NOT affect any other cart forms.
  ───────────────────────────────────────── */
  function syncBuyInputs() {
    var vals = getWidgetValues();
    if (!vals) return;

    var form = getAtcForm();
    if (!form) return;

    // Sync quantity
    form.querySelectorAll('.form__qty').forEach(function(input) {
      input.value = vals.qty;
      input.setAttribute('value', vals.qty);
    });

    // Sync selling plan — empty string = one-time (Shopify ignores empty selling_plan)
    form.querySelectorAll('.form__selling_plan').forEach(function(input) {
      if (vals.plan) {
        input.value = vals.plan;
        input.setAttribute('value', vals.plan);
      } else {
        input.value = '';
        input.removeAttribute('value');
      }
    });

    console.log('[SSW Sync] product:', vals.productId, '| qty:', vals.qty, '| plan:', vals.plan || '(none)');
  }

  /* ─────────────────────────────────────────
     FETCH INTERCEPT — /cart/add safety net
     Patches the request body at the last moment
     in case the theme serialises the form fresh
     at submit time (some themes do this).
     Scoped: only fires when widget is on the page.
  ───────────────────────────────────────── */
  if (!window.fetch.__cartPatched) {

    var _fetch = window.fetch;

    window.fetch = function(input, init) {
      var url = typeof input === 'string' ? input : (input && input.url ? input.url : '');

      if (url.includes('/cart/add')) {

        // Sync DOM first so the form already reflects the correct values
        syncBuyInputs();

        var widget = getWidget();
        if (widget) {
          var vals = getWidgetValues();

          if (vals) {

            // FormData (most Shopify themes use this)
            if (init && init.body instanceof FormData) {
              init.body.set('quantity', vals.qty);
              if (vals.plan) {
                init.body.set('selling_plan', vals.plan);
              } else {
                init.body.delete('selling_plan');
              }

            // JSON body
            } else if (init && typeof init.body === 'string') {
              try {
                var json = JSON.parse(init.body);
                json.quantity = parseInt(vals.qty, 10);
                if (vals.plan) {
                  json.selling_plan = vals.plan;
                } else {
                  delete json.selling_plan;
                }
                init = Object.assign({}, init, { body: JSON.stringify(json) });

              } catch(e) {
                // URL-encoded fallback
                var p = new URLSearchParams(init.body);
                p.set('quantity', vals.qty);
                if (vals.plan) {
                  p.set('selling_plan', vals.plan);
                } else {
                  p.delete('selling_plan');
                }
                init = Object.assign({}, init, { body: p.toString() });
              }
            }

            console.log('[Cart Add] product:', vals.productId, '| qty:', vals.qty, '| plan:', vals.plan || '(none)');
          }
        }
      }

      return _fetch.call(this, input, init);
    };

    window.fetch.__cartPatched = true;
  }

  /* ─────────────────────────────────────────
     EVENT WIRING
     Sync immediately on any widget interaction.
     No setTimeout needed — widget JS updates
     its hidden inputs synchronously on click.
  ───────────────────────────────────────── */
  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-widget="subscribe-save"]')) {
      syncBuyInputs();
    }
  });

  document.addEventListener('change', function(e) {
    if (e.target.closest('[data-widget="subscribe-save"]')) {
      syncBuyInputs();
    }
  });

  // Custom event hook for external triggers
  document.addEventListener('ssw:updated', syncBuyInputs);

  /* ─────────────────────────────────────────
     INIT — sync once DOM is ready
  ───────────────────────────────────────── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', syncBuyInputs);
  } else {
    syncBuyInputs();
  }

})();
