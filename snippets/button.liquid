<script>
(function() {

  if (window.fetch.__cartPatched) return;

  function getWidgetValues() {
    const widget = document.querySelector('[data-widget="subscribe-save"]');
    if (!widget) return null;
    return {
      qty:  widget.querySelector(".wid__varient__qty")?.value || "1",
      plan: widget.querySelector(".wid__selling_plan")?.value || ""
    };
  }

  function syncDOM(qty, plan) {
    // Find the form the button submits
    const buyBtn = document.querySelector(".cstm-buy__btn");
    if (!buyBtn) return;

    const formId = buyBtn.closest("buy-buttons")?.getAttribute("form");
    const form   = formId ? document.getElementById(formId) : buyBtn.closest("form");

    // Update every input inside the actual form
    if (form) {
      form.querySelectorAll('input[name="quantity"]').forEach(inp => {
        inp.value = qty;
        inp.setAttribute("value", qty);
      });
      form.querySelectorAll('input[name="selling_plan"]').forEach(inp => {
        inp.value = plan;
        inp.setAttribute("value", plan);
      });
    }

    // Also update any standalone buy_product__ inputs outside the form
    document.querySelectorAll('.buy_product__qty, .form__qty').forEach(inp => {
      inp.value = qty;
      inp.setAttribute("value", qty);
    });
    document.querySelectorAll('.buy_product__selling_plan, .form__selling_plan').forEach(inp => {
      inp.value = plan;
      inp.setAttribute("value", plan);
    });
  }

  const _fetch = window.fetch;

  window.fetch = function(input, init) {
    const url = typeof input === "string" ? input : input?.url || "";

    if (url.includes("/cart/add")) {
      const vals = getWidgetValues();

      if (vals) {
        // ── FormData ─────────────────────────────────────────────
        if (init?.body instanceof FormData) {
          init.body.set("quantity", vals.qty);
          vals.plan
            ? init.body.set("selling_plan", vals.plan)
            : init.body.delete("selling_plan");

        // ── JSON string ──────────────────────────────────────────
        } else if (typeof init?.body === "string") {
          try {
            const json = JSON.parse(init.body);
            json.quantity = parseInt(vals.qty);
            if (vals.plan) json.selling_plan = vals.plan;
            init = { ...init, body: JSON.stringify(json) };
          } catch(e) {
            const p = new URLSearchParams(init.body);
            p.set("quantity", vals.qty);
            vals.plan ? p.set("selling_plan", vals.plan) : p.delete("selling_plan");
            init = { ...init, body: p.toString() };
          }
        }

        // Sync DOM to match submitted values
        syncDOM(vals.qty, vals.plan);

        console.log("[CartIntercept] ✅ qty:", vals.qty, "| plan:", vals.plan);
      }
    }

    return _fetch.call(this, input, init);
  };

  window.fetch.__cartPatched = true;

})();
</script>
{% endif %}