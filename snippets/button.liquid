{% comment %} <script>
document.addEventListener("DOMContentLoaded", function () {

  const widget = document.querySelector('[data-widget="subscribe-save"]');
  if (!widget) return;

  // BUY BUTTON INPUTS
  const buyBtn = document.querySelector(".cstm-buy__btn");
  const buyQtyInput = document.querySelector(".buy_product__qty");
  const buyIdInput = document.querySelector(".buy_product__id");
  const buySellingPlanInput = document.querySelector(".buy_product__selling_plan");

  // WIDGET INPUTS
  const qtyInput = widget.querySelector("[data-ssw-quantity]");
  const variantInput = widget.querySelector("[data-ssw-variant]");
  const frequencySelect = widget.querySelector("[data-ssw-frequency]");

  // STATE
  let state = {
    quantity: parseInt(qtyInput?.value || 1),
    variantId: variantInput?.value || null,
    purchaseType: "one_time",
    sellingPlan: null
  };

  // -------------------------
  // UPDATE BUY BUTTON INPUTS
  // -------------------------
  function syncToBuyButton() {
    if (buyQtyInput) buyQtyInput.value = state.quantity;
    if (buyIdInput) buyIdInput.value = state.variantId;

    // selling plan logic
    if (state.purchaseType === "subscribe" && state.sellingPlan) {
      buySellingPlanInput.value = state.sellingPlan;
      buySellingPlanInput.disabled = false;
    } else {
      buySellingPlanInput.value = "";
      buySellingPlanInput.disabled = true;
    }
  }

  // -------------------------
  // QUANTITY CHANGE (from plans)
  // -------------------------
  function bindPlanClicks() {
    const plans = widget.querySelectorAll("[data-ssw-plan]");

    plans.forEach(plan => {
      plan.addEventListener("click", () => {
        plans.forEach(p => p.classList.remove("is-selected"));
        plan.classList.add("is-selected");

        state.quantity = parseInt(plan.dataset.quantity || 1);
        qtyInput.value = state.quantity;

        syncToBuyButton();
      });
    });
  }

  // -------------------------
  // PURCHASE TYPE SWITCH
  // -------------------------
  function bindPurchaseType() {
    const rows = widget.querySelectorAll("[data-ssw-purchase-row]");

    rows.forEach(row => {
      row.addEventListener("click", () => {
        rows.forEach(r => r.classList.remove("is-selected"));
        row.classList.add("is-selected");

        state.purchaseType = row.dataset.sswPurchaseRow;

        if (state.purchaseType === "subscribe") {
          const plan = frequencySelect?.value;
          state.sellingPlan = plan || null;
        } else {
          state.sellingPlan = null;
        }

        syncToBuyButton();
      });
    });
  }

  // -------------------------
  // SUBSCRIPTION PLAN CHANGE
  // -------------------------
  function bindFrequencyChange() {
    if (!frequencySelect) return;

    frequencySelect.addEventListener("change", (e) => {
      state.sellingPlan = e.target.value;

      // auto switch to subscribe mode if user selects plan
      state.purchaseType = "subscribe";

      const subscribeRow = widget.querySelector('[data-ssw-purchase-row="subscribe"]');
      const oneTimeRow = widget.querySelector('[data-ssw-purchase-row="one_time"]');

      subscribeRow?.classList.add("is-selected");
      oneTimeRow?.classList.remove("is-selected");

      syncToBuyButton();
    });
  }

  // -------------------------
  // INITIAL SYNC
  // -------------------------
  function init() {
    state.variantId = variantInput?.value;
    state.quantity = parseInt(qtyInput?.value || 1);

    const selectedRow = widget.querySelector(".ssw-purchase-row.is-selected");
    state.purchaseType = selectedRow?.dataset.sswPurchaseRow || "one_time";

    state.sellingPlan = frequencySelect?.value || null;

    bindPlanClicks();
    bindPurchaseType();
    bindFrequencyChange();

    syncToBuyButton();
  }

  init();
});
</script> {% endcomment %}

