{% style %}

.product-accordion {
  width: 100%;
}

.product-accordion__item {
  border-bottom: 1px solid #e5e5e5;
}

.product-accordion__header {
  width: 100%;
  padding: 24px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  border: none;
  background: transparent;
  cursor: pointer;
  text-align: left;
}

.product-accordion__title {
  font-size: 32px;
  font-weight: 600;
  line-height: 1.2;
}

.product-accordion__icon {
  position: relative;
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.product-accordion__icon span {
  position: absolute;
  top: 50%;
  left: 50%;
  background: currentColor;
  transform: translate(-50%, -50%);
  transition: all .3s ease;
}

.icon-horizontal {
  width: 18px;
  height: 2px;
}

.icon-vertical {
  width: 2px;
  height: 18px;
}

.product-accordion__item.active .icon-vertical {
  opacity: 0;
  transform: translate(-50%, -50%) rotate(90deg);
}

.product-accordion__content {
  max-height: 0;
  overflow: hidden;
  transition: max-height .4s ease;
}

.product-accordion__content-inner {
  padding-bottom: 24px;
}

.product-accordion__content-inner p:last-child {
  margin-bottom: 0;
}

@media screen and (max-width: 749px) {
  .product-accordion__title {
    font-size: 24px;
  }
}

{% endstyle %}

<div class="product-accordion">
  {% for block in section.blocks %}
    {% assign answer = block.settings.answer
      | replace: '<p>', ''
      | replace: '</p>', ''
    %}

    <div
      class="product-accordion__item {% if block.settings.default_open %}active{% endif %}"
      {{ block.shopify_attributes }}
    >
      <button
        class="product-accordion__header"
        type="button"
        aria-expanded="{% if block.settings.default_open %}true{% else %}false{% endif %}"
      >
        <span class="product-accordion__title">
          {{ block.settings.question }}
        </span>

        <span class="product-accordion__icon">
          <span class="icon-horizontal"></span>
          <span class="icon-vertical"></span>
        </span>
      </button>

      <div class="product-accordion__content">
        <div class="product-accordion__content-inner">
          {{ answer }}
        </div>
      </div>
    </div>
  {% endfor %}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const accordionItems = document.querySelectorAll('.product-accordion__item');

  function closeAll(exceptItem = null) {
    accordionItems.forEach((item) => {
      if (item === exceptItem) return;

      item.classList.remove('active');

      const content = item.querySelector('.product-accordion__content');
      const button = item.querySelector('.product-accordion__header');

      content.style.maxHeight = null;
      button.setAttribute('aria-expanded', 'false');
    });
  }

  accordionItems.forEach((item) => {
    const button = item.querySelector('.product-accordion__header');
    const content = item.querySelector('.product-accordion__content');

    // Handle active class already present
    if (item.classList.contains('active')) {
      content.style.maxHeight = content.scrollHeight + 'px';
      button.setAttribute('aria-expanded', 'true');
    }

    button.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      closeAll(item);

      if (isActive) {
        item.classList.remove('active');
        content.style.maxHeight = null;
        button.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('active');
        content.style.maxHeight = content.scrollHeight + 'px';
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
});
</script>