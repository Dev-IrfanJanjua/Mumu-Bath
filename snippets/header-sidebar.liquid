            <div id="header-panel-{{ forloop.index }}" class="header-sidebar__sub-panel" hidden>

              {%- comment -%} Back button {%- endcomment -%}
              <button type="button" class="header-sidebar__back-button link-faded {% if show_dividers %}is-divided{% endif %} text-with-icon {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %} md:hidden" data-action="close-panel">
                {%- render 'icon' with 'chevron-left', width: 12, direction_aware: true -%}
                {{- link.title -}}
              </button>

              {%- comment -%}
                ACCORDION LIST — sirf links andar, koi promo nahi
              {%- endcomment -%}
              <ul class="header-sidebar__linklist second {% if show_dividers %}divide-y{% endif %} unstyled-list" role="list">
                {%- for sub_link in link.links -%}
                  <li>
                    {%- if sub_link.links.size > 0 -%}

                      {%- comment -%} Match promo block by handle {%- endcomment -%}
                      {%- assign matched_promo = nil -%}
                      {%- for promo_block in section.blocks -%}
                        {%- if promo_block.type == 'mega_menu_item_promo'
                            and promo_block.settings.menu_item_handle == sub_link.handle -%}
                          {%- assign matched_promo = promo_block -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- comment -%} Side icon image {%- endcomment -%}
                      {%- assign side_image = nil -%}
                      {%- if matched_promo != nil and matched_promo.settings.side_image != blank -%}
                        {%- assign side_image = matched_promo.settings.side_image -%}
                      {%- endif -%}

                      {%- comment -%}
                        data-link-handle is used by JS to match this accordion
                        to its promo panel below the ul
                      {%- endcomment -%}
                      <details
                        is="accordion-disclosure"
                        class="group header-sidebar__accordion"
                        data-link-handle="{{ sub_link.handle }}"
                      >
                        <summary class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                          <div class="mega-row">
                            {%- if side_image != blank -%}
                              <span class="mega-menu__sidebar-icon" aria-hidden="true">
                                {{- side_image | image_url: width: 40 | image_tag:
                                  loading: 'lazy',
                                  widths: '40',
                                  class: 'mega-menu__sidebar-icon-img'
                                -}}
                              </span>
                            {%- endif -%}
                            {{- sub_link.title -}}
                          </div>
                          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="9" viewBox="0 0 17 9" fill="none">
                            <path d="M-2.96076e-07 1.00002C3.22144 1.00002 6.04325 3.25828 8.46813 7.77344C10.4866 3.25828 13.0835 1.00002 16.2589 1.00002" stroke="black" stroke-width="2" stroke-linejoin="round"/>
                          </svg>
                        </summary>

                        {%- comment -%} SIRF nested links — koi promo nahi andar {%- endcomment -%}
                        <div class="header-sidebar__nested-linklist">
                          {%- for sub_sub_link in sub_link.links -%}
                            <a href="{{ sub_sub_link.url }}" class="link-faded-reverse">{{ sub_sub_link.title }}</a>
                          {%- endfor -%}
                        </div>

                      </details>

                    {%- else -%}
                      <a href="{{ sub_link.url }}" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                        {{- sub_link.title -}}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>

              {%- comment -%}
                ═══════════════════════════════════════════════════════
                PROMO PANELS — ul ke BAAD, sub-panel ke andar neeche
                Har sub_link ka aik panel, data-promo-handle se match
                JS inhe toggle karta hai based on open accordion
                ═══════════════════════════════════════════════════════
              {%- endcomment -%}
              <div class="header-sidebar__promo-area">
                {%- for sub_link in link.links -%}
                  {%- if sub_link.links.size > 0 -%}

                    {%- assign matched_promo = nil -%}
                    {%- for promo_block in section.blocks -%}
                      {%- if promo_block.type == 'mega_menu_item_promo'
                          and promo_block.settings.menu_item_handle == sub_link.handle -%}
                        {%- assign matched_promo = promo_block -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}

                    {%- if matched_promo != nil -%}
                      {%- comment -%} CTA values {%- endcomment -%}
                      {%- if matched_promo.settings.button_text != blank -%}
                        {%- assign sb_cta_text = matched_promo.settings.button_text -%}
                        {%- assign sb_cta_url  = matched_promo.settings.button_link | default: sub_link.url -%}
                      {%- else -%}
                        {%- assign sb_cta_text = 'Shop ' | append: sub_link.title -%}
                        {%- assign sb_cta_url  = sub_link.url -%}
                      {%- endif -%}

                      {%- comment -%}
                        data-promo-handle must match the accordion's data-link-handle
                        JS shows/hides these panels via this attribute
                        Default hidden — JS shows the one whose accordion is open
                      {%- endcomment -%}
                      <div
                        class="header-sidebar__promo-panel"
                        data-promo-handle="{{ sub_link.handle }}"
                        hidden
                      >
                        {%- if matched_promo.settings.promo_image != blank -%}
                          <a href="{{ matched_promo.settings.promo_link | default: '#' }}" class="sidebar-promo-card">
                            <img
                              src="{{ matched_promo.settings.promo_image | image_url: width: 600 }}"
                              alt="{{ matched_promo.settings.promo_title | escape }}"
                              width="600"
                              height="400"
                              loading="lazy"
                              class="sidebar-promo-card__img"
                            >
                            {%- if matched_promo.settings.promo_title != blank -%}
                              <span class="sidebar-promo-card__label">{{ matched_promo.settings.promo_title }}</span>
                            {%- endif -%}
                          </a>
                        {%- endif -%}

                        {%- if matched_promo.settings.promo_image_2 != blank -%}
                          <a href="{{ matched_promo.settings.promo_link_2 | default: '#' }}" class="sidebar-promo-card">
                            <img
                              src="{{ matched_promo.settings.promo_image_2 | image_url: width: 600 }}"
                              alt="{{ matched_promo.settings.promo_title_2 | escape }}"
                              width="600"
                              height="400"
                              loading="lazy"
                              class="sidebar-promo-card__img"
                            >
                            {%- if matched_promo.settings.promo_title_2 != blank -%}
                              <span class="sidebar-promo-card__label">{{ matched_promo.settings.promo_title_2 }}</span>
                            {%- endif -%}
                          </a>
                        {%- endif -%}

                        <a href="{{ sb_cta_url }}" class="mega-menu__panel-cta">
                          {{ sb_cta_text }}
                        </a>
                      </div>

                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- comment -%} /.header-sidebar__promo-area {%- endcomment -%}

            </div>
            {%- comment -%} /.header-sidebar__sub-panel {%- endcomment -%}

          {%- endif -%}
        {%- endfor -%}

      </div>
    </header-sidebar-collapsible-panel>
  {%- endif -%}

</header-sidebar>

<script>
(function () {
  'use strict';

  function initSidebarPromo() {
    var sidebar = document.getElementById('sidebar-menu');
    if (!sidebar) return;

    // ── Single-open: jab ek details khule, baaki band karo ──────────────
    sidebar.addEventListener('toggle', function (e) {
      var details = e.target;
      if (!details || details.tagName !== 'DETAILS') return;

      var subPanel = details.closest('.header-sidebar__sub-panel');
      if (!subPanel) return;

      if (details.open) {
        // Close all sibling accordions in same sub-panel
        subPanel.querySelectorAll('details[open]').forEach(function (sib) {
          if (sib !== details) {
            sib.removeAttribute('open');
            sib.setAttribute('aria-expanded', 'false');
          }
        });

        // Show matching promo panel, hide others
        var handle = details.getAttribute('data-link-handle');
        showPromo(subPanel, handle);
      } else {
        // If closed and no other is open, hide all promos
        var anyOpen = subPanel.querySelector('details[open]');
        if (!anyOpen) hideAllPromos(subPanel);
      }
    }, true);

    // ── Also respond when a new sub-panel becomes visible (back/forward) ─
    // MutationObserver: watch sub-panel hidden attribute removal
    var observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'hidden') {
          var panel = mutation.target;
          if (!panel.classList.contains('header-sidebar__sub-panel')) return;
          if (!panel.hasAttribute('hidden')) {
            // Panel just became visible — check if any accordion already open
            var openDetails = panel.querySelector('details[open]');
            if (openDetails) {
              showPromo(panel, openDetails.getAttribute('data-link-handle'));
            } else {
              hideAllPromos(panel);
            }
          }
        }
      });
    });

    sidebar.querySelectorAll('.header-sidebar__sub-panel').forEach(function (panel) {
      observer.observe(panel, { attributes: true });
    });
  }

  function showPromo(subPanel, handle) {
    var promoArea = subPanel.querySelector('.header-sidebar__promo-area');
    if (!promoArea) return;

    promoArea.querySelectorAll('.header-sidebar__promo-panel').forEach(function (panel) {
      if (panel.getAttribute('data-promo-handle') === handle) {
        panel.removeAttribute('hidden');
        // Trigger animation by forcing reflow
        panel.classList.remove('is-visible');
        void panel.offsetWidth;
        panel.classList.add('is-visible');
      } else {
        panel.setAttribute('hidden', '');
        panel.classList.remove('is-visible');
      }
    });
  }

  function hideAllPromos(subPanel) {
    var promoArea = subPanel.querySelector('.header-sidebar__promo-area');
    if (!promoArea) return;
    promoArea.querySelectorAll('.header-sidebar__promo-panel').forEach(function (p) {
      p.setAttribute('hidden', '');
      p.classList.remove('is-visible');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarPromo);
  } else {
    initSidebarPromo();
  }

  document.addEventListener('shopify:section:load', initSidebarPromo);
})();
</script>


<style>
/* ==========================================================================
   HEADER SIDEBAR — Promo area below accordion list
   ========================================================================== */

/* ── Accordion summary row layout ─────────────────────────────────────── */
.mega-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

.mega-menu__sidebar-icon {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mega-menu__sidebar-icon-img {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

/* Chevron rotation when accordion is open */
.header-sidebar__accordion > summary svg {
  flex-shrink: 0;
  transition: transform 0.25s ease;
}

.header-sidebar__accordion[open] > summary svg {
  transform: rotate(180deg);
}

/* ── Promo area container — sits below the <ul>, inside sub-panel ──────── */
.header-sidebar__promo-area {
  /* No padding/background by itself — panels carry their own */
}

/* ── Individual promo panel (one per sub_link) ─────────────────────────── */
.header-sidebar__promo-panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0 16px 40px;
    margin: 10px 0 4px;

  /* Hidden state: no animation */
  opacity: 0;
  transform: translateY(6px);
}

/* Visible state triggered by JS adding .is-visible */
.header-sidebar__promo-panel.is-visible {
  animation: sidebarPromoIn 0.25s ease forwards;
}

@keyframes sidebarPromoIn {
  from {
    opacity: 0;
    transform: translateY(6px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ── Promo image card ──────────────────────────────────────────────────── */
.sidebar-promo-card {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: 12px;
  text-decoration: none;
  min-height: 110px;
  background: #e8e8e8;
}

.sidebar-promo-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.sidebar-promo-card:active .sidebar-promo-card__img {
  transform: scale(1.03);
}

/* Absolute label top-left over image */
.sidebar-promo-card__label {
  position: absolute;
  top: 16px;
  left: 16px;
  color: #000;
  font-family: "Plus Jakarta Sans";
  font-size: 18px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
}

/* ── CTA button — full width pill ─────────────────────────────────────── */
.sidebar-promo__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 12px 20px;
  margin-top: 4px;
  border-radius: 100px;
  background: #f5c518;
  color: #111;
  font-size: 0.85rem;
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background 0.2s ease;
  text-align: center;
}

.sidebar-promo__cta:active {
  background: #e6b800;
}

.header-sidebar__linklist.second    .header-sidebar__linklist-button {
       border:0px;
}


.header-sidebar::part(content)::-webkit-scrollbar {
  display: none;
}
.header-sidebar__promo-panel a.mega-menu__panel-cta {
    width: 100%;
    display: flex;
}

</style>
