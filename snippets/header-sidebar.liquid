                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- comment -%} Resolve CTA values {%- endcomment -%}
                      {%- if matched_promo != nil and matched_promo.settings.button_text != blank -%}
                        {%- assign sb_cta_text = matched_promo.settings.button_text -%}
                        {%- assign sb_cta_url  = matched_promo.settings.button_link | default: sub_link.url -%}
                      {%- else -%}
                        {%- assign sb_cta_text = 'Shop ' | append: sub_link.title -%}
                        {%- assign sb_cta_url  = sub_link.url -%}
                      {%- endif -%}

                      {%- comment -%}
                        Pass promo image URLs via data-attrs so the observer JS can
                        inject them without any extra server round-trips.
                      {%- endcomment -%}
                      {%- comment -%} Resolve side image from matched block {%- endcomment -%}
                      {%- assign side_image = nil -%}
                      {%- if matched_promo != nil and matched_promo.settings.side_image != blank -%}
                        {%- assign side_image = matched_promo.settings.side_image -%}
                      {%- endif -%}

                      <details
                        is="accordion-disclosure"
                        class="group header-sidebar__accordion"
                        data-link-handle="{{ sub_link.handle }}"
                        data-cta-text="{{ sb_cta_text | escape }}"
                        data-cta-url="{{ sb_cta_url | escape }}"
                        {%- if matched_promo != nil -%}
                          {%- if matched_promo.settings.promo_image != blank %}
                            data-img1-src="{{ matched_promo.settings.promo_image | image_url: width: 600 }}"
                            data-img1-alt="{{ matched_promo.settings.promo_title | escape }}"
                            data-img1-label="{{ matched_promo.settings.promo_title | escape }}"
                            data-img1-link="{{ matched_promo.settings.promo_link | default: '#' | escape }}"
                          {%- endif -%}
                          {%- if matched_promo.settings.promo_image_2 != blank %}
                            data-img2-src="{{ matched_promo.settings.promo_image_2 | image_url: width: 600 }}"
                            data-img2-alt="{{ matched_promo.settings.promo_title_2 | escape }}"
                            data-img2-label="{{ matched_promo.settings.promo_title_2 | escape }}"
                            data-img2-link="{{ matched_promo.settings.promo_link_2 | default: '#' | escape }}"
                          {%- endif -%}
                        {%- endif -%}
                      >
                        <summary class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                          <div class="meaga-row">
                          {%- if side_image != blank -%}
                            <span class="mega-menu__sidebar-icon" aria-hidden="true">
                              {{- side_image | image_url: width: 40 | image_tag:
                                loading: 'lazy',
                                widths: '40',
                                class: 'mega-menu__sidebar-icon-img'
                              -}}
                            </span>
                          {%- endif -%}
                          {{- sub_link.title -}}
                        </div>
                          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="9" viewBox="0 0 17 9" fill="none">
                            <path d="M-2.96076e-07 1.00002C3.22144 1.00002 6.04325 3.25828 8.46813 7.77344C10.4866 3.25828 13.0835 1.00002 16.2589 1.00002" stroke="black" stroke-width="2" stroke-linejoin="round"/>
                          </svg>
                        </summary>

                        {%- comment -%} Nested child links {%- endcomment -%}
                        <div class="header-sidebar__nested-linklist">
                          {%- for sub_sub_link in sub_link.links -%}
                            <a href="{{ sub_sub_link.url }}" class="link-faded-reverse">{{ sub_sub_link.title }}</a>
                          {%- endfor -%}
                        </div>

                       

                      </details>

                    {%- else -%}
                      <a href="{{ sub_link.url }}" class="header-sidebar__linklist-button {% if section.settings.sidebar_text_font == 'heading' %}h6{% endif %}">
                        {{- sub_link.title -}}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>

                {%- comment -%}
                          Promo slot — rendered once per accordion, populated/swapped by JS
                          when the <details> opens. Kept inside <details> so it collapses
                          with the accordion automatically.
                {%- endcomment -%}
                        {%- if matched_promo != nil -%}
                          <div class="header-sidebar__accordion-promo" data-promo-slot>
                            {%- if matched_promo.settings.promo_image != blank -%}
                              <a href="{{ matched_promo.settings.promo_link | default: '#' }}" class="sidebar-promo-card">
                                <img
                                  src="{{ matched_promo.settings.promo_image | image_url: width: 600 }}"
                                  alt="{{ matched_promo.settings.promo_title | escape }}"
                                  width="600"
                                  height="400"
                                  loading="lazy"
                                  class="sidebar-promo-card__img"
                                >
                                {%- if matched_promo.settings.promo_title != blank -%}
                                  <span class="sidebar-promo-card__label">{{ matched_promo.settings.promo_title }}</span>
                                {%- endif -%}
                              </a>
                            {%- endif -%}

                            {%- if matched_promo.settings.promo_image_2 != blank -%}
                              <a href="{{ matched_promo.settings.promo_link_2 | default: '#' }}" class="sidebar-promo-card">
                                <img
                                  src="{{ matched_promo.settings.promo_image_2 | image_url: width: 600 }}"
                                  alt="{{ matched_promo.settings.promo_title_2 | escape }}"
                                  width="600"
                                  height="400"
                                  loading="lazy"
                                  class="sidebar-promo-card__img"
                                >
                                {%- if matched_promo.settings.promo_title_2 != blank -%}
                                  <span class="sidebar-promo-card__label">{{ matched_promo.settings.promo_title_2 }}</span>
                                {%- endif -%}
                              </a>
                            {%- endif -%}

                            {%- comment -%} CTA button {%- endcomment -%}
                            <a href="{{ sb_cta_url }}" class="sidebar-promo__cta button">
                              {{ sb_cta_text }}
                            </a>
                          </div>
                        {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </header-sidebar-collapsible-panel>
  {%- endif -%}

</header-sidebar>

{%- comment -%}
  MutationObserver — watches for <details open> changes inside the sidebar.
  When a details opens: its [data-promo-slot] is already rendered in the DOM
  (inside the details element), so it shows automatically with CSS.
  We close all other open details in the same panel to enforce single-open behaviour.
{%- endcomment -%}
<script>
(function () {
  'use strict';

  function initSidebarAccordionPromo() {
    var sidebar = document.getElementById('sidebar-menu');
    if (!sidebar) return;

    // ── Enforce single-open per sub-panel: close siblings when one opens ──
    sidebar.addEventListener('toggle', function (e) {
      var details = e.target;
      if (!details || details.tagName !== 'DETAILS') return;
      if (!details.open) return;

      // Find sibling <details> in the same <ul> and close them
      var parentList = details.closest('ul');
      if (!parentList) return;

      parentList.querySelectorAll('details[open]').forEach(function (sibling) {
        if (sibling !== details) {
          sibling.removeAttribute('open');
          sibling.setAttribute('aria-expanded', 'false');
        }
      });
    }, true); // capture phase so it fires before accordion-disclosure's own handler
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarAccordionPromo);
  } else {
    initSidebarAccordionPromo();
  }

  document.addEventListener('shopify:section:load', initSidebarAccordionPromo);
})();
</script> {% endcomment %}








